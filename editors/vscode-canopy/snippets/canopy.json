{
  "Module Declaration": {
    "prefix": "module",
    "body": [
      "module ${1:ModuleName} exposing (${2:..})",
      "",
      "$0"
    ],
    "description": "Create a new module declaration"
  },
  "Module Declaration with Port": {
    "prefix": "module-port",
    "body": [
      "port module ${1:ModuleName} exposing (${2:..})",
      "",
      "$0"
    ],
    "description": "Create a new port module declaration"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import ${1:Module}"
    ],
    "description": "Import a module"
  },
  "Import Exposing": {
    "prefix": "import-exposing",
    "body": [
      "import ${1:Module} exposing (${2:..})"
    ],
    "description": "Import a module exposing specific items"
  },
  "Import As": {
    "prefix": "import-as",
    "body": [
      "import ${1:Module} as ${2:Alias}"
    ],
    "description": "Import a module with an alias"
  },
  "Foreign Import JavaScript": {
    "prefix": "foreign-import",
    "body": [
      "foreign import javascript \"${1:path/to/file.js}\" as ${2:Module}"
    ],
    "description": "Import a JavaScript FFI module"
  },
  "Type Alias": {
    "prefix": "type-alias",
    "body": [
      "type alias ${1:Name} =",
      "    { ${2:field} : ${3:Type}",
      "    }"
    ],
    "description": "Create a type alias for a record"
  },
  "Type Alias Simple": {
    "prefix": "type-alias-simple",
    "body": [
      "type alias ${1:Name} = ${2:Type}"
    ],
    "description": "Create a simple type alias"
  },
  "Custom Type": {
    "prefix": "type",
    "body": [
      "type ${1:Name}",
      "    = ${2:Constructor1}",
      "    | ${3:Constructor2}"
    ],
    "description": "Create a custom type (union type)"
  },
  "Custom Type with Parameters": {
    "prefix": "type-param",
    "body": [
      "type ${1:Name} ${2:a}",
      "    = ${3:Constructor1} ${2:a}",
      "    | ${4:Constructor2}"
    ],
    "description": "Create a custom type with type parameters"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "${1:functionName} : ${2:Type} -> ${3:ReturnType}",
      "${1:functionName} ${4:param} =",
      "    $0"
    ],
    "description": "Create a function with type annotation"
  },
  "Function with Multiple Parameters": {
    "prefix": "fn2",
    "body": [
      "${1:functionName} : ${2:Type1} -> ${3:Type2} -> ${4:ReturnType}",
      "${1:functionName} ${5:param1} ${6:param2} =",
      "    $0"
    ],
    "description": "Create a function with two parameters"
  },
  "Function with Three Parameters": {
    "prefix": "fn3",
    "body": [
      "${1:functionName} : ${2:Type1} -> ${3:Type2} -> ${4:Type3} -> ${5:ReturnType}",
      "${1:functionName} ${6:param1} ${7:param2} ${8:param3} =",
      "    $0"
    ],
    "description": "Create a function with three parameters"
  },
  "Anonymous Function": {
    "prefix": "lambda",
    "body": [
      "\\${1:param} -> ${0:body}"
    ],
    "description": "Create an anonymous function (lambda)"
  },
  "Anonymous Function Multi-param": {
    "prefix": "lambda2",
    "body": [
      "\\${1:param1} ${2:param2} -> ${0:body}"
    ],
    "description": "Create an anonymous function with multiple parameters"
  },
  "If Expression": {
    "prefix": "if",
    "body": [
      "if ${1:condition} then",
      "    ${2:thenBranch}",
      "",
      "else",
      "    ${0:elseBranch}"
    ],
    "description": "Create an if-then-else expression"
  },
  "If Expression Inline": {
    "prefix": "if-inline",
    "body": [
      "if ${1:condition} then ${2:thenBranch} else ${0:elseBranch}"
    ],
    "description": "Create an inline if-then-else expression"
  },
  "Case Expression": {
    "prefix": "case",
    "body": [
      "case ${1:expression} of",
      "    ${2:Pattern1} ->",
      "        ${3:result1}",
      "",
      "    ${4:Pattern2} ->",
      "        ${0:result2}"
    ],
    "description": "Create a case expression"
  },
  "Case Maybe": {
    "prefix": "case-maybe",
    "body": [
      "case ${1:maybeValue} of",
      "    Just ${2:value} ->",
      "        ${3:result}",
      "",
      "    Nothing ->",
      "        ${0:default}"
    ],
    "description": "Create a case expression for Maybe"
  },
  "Case Result": {
    "prefix": "case-result",
    "body": [
      "case ${1:result} of",
      "    Ok ${2:value} ->",
      "        ${3:successResult}",
      "",
      "    Err ${4:error} ->",
      "        ${0:errorResult}"
    ],
    "description": "Create a case expression for Result"
  },
  "Case List": {
    "prefix": "case-list",
    "body": [
      "case ${1:list} of",
      "    [] ->",
      "        ${2:emptyResult}",
      "",
      "    ${3:x} :: ${4:xs} ->",
      "        ${0:consResult}"
    ],
    "description": "Create a case expression for List"
  },
  "Let Expression": {
    "prefix": "let",
    "body": [
      "let",
      "    ${1:name} =",
      "        ${2:value}",
      "in",
      "${0:expression}"
    ],
    "description": "Create a let expression"
  },
  "Let Expression Multiple": {
    "prefix": "let-multi",
    "body": [
      "let",
      "    ${1:name1} =",
      "        ${2:value1}",
      "",
      "    ${3:name2} =",
      "        ${4:value2}",
      "in",
      "${0:expression}"
    ],
    "description": "Create a let expression with multiple bindings"
  },
  "Record": {
    "prefix": "record",
    "body": [
      "{ ${1:field1} = ${2:value1}",
      ", ${3:field2} = ${4:value2}",
      "}"
    ],
    "description": "Create a record literal"
  },
  "Record Update": {
    "prefix": "record-update",
    "body": [
      "{ ${1:record} | ${2:field} = ${0:newValue} }"
    ],
    "description": "Create a record update expression"
  },
  "Record Update Multiple": {
    "prefix": "record-update-multi",
    "body": [
      "{ ${1:record}",
      "    | ${2:field1} = ${3:newValue1}",
      "    , ${4:field2} = ${5:newValue2}",
      "}"
    ],
    "description": "Create a record update with multiple fields"
  },
  "List": {
    "prefix": "list",
    "body": [
      "[ ${1:item1}",
      ", ${2:item2}",
      ", ${3:item3}",
      "]"
    ],
    "description": "Create a list literal"
  },
  "Tuple": {
    "prefix": "tuple",
    "body": [
      "( ${1:first}, ${2:second} )"
    ],
    "description": "Create a tuple"
  },
  "Triple": {
    "prefix": "triple",
    "body": [
      "( ${1:first}, ${2:second}, ${3:third} )"
    ],
    "description": "Create a triple"
  },
  "Port Outgoing": {
    "prefix": "port-out",
    "body": [
      "port ${1:portName} : ${2:Type} -> Cmd msg"
    ],
    "description": "Create an outgoing port"
  },
  "Port Incoming": {
    "prefix": "port-in",
    "body": [
      "port ${1:portName} : (${2:Type} -> msg) -> Sub msg"
    ],
    "description": "Create an incoming port"
  },
  "Main Program": {
    "prefix": "main",
    "body": [
      "main : Program () Model Msg",
      "main =",
      "    Browser.sandbox",
      "        { init = init",
      "        , update = update",
      "        , view = view",
      "        }"
    ],
    "description": "Create a main sandbox program"
  },
  "Main Element": {
    "prefix": "main-element",
    "body": [
      "main : Program () Model Msg",
      "main =",
      "    Browser.element",
      "        { init = init",
      "        , update = update",
      "        , subscriptions = subscriptions",
      "        , view = view",
      "        }"
    ],
    "description": "Create a main element program"
  },
  "Main Document": {
    "prefix": "main-document",
    "body": [
      "main : Program () Model Msg",
      "main =",
      "    Browser.document",
      "        { init = init",
      "        , update = update",
      "        , subscriptions = subscriptions",
      "        , view = view",
      "        }"
    ],
    "description": "Create a main document program"
  },
  "Main Application": {
    "prefix": "main-application",
    "body": [
      "main : Program () Model Msg",
      "main =",
      "    Browser.application",
      "        { init = init",
      "        , update = update",
      "        , subscriptions = subscriptions",
      "        , view = view",
      "        , onUrlChange = UrlChanged",
      "        , onUrlRequest = LinkClicked",
      "        }"
    ],
    "description": "Create a main application program"
  },
  "Model": {
    "prefix": "model",
    "body": [
      "type alias Model =",
      "    { ${1:field} : ${2:Type}",
      "    }"
    ],
    "description": "Create a Model type alias"
  },
  "Init": {
    "prefix": "init",
    "body": [
      "init : Model",
      "init =",
      "    { ${1:field} = ${2:initialValue}",
      "    }"
    ],
    "description": "Create an init function"
  },
  "Init with Cmd": {
    "prefix": "init-cmd",
    "body": [
      "init : () -> ( Model, Cmd Msg )",
      "init _ =",
      "    ( { ${1:field} = ${2:initialValue}",
      "      }",
      "    , Cmd.none",
      "    )"
    ],
    "description": "Create an init function with Cmd"
  },
  "Msg": {
    "prefix": "msg",
    "body": [
      "type Msg",
      "    = ${1:NoOp}",
      "    | ${2:SomeAction}"
    ],
    "description": "Create a Msg type"
  },
  "Update": {
    "prefix": "update",
    "body": [
      "update : Msg -> Model -> Model",
      "update msg model =",
      "    case msg of",
      "        ${1:NoOp} ->",
      "            model",
      "",
      "        ${2:SomeAction} ->",
      "            ${0:model}"
    ],
    "description": "Create an update function (sandbox)"
  },
  "Update with Cmd": {
    "prefix": "update-cmd",
    "body": [
      "update : Msg -> Model -> ( Model, Cmd Msg )",
      "update msg model =",
      "    case msg of",
      "        ${1:NoOp} ->",
      "            ( model, Cmd.none )",
      "",
      "        ${2:SomeAction} ->",
      "            ( ${0:model}, Cmd.none )"
    ],
    "description": "Create an update function with Cmd"
  },
  "View": {
    "prefix": "view",
    "body": [
      "view : Model -> Html Msg",
      "view model =",
      "    div []",
      "        [ ${0:text \"Hello, Canopy!\"} ]"
    ],
    "description": "Create a view function"
  },
  "View Document": {
    "prefix": "view-document",
    "body": [
      "view : Model -> Browser.Document Msg",
      "view model =",
      "    { title = \"${1:Page Title}\"",
      "    , body =",
      "        [ div []",
      "            [ ${0:text \"Hello, Canopy!\"} ]",
      "        ]",
      "    }"
    ],
    "description": "Create a document view function"
  },
  "Subscriptions": {
    "prefix": "subscriptions",
    "body": [
      "subscriptions : Model -> Sub Msg",
      "subscriptions model =",
      "    Sub.none"
    ],
    "description": "Create a subscriptions function"
  },
  "HTTP Get": {
    "prefix": "http-get",
    "body": [
      "Http.get",
      "    { url = \"${1:url}\"",
      "    , expect = Http.expectJson ${2:GotData} ${3:decoder}",
      "    }"
    ],
    "description": "Create an HTTP GET request"
  },
  "HTTP Post": {
    "prefix": "http-post",
    "body": [
      "Http.post",
      "    { url = \"${1:url}\"",
      "    , body = Http.jsonBody ${2:jsonValue}",
      "    , expect = Http.expectJson ${3:GotResponse} ${4:decoder}",
      "    }"
    ],
    "description": "Create an HTTP POST request"
  },
  "JSON Decoder": {
    "prefix": "decoder",
    "body": [
      "${1:decoderName} : Decoder ${2:Type}",
      "${1:decoderName} =",
      "    Decode.map ${2:Type}",
      "        (Decode.field \"${3:fieldName}\" Decode.${4:string})"
    ],
    "description": "Create a JSON decoder"
  },
  "JSON Decoder Object": {
    "prefix": "decoder-object",
    "body": [
      "${1:decoderName} : Decoder ${2:Type}",
      "${1:decoderName} =",
      "    Decode.succeed ${2:Type}",
      "        |> required \"${3:field1}\" Decode.${4:string}",
      "        |> required \"${5:field2}\" Decode.${6:int}"
    ],
    "description": "Create a JSON object decoder with pipeline"
  },
  "JSON Encoder": {
    "prefix": "encoder",
    "body": [
      "${1:encoderName} : ${2:Type} -> Encode.Value",
      "${1:encoderName} ${3:value} =",
      "    Encode.object",
      "        [ ( \"${4:fieldName}\", Encode.${5:string} ${3:value}.${4:fieldName} )",
      "        ]"
    ],
    "description": "Create a JSON encoder"
  },
  "Task": {
    "prefix": "task",
    "body": [
      "Task.attempt ${1:GotResult} ${2:taskExpression}"
    ],
    "description": "Create a Task.attempt expression"
  },
  "Task Map": {
    "prefix": "task-map",
    "body": [
      "${1:task}",
      "    |> Task.map ${2:transformFn}",
      "    |> Task.attempt ${3:GotResult}"
    ],
    "description": "Create a Task with map"
  },
  "Task And Then": {
    "prefix": "task-andthen",
    "body": [
      "${1:task}",
      "    |> Task.andThen ${2:nextTaskFn}",
      "    |> Task.attempt ${3:GotResult}"
    ],
    "description": "Create a Task chain with andThen"
  },
  "Pipeline Forward": {
    "prefix": "pipe",
    "body": [
      "${1:value}",
      "    |> ${2:function1}",
      "    |> ${3:function2}"
    ],
    "description": "Create a forward pipeline"
  },
  "Html Div": {
    "prefix": "div",
    "body": [
      "div [ ${1:class \"${2:className}\"} ]",
      "    [ ${0:text \"content\"} ]"
    ],
    "description": "Create a div element"
  },
  "Html Button": {
    "prefix": "button",
    "body": [
      "button [ onClick ${1:Msg} ]",
      "    [ text \"${0:Click me}\" ]"
    ],
    "description": "Create a button element"
  },
  "Html Input": {
    "prefix": "input",
    "body": [
      "input",
      "    [ type_ \"${1:text}\"",
      "    , placeholder \"${2:Enter text...}\"",
      "    , value model.${3:fieldName}",
      "    , onInput ${4:UpdateField}",
      "    ]",
      "    []"
    ],
    "description": "Create an input element"
  },
  "Html Link": {
    "prefix": "a",
    "body": [
      "a [ href \"${1:url}\" ]",
      "    [ text \"${0:Link text}\" ]"
    ],
    "description": "Create an anchor element"
  },
  "Html List": {
    "prefix": "ul",
    "body": [
      "ul []",
      "    (List.map ${1:viewItem} ${2:items})"
    ],
    "description": "Create an unordered list"
  },
  "Comment Line": {
    "prefix": "comment",
    "body": [
      "-- ${0:comment}"
    ],
    "description": "Create a line comment"
  },
  "Comment Block": {
    "prefix": "comment-block",
    "body": [
      "{-",
      "${0:comment}",
      "-}"
    ],
    "description": "Create a block comment"
  },
  "Documentation Comment": {
    "prefix": "doc",
    "body": [
      "{-| ${0:description}",
      "-}"
    ],
    "description": "Create a documentation comment"
  },
  "Debug Log": {
    "prefix": "debug-log",
    "body": [
      "Debug.log \"${1:label}\" ${0:value}"
    ],
    "description": "Create a Debug.log expression"
  },
  "Debug Todo": {
    "prefix": "debug-todo",
    "body": [
      "Debug.todo \"${0:implement this}\""
    ],
    "description": "Create a Debug.todo placeholder"
  },
  "Test Module": {
    "prefix": "test-module",
    "body": [
      "module ${1:ModuleName}Test exposing (..)",
      "",
      "import Expect",
      "import Test exposing (..)",
      "import ${1:ModuleName}",
      "",
      "",
      "suite : Test",
      "suite =",
      "    describe \"${1:ModuleName}\"",
      "        [ test \"${2:description}\" <|",
      "            \\_ ->",
      "                ${0:Expect.equal True True}",
      "        ]"
    ],
    "description": "Create a test module"
  },
  "Test": {
    "prefix": "test",
    "body": [
      "test \"${1:description}\" <|",
      "    \\_ ->",
      "        ${0:Expect.equal True True}"
    ],
    "description": "Create a test case"
  },
  "Describe": {
    "prefix": "describe",
    "body": [
      "describe \"${1:description}\"",
      "    [ test \"${2:testDescription}\" <|",
      "        \\_ ->",
      "            ${0:Expect.equal True True}",
      "    ]"
    ],
    "description": "Create a describe block"
  }
}
