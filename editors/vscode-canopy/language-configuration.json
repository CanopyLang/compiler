{
  "comments": {
    "lineComment": "--",
    "blockComment": ["{-", "-}"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "{-", "close": "-}" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*(=|->|\\{|\\[|\\(|\\bthen\\b|\\belse\\b|\\bof\\b|\\blet\\b|\\bin\\b)\\s*$",
    "decreaseIndentPattern": "^\\s*(\\}|\\]|\\)).*$"
  },
  "wordPattern": "[a-zA-Z_'][a-zA-Z0-9_']*"
}
