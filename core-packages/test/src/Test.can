-- | Test framework for Canopy (similar to elm-explorations/test)
-- Provides core testing functionality including sync, async, and browser tests

module Test exposing
  ( Test(..)
  , FuzzOutcome(..)
  , PlaywrightAction(..)
  , BrowserTest(..)
  , inBrowser
  , describe
  , test
  , skip
  , todo
  , only
  , fuzz
  , asyncTest
  , toRunner
  , run
  , runTests
  , TestResult
  , RunnerResult
  , TestError(..)
  )

import Expect exposing (Expectation)
import Fuzz exposing (Fuzzer)
import Random
import Task exposing (Task)


{-| A Test is a collection of expectations or other tests.

The Test type supports several kinds of tests:

  - `UnitTest` - Synchronous test with immediate expectation
  - `TestGroup` - Group of tests (describe block)
  - `AsyncTest` - Generic async test returning Task<Expectation>
  - `Skip` - Skipped test (will be reported but not run)
  - `Todo` - Placeholder test (will be reported as todo)
  - `Only` - Focus on this test only (for debugging)
  - `FuzzTest` - Property-based test with random input
  - `PlaywrightStep` - Playwright browser automation step (visit, click, fill, etc.)

-}
type Test
  = UnitTest String (() -> Expectation)
  | TestGroup String (List Test)
  | AsyncTest String (Task TestError Expectation)
  | Skip Test
  | Todo String
  | Only Test
  | FuzzTest String (Int -> Int -> FuzzOutcome)
  | PlaywrightStep PlaywrightAction


{-| Outcome of running a fuzz test.
-}
type FuzzOutcome
  = FuzzPassed Int
  | FuzzFailed String String


{-| Actions that can be performed via Playwright in the browser.

Each action maps to a Playwright command executed on an iframe target
via the console.log RPC bridge.

-}
type PlaywrightAction
  = Visit String
  | Click String
  | Fill String String
  | Check String
  | SeeText String
  | SeeElement String
  | DontSee String
  | DontSeeElement String
  | WaitFor String
  | Screenshot String


{-| A BrowserTest wraps a list of Tests for execution in a real browser.

Use this when your tests need real browser APIs (Web Audio, Canvas, WebGL, etc.)
that are not available in Node.js. Supports both direct browser API tests and
Playwright automation steps.

    main : BrowserTest
    main =
        inBrowser
            [ describe "Web Audio"
                [ test "creates oscillator" <| \_ -> ...
                ]
            , visit "/app"
            , click "#start-button"
            , seeText "Playing"
            ]

-}
type BrowserTest = InBrowser (List Test)


{-| Create a BrowserTest from a list of tests.

    main : BrowserTest
    main =
        inBrowser [ suite ]

-}
inBrowser : List Test -> BrowserTest
inBrowser tests =
    InBrowser tests


{-| Error type for async and browser tests.
-}
type TestError
  = TestTimeout String
  | TestException String
  | BrowserError String


-- | Test result type for internal use
type alias TestResult =
  { description : String
  , status : String
  , message : String
  , duration : Int
  }


-- | Result format expected by the test harness
-- The test harness expects { name, passed, reason }
type alias RunnerResult =
  { name : String
  , passed : Bool
  , reason : String
  }


{-| Create a group of tests with a description.

    describe "Math operations"
        [ test "addition" <| \_ -> Expect.equal 4 (2 + 2)
        , test "subtraction" <| \_ -> Expect.equal 2 (4 - 2)
        ]

-}
describe : String -> List Test -> Test
describe description tests =
  TestGroup description tests


{-| Create a single test with a description and expectation.

    test "addition works" <|
        \_ -> Expect.equal 4 (2 + 2)

-}
test : String -> (() -> Expectation) -> Test
test description expectationFn =
  UnitTest description expectationFn


{-| Skip a test. It will be reported as skipped but not executed.

    skip <|
        test "not ready yet" <| \_ -> ...

-}
skip : Test -> Test
skip testToSkip =
  Skip testToSkip


{-| Mark a test as todo. Useful for planning tests.

    todo "implement user authentication tests"

-}
todo : String -> Test
todo description =
  Todo description


{-| Focus on this test only (for debugging).
Other tests will be skipped.

    only <|
        test "debug this one" <| \_ -> ...

-}
only : Test -> Test
only testToFocus =
  Only testToFocus


{-| Create a fuzz test with random inputs.

    fuzz Fuzz.int "positive integers" <|
        \n -> Expect.equal True (n * n >= 0)

-}
fuzz : Fuzzer a -> String -> (a -> Expectation) -> Test
fuzz (Fuzz.Fuzzer generator shrinker toString) description testFn =
  FuzzTest description (\seed numRuns ->
    executeFuzz generator shrinker toString testFn seed numRuns
  )


{-| Create an async test that returns a Task.

    asyncTest "fetch user data" <|
        Http.get "/api/user"
            |> Task.map (\user -> Expect.equal "Alice" user.name)

-}
asyncTest : String -> Task TestError Expectation -> Test
asyncTest description taskExpectation =
  AsyncTest description taskExpectation


-- | Convert tests to the runner format expected by the test harness
-- Returns a list of { name, passed, reason } results
toRunner : List Test -> List RunnerResult
toRunner tests =
  List.concatMap runToRunnerResults tests


-- | Run a test and convert to RunnerResult format
runToRunnerResults : Test -> List RunnerResult
runToRunnerResults testCase =
  case testCase of
    UnitTest description expectationFn ->
      [ expectationToRunnerResult description (expectationFn ()) ]

    TestGroup _groupDescription tests ->
      List.concatMap runToRunnerResults tests

    Skip innerTest ->
      [ { name = getTestName innerTest
        , passed = True
        , reason = "SKIPPED"
        }
      ]

    Todo description ->
      [ { name = description
        , passed = True
        , reason = "TODO"
        }
      ]

    Only innerTest ->
      runToRunnerResults innerTest

    AsyncTest description _task ->
      [ { name = description
        , passed = True
        , reason = "ASYNC_TEST (run with async runner)"
        }
      ]

    FuzzTest description runFuzz ->
      let
        outcome = runFuzz 42 100
      in
      case outcome of
        FuzzPassed count ->
          [ { name = description
            , passed = True
            , reason = "passed " ++ String.fromInt count ++ " fuzz iterations"
            }
          ]

        FuzzFailed valueStr message ->
          [ { name = description
            , passed = False
            , reason = "Counterexample: " ++ valueStr ++ "\n" ++ message
            }
          ]

    PlaywrightStep _action ->
      [ { name = describePlaywrightAction _action
        , passed = True
        , reason = "PLAYWRIGHT_STEP (run in browser)"
        }
      ]


{-| Get the name of a test.
-}
getTestName : Test -> String
getTestName testCase =
  case testCase of
    UnitTest name _ -> name
    TestGroup name _ -> name
    AsyncTest name _ -> name
    Skip inner -> getTestName inner
    Todo name -> name
    Only inner -> getTestName inner
    FuzzTest name _ -> name
    PlaywrightStep action -> describePlaywrightAction action


-- | Convert an expectation to the RunnerResult format
expectationToRunnerResult : String -> Expectation -> RunnerResult
expectationToRunnerResult name expectation =
  case expectation of
    Expect.Pass ->
      { name = name
      , passed = True
      , reason = ""
      }
    Expect.Fail reason ->
      { name = name
      , passed = False
      , reason = Expect.reasonToString reason
      }


-- | Run a test and get the results (for internal/legacy use)
run : Test -> TestResult
run testCase =
  case testCase of
    UnitTest description expectationFn ->
      runUnitTest description (expectationFn ())

    TestGroup description tests ->
      runTestGroup description tests

    Skip innerTest ->
      { description = getTestName innerTest
      , status = "SKIP"
      , message = "Test skipped"
      , duration = 0
      }

    Todo description ->
      { description = description
      , status = "TODO"
      , message = "Test not implemented"
      , duration = 0
      }

    Only innerTest ->
      run innerTest

    AsyncTest description _task ->
      { description = description
      , status = "SKIP"
      , message = "Async test - use async runner"
      , duration = 0
      }

    FuzzTest description runFuzz ->
      case runFuzz 42 100 of
        FuzzPassed count ->
          { description = description
          , status = "PASS"
          , message = "passed " ++ String.fromInt count ++ " fuzz iterations"
          , duration = 0
          }

        FuzzFailed valueStr message ->
          { description = description
          , status = "FAIL"
          , message = "Counterexample: " ++ valueStr ++ "\n" ++ message
          , duration = 0
          }

    PlaywrightStep action ->
      { description = describePlaywrightAction action
      , status = "SKIP"
      , message = "Playwright step - run in browser"
      , duration = 0
      }


runUnitTest : String -> Expectation -> TestResult
runUnitTest description result =
  case result of
    Expect.Pass ->
      { description = description
      , status = "PASS"
      , message = ""
      , duration = 0
      }
    Expect.Fail reason ->
      { description = description
      , status = "FAIL"
      , message = Expect.reasonToString reason
      , duration = 0
      }


runTestGroup : String -> List Test -> TestResult
runTestGroup description tests =
  let
    results = List.map run tests
    failures = List.filter (\r -> r.status == "FAIL") results
  in
  { description = description
  , status = if List.isEmpty failures then "PASS" else "FAIL"
  , message = String.fromInt (List.length failures) ++ " of " ++ String.fromInt (List.length results) ++ " tests failed"
  , duration = 0
  }


-- | Test runner that outputs to console (will be called from generated JavaScript)
runTests : List Test -> String
runTests tests =
  let
    results = List.map run tests
    totalTests = List.length results
    passedTests = List.length (List.filter (\r -> r.status == "PASS") results)
    failedTests = totalTests - passedTests
  in
  formatTestSummary totalTests passedTests failedTests results


formatTestSummary : Int -> Int -> Int -> List TestResult -> String
formatTestSummary total passed failed results =
  "Test Results:\n" ++
  "Total: " ++ String.fromInt total ++ "\n" ++
  "Passed: " ++ String.fromInt passed ++ "\n" ++
  "Failed: " ++ String.fromInt failed ++ "\n" ++
  formatFailures failed results


formatFailures : Int -> List TestResult -> String
formatFailures failedCount results =
  if failedCount > 0 then
    "\nFailures:\n" ++
    String.join "\n" (List.map formatFailure (List.filter (\r -> r.status == "FAIL") results))
  else
    "\nAll tests passed!"


formatFailure : TestResult -> String
formatFailure result =
  "X " ++ result.description ++ ": " ++ result.message


{-| Describe a PlaywrightAction as a human-readable string for test output.
-}
describePlaywrightAction : PlaywrightAction -> String
describePlaywrightAction action =
  case action of
    Visit url -> "visit " ++ url
    Click selector -> "click " ++ selector
    Fill selector value -> "fill " ++ selector ++ " with " ++ value
    Check selector -> "check " ++ selector
    SeeText text -> "see text \"" ++ text ++ "\""
    SeeElement selector -> "see element " ++ selector
    DontSee text -> "don't see \"" ++ text ++ "\""
    DontSeeElement selector -> "don't see element " ++ selector
    WaitFor selector -> "wait for " ++ selector
    Screenshot name -> "screenshot " ++ name


-- ============================================================================
-- Fuzz Test Execution
-- ============================================================================


{-| Execute a fuzz test: generate random values, test them, shrink on failure.
-}
executeFuzz : Random.Generator a -> (a -> List a) -> (a -> String) -> (a -> Expectation) -> Int -> Int -> FuzzOutcome
executeFuzz generator shrinker toString testFn seedInt numRuns =
  let
    seed = Random.initialSeed seedInt
  in
  fuzzLoop generator shrinker toString testFn seed numRuns 0


fuzzLoop : Random.Generator a -> (a -> List a) -> (a -> String) -> (a -> Expectation) -> Random.Seed -> Int -> Int -> FuzzOutcome
fuzzLoop generator shrinker toString testFn seed remaining passed =
  if remaining <= 0 then
    FuzzPassed passed
  else
    let
      ( value, nextSeed ) = Random.step generator seed
      result = testFn value
    in
    case result of
      Expect.Pass ->
        fuzzLoop generator shrinker toString testFn nextSeed (remaining - 1) (passed + 1)

      Expect.Fail reason ->
        let
          shrunk = shrinkLoop shrinker testFn value 100
          message = Expect.reasonToString reason
        in
        FuzzFailed (toString shrunk) message


{-| Shrink a failing value to find the minimal counterexample.
-}
shrinkLoop : (a -> List a) -> (a -> Expectation) -> a -> Int -> a
shrinkLoop shrinker testFn value attemptsLeft =
  if attemptsLeft <= 0 then
    value
  else
    let
      candidates = shrinker value
    in
    case findSmallerFailure testFn candidates of
      Nothing ->
        value

      Just smaller ->
        shrinkLoop shrinker testFn smaller (attemptsLeft - 1)


{-| Find the first candidate that still fails the test.
-}
findSmallerFailure : (a -> Expectation) -> List a -> Maybe a
findSmallerFailure testFn candidates =
  case candidates of
    [] ->
      Nothing

    candidate :: rest ->
      case testFn candidate of
        Expect.Fail _ ->
          Just candidate

        Expect.Pass ->
          findSmallerFailure testFn rest
