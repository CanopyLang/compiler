module Expect exposing
    ( Expectation(..)
    , Reason(..)
    , equal
    , notEqual
    , lessThan
    , atMost
    , greaterThan
    , atLeast
    , true
    , false
    , ok
    , err
    , all
    , onFail
    , pass
    , fail
    , within
    , FloatingPointTolerance(..)
    , reasonToString
    )

{-| Expectations for testing values.

## Basic Comparisons

    Expect.equal 4 (2 + 2)
    Expect.notEqual "hello" "world"
    Expect.lessThan 5 3

## Boolean Expectations

    Expect.true "should be true" condition
    Expect.false "should be false" condition

## Result Expectations

    Expect.ok (Result.Ok 42)
    Expect.err (Result.Err "oops")

## Combining Expectations

    Expect.all
        [ Expect.greaterThan 0
        , Expect.lessThan 100
        ]
        value

-}

import Debug


{-| The result of an expectation. Either it passed or it failed with a reason.
-}
type Expectation
    = Pass
    | Fail Reason


{-| Internal: reason for failure
-}
type Reason
    = Equality String String String
    | Comparison String String String String
    | Custom String


{-| Expect two values to be equal.

    Expect.equal "hello" (String.reverse "olleh")

-}
equal : a -> a -> Expectation
equal expected actual =
    if actual == expected then
        Pass
    else
        Fail (Equality "Expect.equal" (Debug.toString expected) (Debug.toString actual))


{-| Expect two values to NOT be equal.

    Expect.notEqual "hello" "world"

-}
notEqual : a -> a -> Expectation
notEqual expected actual =
    if actual /= expected then
        Pass
    else
        Fail (Custom ("Expected values to be different, but both were: " ++ Debug.toString actual))


{-| Expect the first value to be less than the second.

    Expect.lessThan 5 3  -- passes (3 < 5)

-}
lessThan : comparable -> comparable -> Expectation
lessThan threshold actual =
    if actual < threshold then
        Pass
    else
        Fail (Comparison "Expect.lessThan" (Debug.toString actual) "<" (Debug.toString threshold))


{-| Expect the first value to be less than or equal to the second.

    Expect.atMost 5 5  -- passes (5 <= 5)

-}
atMost : comparable -> comparable -> Expectation
atMost threshold actual =
    if actual <= threshold then
        Pass
    else
        Fail (Comparison "Expect.atMost" (Debug.toString actual) "<=" (Debug.toString threshold))


{-| Expect the first value to be greater than the second.

    Expect.greaterThan 3 5  -- passes (5 > 3)

-}
greaterThan : comparable -> comparable -> Expectation
greaterThan threshold actual =
    if actual > threshold then
        Pass
    else
        Fail (Comparison "Expect.greaterThan" (Debug.toString actual) ">" (Debug.toString threshold))


{-| Expect the first value to be greater than or equal to the second.

    Expect.atLeast 3 3  -- passes (3 >= 3)

-}
atLeast : comparable -> comparable -> Expectation
atLeast threshold actual =
    if actual >= threshold then
        Pass
    else
        Fail (Comparison "Expect.atLeast" (Debug.toString actual) ">=" (Debug.toString threshold))


{-| Expect a boolean to be True.

    Expect.true "List should not be empty" (not (List.isEmpty myList))

-}
true : String -> Bool -> Expectation
true description condition =
    if condition then
        Pass
    else
        Fail (Custom description)


{-| Expect a boolean to be False.

    Expect.false "List should be empty" (List.isEmpty [1, 2, 3])

-}
false : String -> Bool -> Expectation
false description condition =
    if not condition then
        Pass
    else
        Fail (Custom description)


{-| Expect a Result to be Ok.

    Expect.ok (String.toInt "42")

-}
ok : Result err value -> Expectation
ok result =
    case result of
        Ok _ ->
            Pass

        Err e ->
            Fail (Custom ("Expected Ok but got Err: " ++ Debug.toString e))


{-| Expect a Result to be Err.

    Expect.err (String.toInt "not a number")

-}
err : Result err value -> Expectation
err result =
    case result of
        Err _ ->
            Pass

        Ok v ->
            Fail (Custom ("Expected Err but got Ok: " ++ Debug.toString v))


{-| Run multiple expectations on a value. All must pass.

    Expect.all
        [ Expect.greaterThan 0
        , Expect.lessThan 100
        , \n -> Expect.equal 0 (modBy 2 n)
        ]
        42

-}
all : List (a -> Expectation) -> a -> Expectation
all expectations value =
    let
        results =
            List.map (\expectation -> expectation value) expectations

        failures =
            List.filter isFailure results
    in
    case failures of
        [] ->
            Pass

        first :: _ ->
            first


isFailure : Expectation -> Bool
isFailure expectation =
    case expectation of
        Pass ->
            False

        Fail _ ->
            True


{-| Add additional context to an expectation on failure.

    myValue
        |> Expect.equal 42
        |> Expect.onFail "myValue should be the answer to everything"

-}
onFail : String -> Expectation -> Expectation
onFail message expectation =
    case expectation of
        Pass ->
            Pass

        Fail reason ->
            Fail (Custom (message ++ "\n" ++ reasonToString reason))


reasonToString : Reason -> String
reasonToString reason =
    case reason of
        Equality label expected actual ->
            label ++ "\n\nExpected:\n    " ++ expected ++ "\n\nActual:\n    " ++ actual

        Comparison label actual op threshold ->
            label ++ "\n\nExpected " ++ actual ++ " " ++ op ++ " " ++ threshold

        Custom message ->
            message


{-| An expectation that always passes.
-}
pass : Expectation
pass =
    Pass


{-| An expectation that always fails with the given message.
-}
fail : String -> Expectation
fail message =
    Fail (Custom message)


{-| Tolerance types for floating-point comparisons.
-}
type FloatingPointTolerance
    = Absolute Float
    | Relative Float
    | AbsoluteOrRelative Float Float


{-| Expect two floating-point values to be within a tolerance.

    Expect.within (Expect.Absolute 0.001) 3.14159 pi

-}
within : FloatingPointTolerance -> Float -> Float -> Expectation
within tolerance expected actual =
    let
        diff =
            abs (expected - actual)

        withinTolerance =
            case tolerance of
                Absolute maxDiff ->
                    diff <= maxDiff

                Relative maxRelDiff ->
                    diff <= abs expected * maxRelDiff

                AbsoluteOrRelative maxAbsDiff maxRelDiff ->
                    diff <= maxAbsDiff || diff <= abs expected * maxRelDiff
    in
    if withinTolerance then
        Pass
    else
        Fail (Custom ("Expected " ++ Debug.toString actual ++ " to be within tolerance of " ++ Debug.toString expected ++ " (diff: " ++ Debug.toString diff ++ ")"))
