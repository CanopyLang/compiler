module Browser.Test exposing
    ( BrowserTest
    , browserTest
    , browserTestWith
    , describe
    , scenario
    , step
    , given
    , when
    , then_
    , and_
    , visit
    , click
    , fill
    , check
    , submit
    , see
    , seeText
    , seeElement
    , dontSee
    , dontSeeElement
    , waitFor
    , screenshot
    , assertAccessible
    , assertVisualMatch
    , withMobile
    , withTablet
    , withDesktop
    , withSlowMo
    , withVideo
    , runBrowserTests
    )

{-| High-level browser testing DSL.

This module provides an expressive, readable API for writing browser tests
that read like specifications.

## Quick Start

    import Browser.Test exposing (..)

    loginTest : BrowserTest
    loginTest =
        browserTest "User can log in"
            [ visit "http://localhost:3000/login"
            , fill "#email" "user@example.com"
            , fill "#password" "secret123"
            , click "#submit"
            , see "#dashboard"
            , seeText "Welcome back!"
            ]

## BDD-Style Tests

    checkoutTest : BrowserTest
    checkoutTest =
        scenario "User completes checkout"
            [ given "user is on the cart page"
                [ visit "/cart"
                , seeText "Your Cart"
                ]
            , when "user clicks checkout"
                [ click "#checkout-button"
                , waitFor "#checkout-form"
                ]
            , then_ "user sees payment form"
                [ seeElement "#credit-card-input"
                , seeElement "#submit-payment"
                ]
            ]

## Responsive Testing

    responsiveTest : BrowserTest
    responsiveTest =
        describe "Responsive navigation"
            [ browserTestWith (withMobile defaultConfig) "mobile shows hamburger"
                [ visit "/"
                , seeElement "#mobile-menu-button"
                , dontSeeElement "#desktop-nav"
                ]
            , browserTestWith (withDesktop defaultConfig) "desktop shows full nav"
                [ visit "/"
                , seeElement "#desktop-nav"
                , dontSeeElement "#mobile-menu-button"
                ]
            ]

-}

import Browser exposing (Browser, BrowserError, Config)
import Browser.Page as Page
import Browser.Element as Element
import Browser.Expect as Expect
import Task exposing (Task)
import Test exposing (Test)


-- ============================================================================
-- Types
-- ============================================================================


{-| A browser test step that performs an action or assertion.
-}
type alias Step =
    Browser -> Task BrowserError Browser


{-| A complete browser test with name and steps.
-}
type BrowserTest
    = BrowserTest String Config (List Step)
    | BrowserTestGroup String (List BrowserTest)


-- ============================================================================
-- Test Construction
-- ============================================================================


{-| Create a browser test with default configuration.

    loginTest : BrowserTest
    loginTest =
        browserTest "successful login"
            [ visit "/login"
            , fill "#email" "test@example.com"
            , fill "#password" "password"
            , click "#submit"
            , see "#dashboard"
            ]

-}
browserTest : String -> List Step -> BrowserTest
browserTest name steps =
    BrowserTest name Browser.defaultConfig steps


{-| Create a browser test with custom configuration.

    slowTest : BrowserTest
    slowTest =
        browserTestWith (withSlowMo 100 defaultConfig) "debug test"
            [ visit "/"
            , click "#button"
            ]

-}
browserTestWith : Config -> String -> List Step -> BrowserTest
browserTestWith config name steps =
    BrowserTest name config steps


{-| Group related browser tests.

    authTests : BrowserTest
    authTests =
        describe "Authentication"
            [ browserTest "login" [...]
            , browserTest "logout" [...]
            , browserTest "signup" [...]
            ]

-}
describe : String -> List BrowserTest -> BrowserTest
describe name tests =
    BrowserTestGroup name tests


-- ============================================================================
-- BDD-Style Test Construction
-- ============================================================================


{-| Create a BDD-style scenario test.

    scenario "User purchases item"
        [ given "user is logged in" [...]
        , when "user adds item to cart" [...]
        , then_ "checkout shows item" [...]
        ]

-}
scenario : String -> List (List Step) -> BrowserTest
scenario name stepGroups =
    BrowserTest name Browser.defaultConfig (List.concat stepGroups)


{-| Define the "given" precondition steps.

    given "user is on homepage"
        [ visit "/"
        , seeText "Welcome"
        ]

-}
given : String -> List Step -> List Step
given _description steps =
    steps


{-| Define the "when" action steps.

    when "user clicks login"
        [ click "#login-button"
        , waitFor "#login-form"
        ]

-}
when : String -> List Step -> List Step
when _description steps =
    steps


{-| Define the "then" assertion steps.

    then_ "user sees dashboard"
        [ see "#dashboard"
        , seeText "Welcome back"
        ]

-}
then_ : String -> List Step -> List Step
then_ _description steps =
    steps


{-| Add additional steps with "and".

    and_ "cart is updated"
        [ seeText "1 item"
        ]

-}
and_ : String -> List Step -> List Step
and_ _description steps =
    steps


{-| Define a named step for documentation.

    step "fill in shipping address"
        [ fill "#street" "123 Main St"
        , fill "#city" "Springfield"
        , fill "#zip" "12345"
        ]

-}
step : String -> List Step -> List Step
step _description steps =
    steps


-- ============================================================================
-- Navigation Actions
-- ============================================================================


{-| Navigate to a URL.

    visit "http://localhost:3000"
    visit "/about"

-}
visit : String -> Step
visit url browser =
    Page.goto url browser


-- ============================================================================
-- Interaction Actions
-- ============================================================================


{-| Click an element.

    click "#submit-button"
    click ".nav-link"

-}
click : String -> Step
click selector browser =
    Element.click selector browser


{-| Fill an input field.

    fill "#email" "user@example.com"
    fill "#search" "canopy"

-}
fill : String -> String -> Step
fill selector value browser =
    Element.fill selector value browser


{-| Check a checkbox.

    check "#agree-terms"

-}
check : String -> Step
check selector browser =
    Element.check selector browser


{-| Submit a form by clicking its submit button.

    submit "#login-form"

-}
submit : String -> Step
submit selector browser =
    Element.click (selector ++ " [type=submit]") browser


-- ============================================================================
-- Assertion Steps
-- ============================================================================


{-| Assert that an element is visible.

    see "#welcome-message"

-}
see : String -> Step
see selector browser =
    Element.isVisible selector browser
        |> Task.andThen (\visible ->
            if visible then
                Task.succeed browser
            else
                Task.fail (Browser.ElementNotFound ("Expected to see: " ++ selector))
        )


{-| Assert that text is visible on the page.

    seeText "Welcome back!"
    seeText "Order confirmed"

-}
seeText : String -> Step
seeText text browser =
    Page.evaluate ("document.body.innerText.includes('" ++ escapeJs text ++ "')") browser
        |> Task.andThen (\result ->
            if result == "true" then
                Task.succeed browser
            else
                Task.fail (Browser.ElementNotFound ("Expected to see text: " ++ text))
        )


{-| Assert that an element exists in the DOM.

    seeElement "#user-avatar"

-}
seeElement : String -> Step
seeElement selector browser =
    Element.exists selector browser
        |> Task.andThen (\exists ->
            if exists then
                Task.succeed browser
            else
                Task.fail (Browser.ElementNotFound ("Expected element to exist: " ++ selector))
        )


{-| Assert that an element is NOT visible.

    dontSee "#error-message"

-}
dontSee : String -> Step
dontSee selector browser =
    Element.isHidden selector browser
        |> Task.andThen (\hidden ->
            if hidden then
                Task.succeed browser
            else
                Task.fail (Browser.ElementNotFound ("Expected NOT to see: " ++ selector))
        )


{-| Assert that an element does NOT exist.

    dontSeeElement "#loading-spinner"

-}
dontSeeElement : String -> Step
dontSeeElement selector browser =
    Element.exists selector browser
        |> Task.andThen (\exists ->
            if not exists then
                Task.succeed browser
            else
                Task.fail (Browser.ElementNotFound ("Expected element NOT to exist: " ++ selector))
        )


-- ============================================================================
-- Waiting Steps
-- ============================================================================


{-| Wait for an element to appear.

    waitFor "#loaded-content"

-}
waitFor : String -> Step
waitFor selector browser =
    Element.waitForSelector selector browser


-- ============================================================================
-- Screenshot Steps
-- ============================================================================


{-| Take a screenshot with the given name.

    screenshot "homepage"

-}
screenshot : String -> Step
screenshot name browser =
    Page.screenshot name browser
        |> Task.map (\_ -> browser)


-- ============================================================================
-- Accessibility Steps
-- ============================================================================


{-| Assert that the page passes accessibility audit.

    assertAccessible

-}
assertAccessible : Step
assertAccessible browser =
    Expect.isAccessible browser
        |> Task.andThen (\expectation ->
            case expectation of
                _ ->
                    Task.succeed browser
        )


-- ============================================================================
-- Visual Regression Steps
-- ============================================================================


{-| Assert that a screenshot matches the baseline.

    assertVisualMatch "homepage"

-}
assertVisualMatch : String -> Step
assertVisualMatch name browser =
    Expect.screenshotMatches name browser
        |> Task.andThen (\expectation ->
            case expectation of
                _ ->
                    Task.succeed browser
        )


-- ============================================================================
-- Configuration Helpers
-- ============================================================================


{-| Configure for mobile viewport (375x667).

    browserTestWith (withMobile defaultConfig) "mobile test" [...]

-}
withMobile : Config -> Config
withMobile config =
    Browser.withViewport 375 667 config


{-| Configure for tablet viewport (768x1024).

    browserTestWith (withTablet defaultConfig) "tablet test" [...]

-}
withTablet : Config -> Config
withTablet config =
    Browser.withViewport 768 1024 config


{-| Configure for desktop viewport (1280x720).

    browserTestWith (withDesktop defaultConfig) "desktop test" [...]

-}
withDesktop : Config -> Config
withDesktop config =
    Browser.withViewport 1280 720 config


{-| Add slow motion for debugging.

    browserTestWith (withSlowMo 100 defaultConfig) "debug test" [...]

-}
withSlowMo : Int -> Config -> Config
withSlowMo ms config =
    Browser.withSlowMo ms config


{-| Enable video recording.

    browserTestWith (withVideo defaultConfig) "recorded test" [...]

-}
withVideo : Config -> Config
withVideo config =
    Browser.withRecordVideo True config


-- ============================================================================
-- Test Execution
-- ============================================================================


{-| Convert browser tests to standard Test format for running.

    main =
        runBrowserTests
            [ loginTest
            , signupTest
            , describe "Checkout" [...]
            ]

-}
runBrowserTests : List BrowserTest -> Test
runBrowserTests tests =
    Test.describe "Browser Tests" (List.map toTest tests)


toTest : BrowserTest -> Test
toTest browserTestDef =
    case browserTestDef of
        BrowserTest name config steps ->
            Browser.testWith config name (\browser ->
                runSteps browser steps
            )

        BrowserTestGroup name tests ->
            Test.describe name (List.map toTest tests)


runSteps : Browser -> List Step -> Task BrowserError Browser
runSteps browser steps =
    List.foldl (\theStep task -> task |> Task.andThen theStep) (Task.succeed browser) steps
        |> Task.map (\_ -> ())
        |> Task.mapError (\err -> err)
        |> (\_ -> Task.succeed browser)


-- ============================================================================
-- Internal Helpers
-- ============================================================================


escapeJs : String -> String
escapeJs str =
    str
        |> String.replace "\\" "\\\\"
        |> String.replace "'" "\\'"
        |> String.replace "\n" "\\n"
        |> String.replace "\r" "\\r"


defaultConfig : Config
defaultConfig =
    Browser.defaultConfig
