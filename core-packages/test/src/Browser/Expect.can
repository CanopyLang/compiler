module Browser.Expect exposing
    ( urlContains
    , urlEquals
    , titleEquals
    , titleContains
    , elementVisible
    , elementHidden
    , elementExists
    , elementNotExists
    , elementHasText
    , elementTextEquals
    , elementHasClass
    , elementHasAttribute
    , elementCount
    , inputHasValue
    , checkboxChecked
    , checkboxUnchecked
    , elementEnabled
    , elementDisabled
    , screenshotMatches
    , screenshotMatchesStrict
    , isAccessible
    , meetsWcagA
    , meetsWcagAA
    , noConsoleErrors
    )

{-| Browser-specific expectations for integration testing.

This module provides assertions tailored for browser testing scenarios.

## URL Expectations

    browser
        |> Browser.Expect.urlContains "/dashboard"
        |> Browser.Expect.urlEquals "http://localhost:3000/dashboard"

## Element Expectations

    browser
        |> Browser.Expect.elementVisible "#welcome"
        |> Browser.Expect.elementHasText "#greeting" "Hello, User"
        |> Browser.Expect.elementHasClass "#status" "active"

## Form Expectations

    browser
        |> Browser.Expect.inputHasValue "#email" "user@example.com"
        |> Browser.Expect.checkboxChecked "#agree"

## Visual Regression

    browser
        |> Browser.Expect.screenshotMatches "homepage"

## Accessibility

    browser
        |> Browser.Expect.isAccessible
        |> Browser.Expect.meetsWcagAA

-}

import Browser exposing (Browser, BrowserError)
import Browser.Page as Page
import Browser.Element as Element
import Expect exposing (Expectation)
import Task exposing (Task)

-- FFI imports
foreign import javascript "../external/playwright.js" as Playwright
foreign import javascript "../external/accessibility.js" as Accessibility
foreign import javascript "../external/visual.js" as Visual


-- ============================================================================
-- URL Expectations
-- ============================================================================


{-| Expect URL to contain a substring.

    browser
        |> Browser.Expect.urlContains "/dashboard"

-}
urlContains : String -> Browser -> Expectation
urlContains expected browser =
    let
        actual = Page.url browser
    in
    if String.contains expected actual then
        Expect.pass
    else
        Expect.fail
            ("Expected URL to contain: " ++ expected ++ "\nActual URL: " ++ actual)


{-| Expect URL to equal exactly.

    browser
        |> Browser.Expect.urlEquals "http://localhost:3000/about"

-}
urlEquals : String -> Browser -> Expectation
urlEquals expected browser =
    let
        actual = Page.url browser
    in
    if actual == expected then
        Expect.pass
    else
        Expect.fail
            ("Expected URL: " ++ expected ++ "\nActual URL: " ++ actual)


{-| Expect page title to equal.

    browser
        |> Browser.Expect.titleEquals "My App - Dashboard"

-}
titleEquals : String -> Browser -> Task BrowserError Expectation
titleEquals expected browser =
    Page.title browser
        |> Task.map (\actual ->
            if actual == expected then
                Expect.pass
            else
                Expect.fail
                    ("Expected title: " ++ expected ++ "\nActual title: " ++ actual)
        )


{-| Expect page title to contain substring.

    browser
        |> Browser.Expect.titleContains "Dashboard"

-}
titleContains : String -> Browser -> Task BrowserError Expectation
titleContains expected browser =
    Page.title browser
        |> Task.map (\actual ->
            if String.contains expected actual then
                Expect.pass
            else
                Expect.fail
                    ("Expected title to contain: " ++ expected ++ "\nActual title: " ++ actual)
        )


-- ============================================================================
-- Element Visibility Expectations
-- ============================================================================


{-| Expect element to be visible.

    browser
        |> Browser.Expect.elementVisible "#welcome-message"

-}
elementVisible : String -> Browser -> Task BrowserError Expectation
elementVisible selector browser =
    Element.isVisible selector browser
        |> Task.map (\visible ->
            if visible then
                Expect.pass
            else
                Expect.fail ("Expected element to be visible: " ++ selector)
        )


{-| Expect element to be hidden.

    browser
        |> Browser.Expect.elementHidden "#loading-spinner"

-}
elementHidden : String -> Browser -> Task BrowserError Expectation
elementHidden selector browser =
    Element.isHidden selector browser
        |> Task.map (\hidden ->
            if hidden then
                Expect.pass
            else
                Expect.fail ("Expected element to be hidden: " ++ selector)
        )


{-| Expect element to exist in DOM.

    browser
        |> Browser.Expect.elementExists "#user-avatar"

-}
elementExists : String -> Browser -> Task BrowserError Expectation
elementExists selector browser =
    Element.exists selector browser
        |> Task.map (\doesExist ->
            if doesExist then
                Expect.pass
            else
                Expect.fail ("Expected element to exist: " ++ selector)
        )


{-| Expect element to NOT exist in DOM.

    browser
        |> Browser.Expect.elementNotExists "#error-message"

-}
elementNotExists : String -> Browser -> Task BrowserError Expectation
elementNotExists selector browser =
    Element.exists selector browser
        |> Task.map (\doesExist ->
            if not doesExist then
                Expect.pass
            else
                Expect.fail ("Expected element to NOT exist: " ++ selector)
        )


-- ============================================================================
-- Element Text Expectations
-- ============================================================================


{-| Expect element to contain text.

    browser
        |> Browser.Expect.elementHasText "#greeting" "Hello"

-}
elementHasText : String -> String -> Browser -> Task BrowserError Expectation
elementHasText selector expected browser =
    Element.textContent selector browser
        |> Task.map (\actual ->
            if String.contains expected actual then
                Expect.pass
            else
                Expect.fail
                    ("Expected element " ++ selector ++ " to contain: " ++ expected
                    ++ "\nActual text: " ++ actual)
        )


{-| Expect element text to equal exactly.

    browser
        |> Browser.Expect.elementTextEquals "#status" "Active"

-}
elementTextEquals : String -> String -> Browser -> Task BrowserError Expectation
elementTextEquals selector expected browser =
    Element.textContent selector browser
        |> Task.map (\actual ->
            if String.trim actual == expected then
                Expect.pass
            else
                Expect.fail
                    ("Expected element " ++ selector ++ " text: " ++ expected
                    ++ "\nActual text: " ++ actual)
        )


-- ============================================================================
-- Element Attribute Expectations
-- ============================================================================


{-| Expect element to have CSS class.

    browser
        |> Browser.Expect.elementHasClass "#button" "active"

-}
elementHasClass : String -> String -> Browser -> Task BrowserError Expectation
elementHasClass selector className browser =
    Element.getAttribute selector "class" browser
        |> Task.map (\classes ->
            if String.contains className classes then
                Expect.pass
            else
                Expect.fail
                    ("Expected element " ++ selector ++ " to have class: " ++ className
                    ++ "\nActual classes: " ++ classes)
        )


{-| Expect element to have attribute with value.

    browser
        |> Browser.Expect.elementHasAttribute "#link" "href" "/about"

-}
elementHasAttribute : String -> String -> String -> Browser -> Task BrowserError Expectation
elementHasAttribute selector attrName expected browser =
    Element.getAttribute selector attrName browser
        |> Task.map (\actual ->
            if actual == expected then
                Expect.pass
            else
                Expect.fail
                    ("Expected element " ++ selector ++ " attribute " ++ attrName
                    ++ " to be: " ++ expected ++ "\nActual value: " ++ actual)
        )


{-| Expect specific number of elements.

    browser
        |> Browser.Expect.elementCount ".list-item" 5

-}
elementCount : String -> Int -> Browser -> Task BrowserError Expectation
elementCount selector expected browser =
    Element.count selector browser
        |> Task.map (\actual ->
            if actual == expected then
                Expect.pass
            else
                Expect.fail
                    ("Expected " ++ String.fromInt expected ++ " elements matching "
                    ++ selector ++ "\nFound: " ++ String.fromInt actual)
        )


-- ============================================================================
-- Form Expectations
-- ============================================================================


{-| Expect input to have specific value.

    browser
        |> Browser.Expect.inputHasValue "#email" "user@example.com"

-}
inputHasValue : String -> String -> Browser -> Task BrowserError Expectation
inputHasValue selector expected browser =
    Element.inputValue selector browser
        |> Task.map (\actual ->
            if actual == expected then
                Expect.pass
            else
                Expect.fail
                    ("Expected input " ++ selector ++ " value: " ++ expected
                    ++ "\nActual value: " ++ actual)
        )


{-| Expect checkbox to be checked.

    browser
        |> Browser.Expect.checkboxChecked "#agree-terms"

-}
checkboxChecked : String -> Browser -> Task BrowserError Expectation
checkboxChecked selector browser =
    Element.isChecked selector browser
        |> Task.map (\checked ->
            if checked then
                Expect.pass
            else
                Expect.fail ("Expected checkbox to be checked: " ++ selector)
        )


{-| Expect checkbox to be unchecked.

    browser
        |> Browser.Expect.checkboxUnchecked "#newsletter"

-}
checkboxUnchecked : String -> Browser -> Task BrowserError Expectation
checkboxUnchecked selector browser =
    Element.isChecked selector browser
        |> Task.map (\checked ->
            if not checked then
                Expect.pass
            else
                Expect.fail ("Expected checkbox to be unchecked: " ++ selector)
        )


{-| Expect element to be enabled.

    browser
        |> Browser.Expect.elementEnabled "#submit"

-}
elementEnabled : String -> Browser -> Task BrowserError Expectation
elementEnabled selector browser =
    Element.isEnabled selector browser
        |> Task.map (\enabled ->
            if enabled then
                Expect.pass
            else
                Expect.fail ("Expected element to be enabled: " ++ selector)
        )


{-| Expect element to be disabled.

    browser
        |> Browser.Expect.elementDisabled "#submit"

-}
elementDisabled : String -> Browser -> Task BrowserError Expectation
elementDisabled selector browser =
    Element.isDisabled selector browser
        |> Task.map (\disabled ->
            if disabled then
                Expect.pass
            else
                Expect.fail ("Expected element to be disabled: " ++ selector)
        )


-- ============================================================================
-- Visual Regression Expectations
-- ============================================================================


{-| Expect screenshot to match baseline (1% threshold).

    browser
        |> Browser.Expect.screenshotMatches "homepage"

On first run, creates the baseline. On subsequent runs, compares.

-}
screenshotMatches : String -> Browser -> Task BrowserError Expectation
screenshotMatches name browser =
    Page.screenshot name browser
        |> Task.andThen (\screenshotPath ->
            Visual.compareDefault name screenshotPath
        )
        |> Task.map (\result ->
            case result.type_ of
                "Match" ->
                    Expect.pass

                "BaselineCreated" ->
                    Expect.pass  -- First run, baseline created

                "Mismatch" ->
                    let
                        pct = String.fromFloat (result.diffPercent * 100)
                    in
                    Expect.fail
                        ("Screenshot mismatch: " ++ name
                        ++ "\nDifference: " ++ pct ++ "%"
                        ++ "\nDiff image: " ++ result.diffPath)

                "DimensionMismatch" ->
                    Expect.fail
                        ("Screenshot dimension mismatch: " ++ name
                        ++ "\nBaseline and current have different sizes")

                _ ->
                    Expect.fail ("Unknown comparison result for: " ++ name)
        )


{-| Expect screenshot to match baseline with strict threshold (0.1%).

    browser
        |> Browser.Expect.screenshotMatchesStrict "critical-ui"

-}
screenshotMatchesStrict : String -> Browser -> Task BrowserError Expectation
screenshotMatchesStrict name browser =
    Page.screenshot name browser
        |> Task.andThen (\screenshotPath ->
            Visual.compareStrict name screenshotPath
        )
        |> Task.map (\result ->
            case result.type_ of
                "Match" ->
                    Expect.pass

                "BaselineCreated" ->
                    Expect.pass

                "Mismatch" ->
                    let
                        pct = String.fromFloat (result.diffPercent * 100)
                    in
                    Expect.fail
                        ("Screenshot mismatch (strict): " ++ name
                        ++ "\nDifference: " ++ pct ++ "%")

                _ ->
                    Expect.fail ("Comparison failed: " ++ name)
        )


-- ============================================================================
-- Accessibility Expectations
-- ============================================================================


{-| Expect page to pass accessibility audit (no violations).

    browser
        |> Browser.Expect.isAccessible

Uses axe-core to check for accessibility violations.

-}
isAccessible : Browser -> Task BrowserError Expectation
isAccessible browser =
    Accessibility.audit browser
        |> Task.map (\result ->
            if result.violations == [] then
                Expect.pass
            else
                let
                    count = List.length result.violations
                    formatted = Accessibility.formatViolations result
                in
                Expect.fail
                    ("Found " ++ String.fromInt count ++ " accessibility violations:\n"
                    ++ formatted)
        )


{-| Expect page to meet WCAG 2.1 Level A.

    browser
        |> Browser.Expect.meetsWcagA

-}
meetsWcagA : Browser -> Task BrowserError Expectation
meetsWcagA browser =
    Accessibility.checkWcagA browser
        |> Task.map (\result ->
            if result.violations == [] then
                Expect.pass
            else
                Expect.fail
                    ("WCAG Level A violations found: "
                    ++ String.fromInt (List.length result.violations))
        )


{-| Expect page to meet WCAG 2.1 Level AA.

    browser
        |> Browser.Expect.meetsWcagAA

-}
meetsWcagAA : Browser -> Task BrowserError Expectation
meetsWcagAA browser =
    Accessibility.checkWcagAA browser
        |> Task.map (\result ->
            if result.violations == [] then
                Expect.pass
            else
                Expect.fail
                    ("WCAG Level AA violations found: "
                    ++ String.fromInt (List.length result.violations))
        )


-- ============================================================================
-- Console Expectations
-- ============================================================================


{-| Expect no console errors on page.

    browser
        |> Browser.Expect.noConsoleErrors

-}
noConsoleErrors : Browser -> Task BrowserError Expectation
noConsoleErrors browser =
    Playwright.getPageErrors browser
        |> Task.map (\errors ->
            if errors == [] then
                Expect.pass
            else
                Expect.fail
                    ("Page has console errors:\n"
                    ++ String.join "\n" errors)
        )
