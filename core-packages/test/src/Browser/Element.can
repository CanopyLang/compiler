module Browser.Element exposing
    ( click
    , doubleClick
    , rightClick
    , hover
    , fill
    , typeText
    , clear
    , press
    , check
    , uncheck
    , selectOption
    , focus
    , blur
    , textContent
    , innerText
    , innerHTML
    , getAttribute
    , inputValue
    , isVisible
    , isHidden
    , isEnabled
    , isDisabled
    , isChecked
    , isEditable
    , count
    , exists
    , waitForSelector
    , waitForHidden
    , scrollIntoView
    )

{-| Element interaction and inspection.

This module provides functions to interact with and query elements on the page.

## Clicking

    browser
        |> Element.click "#submit-button"
        |> Task.andThen (Element.doubleClick "#editable")
        |> Task.andThen (Element.rightClick "#context-menu-trigger")

## Form Filling

    browser
        |> Element.fill "#email" "user@example.com"
        |> Task.andThen (Element.fill "#password" "secret123")
        |> Task.andThen (Element.check "#remember-me")
        |> Task.andThen (Element.selectOption "#country" "US")
        |> Task.andThen (Element.click "#submit")

## Text and State Queries

    Element.textContent "#welcome-message" browser
        |> Task.map (\text -> String.contains "Welcome" text)

    Element.isVisible "#loading-spinner" browser
        |> Task.map not  -- Expect spinner to be hidden

-}

import Browser exposing (Browser, BrowserError)
import Task exposing (Task)

-- FFI import
foreign import javascript "../external/playwright.js" as Playwright


-- ============================================================================
-- Click Actions
-- ============================================================================


{-| Click an element.

Playwright auto-waits for the element to be visible and clickable.

    browser
        |> Element.click "#button"

-}
click : String -> Browser -> Task BrowserError Browser
click selector browser =
    Playwright.click selector browser


{-| Double-click an element.

    browser
        |> Element.doubleClick "#editable-cell"

-}
doubleClick : String -> Browser -> Task BrowserError Browser
doubleClick selector browser =
    Playwright.doubleClick selector browser


{-| Right-click an element (opens context menu).

    browser
        |> Element.rightClick "#item"
        |> Task.andThen (Element.waitForSelector "#context-menu")

-}
rightClick : String -> Browser -> Task BrowserError Browser
rightClick selector browser =
    Playwright.rightClick selector browser


{-| Hover over an element.

    browser
        |> Element.hover "#dropdown-trigger"
        |> Task.andThen (Element.waitForSelector "#dropdown-menu")

-}
hover : String -> Browser -> Task BrowserError Browser
hover selector browser =
    Playwright.hover selector browser


-- ============================================================================
-- Form Input
-- ============================================================================


{-| Fill an input field with text.

This clears the field first, then types the value instantly.

    browser
        |> Element.fill "#search" "canopy testing"

-}
fill : String -> String -> Browser -> Task BrowserError Browser
fill selector value browser =
    Playwright.fill selector value browser


{-| Type text character by character.

Unlike `fill`, this triggers individual keydown/keypress/keyup events.
Useful for testing autocomplete or real-time validation.

    browser
        |> Element.focus "#search"
        |> Task.andThen (Element.typeText "#search" "hello")

-}
typeText : String -> String -> Browser -> Task BrowserError Browser
typeText selector text browser =
    Playwright.typeText selector text browser


{-| Clear an input field.

    browser
        |> Element.clear "#search"

-}
clear : String -> Browser -> Task BrowserError Browser
clear selector browser =
    Playwright.clear selector browser


{-| Press a key or key combination.

    browser
        |> Element.press "Enter"
        |> Task.andThen (Element.press "Tab")
        |> Task.andThen (Element.press "Control+a")

Key names: Enter, Tab, Escape, ArrowUp, ArrowDown, etc.

-}
press : String -> Browser -> Task BrowserError Browser
press key browser =
    Playwright.press key browser


{-| Check a checkbox or radio button.

    browser
        |> Element.check "#agree-terms"

-}
check : String -> Browser -> Task BrowserError Browser
check selector browser =
    Playwright.check selector browser


{-| Uncheck a checkbox.

    browser
        |> Element.uncheck "#subscribe"

-}
uncheck : String -> Browser -> Task BrowserError Browser
uncheck selector browser =
    Playwright.uncheck selector browser


{-| Select an option from a dropdown.

    browser
        |> Element.selectOption "#country" "US"

The value can be the option's value attribute.

-}
selectOption : String -> String -> Browser -> Task BrowserError Browser
selectOption selector value browser =
    Playwright.selectOption selector value browser


{-| Focus an element.

    browser
        |> Element.focus "#search"

-}
focus : String -> Browser -> Task BrowserError Browser
focus selector browser =
    Playwright.focus selector browser


{-| Remove focus from currently focused element.

    browser
        |> Element.blur

-}
blur : Browser -> Task BrowserError Browser
blur browser =
    Playwright.blur browser


-- ============================================================================
-- Text Content Queries
-- ============================================================================


{-| Get the text content of an element (includes hidden text).

    Element.textContent "#message" browser
        |> Task.map (\text -> text == "Hello, World!")

-}
textContent : String -> Browser -> Task BrowserError String
textContent selector browser =
    Playwright.textContent selector browser


{-| Get the inner text of an element (visible text only).

    Element.innerText "#paragraph" browser

-}
innerText : String -> Browser -> Task BrowserError String
innerText selector browser =
    Playwright.innerText selector browser


{-| Get the inner HTML of an element.

    Element.innerHTML "#container" browser

-}
innerHTML : String -> Browser -> Task BrowserError String
innerHTML selector browser =
    Playwright.innerHTML selector browser


{-| Get an attribute value from an element.

    Element.getAttribute "#link" "href" browser
        |> Task.map (\href -> href == "/about")

-}
getAttribute : String -> String -> Browser -> Task BrowserError String
getAttribute selector name browser =
    Playwright.getAttribute selector name browser


{-| Get the value of an input field.

    Element.inputValue "#email" browser

-}
inputValue : String -> Browser -> Task BrowserError String
inputValue selector browser =
    Playwright.inputValue selector browser


-- ============================================================================
-- State Queries
-- ============================================================================


{-| Check if an element is visible.

    Element.isVisible "#loading" browser
        |> Task.map (\visible -> not visible)

-}
isVisible : String -> Browser -> Task BrowserError Bool
isVisible selector browser =
    Playwright.isVisible selector browser


{-| Check if an element is hidden.

    Element.isHidden "#modal" browser

-}
isHidden : String -> Browser -> Task BrowserError Bool
isHidden selector browser =
    Playwright.isHidden selector browser


{-| Check if an element is enabled (not disabled).

    Element.isEnabled "#submit" browser

-}
isEnabled : String -> Browser -> Task BrowserError Bool
isEnabled selector browser =
    Playwright.isEnabled selector browser


{-| Check if an element is disabled.

    Element.isDisabled "#submit" browser

-}
isDisabled : String -> Browser -> Task BrowserError Bool
isDisabled selector browser =
    Playwright.isDisabled selector browser


{-| Check if a checkbox or radio is checked.

    Element.isChecked "#agree-terms" browser

-}
isChecked : String -> Browser -> Task BrowserError Bool
isChecked selector browser =
    Playwright.isChecked selector browser


{-| Check if an element is editable (input, textarea, contenteditable).

    Element.isEditable "#comment" browser

-}
isEditable : String -> Browser -> Task BrowserError Bool
isEditable selector browser =
    Playwright.isEditable selector browser


{-| Count elements matching a selector.

    Element.count ".list-item" browser
        |> Task.map (\n -> n == 5)

-}
count : String -> Browser -> Task BrowserError Int
count selector browser =
    Playwright.count selector browser


{-| Check if any element matches the selector.

    Element.exists "#error-message" browser
        |> Task.map not  -- Expect no error

-}
exists : String -> Browser -> Task BrowserError Bool
exists selector browser =
    Playwright.exists selector browser


-- ============================================================================
-- Waiting
-- ============================================================================


{-| Wait for an element to be visible.

    browser
        |> Element.click "#load-more"
        |> Task.andThen (Element.waitForSelector ".new-items")

-}
waitForSelector : String -> Browser -> Task BrowserError Browser
waitForSelector selector browser =
    Playwright.waitForSelector selector browser


{-| Wait for an element to be hidden or removed.

    browser
        |> Element.click "#close"
        |> Task.andThen (Element.waitForHidden "#modal")

-}
waitForHidden : String -> Browser -> Task BrowserError Browser
waitForHidden selector browser =
    Playwright.waitForHidden selector browser


-- ============================================================================
-- Scrolling
-- ============================================================================


{-| Scroll an element into view.

    browser
        |> Element.scrollIntoView "#footer"
        |> Task.andThen (Element.click "#footer-link")

-}
scrollIntoView : String -> Browser -> Task BrowserError Browser
scrollIntoView selector browser =
    Playwright.scrollIntoView selector browser
