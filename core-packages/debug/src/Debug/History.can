unsafeFromString : String -> a
unsafeFromString _ =
    Debug.todo "unsafeFromString"


{-| Get the current timestamp in milliseconds.
Implemented via JavaScript FFI.
-}
getCurrentTimestamp : () -> Int
getCurrentTimestamp _ =
