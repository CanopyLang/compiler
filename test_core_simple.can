module TestCoreSimple exposing (..)

import Array
import Char
import Dict
import List
import Set
import String

-- Test function that uses previously missing modules
testFunction : String
testFunction =
    let
        arr = Array.fromList [1, 2, 3]
        dict = Dict.fromList [("a", 1), ("b", 2)]
        set = Set.fromList [1, 2, 3]
        str = String.toUpper "hello"
        char = Char.toUpper 'a'
    in
    "Successfully compiled with previously missing modules: Array, Char, Dict, Set, String"