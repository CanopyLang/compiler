# Test Configuration
# This file contains configuration for running the Canopy test suite

# Test timeout in seconds
TIMEOUT=300

# Test output format (can be: silent, normal, verbose)
OUTPUT_FORMAT=normal

# Enable/disable specific test suites
UNIT_TESTS=true
PROPERTY_TESTS=true
INTEGRATION_TESTS=true
GOLDEN_TESTS=false

# QuickCheck configuration
QUICKCHECK_TESTS=100
QUICKCHECK_MAX_SIZE=100

# Coverage reporting
COVERAGE=false
COVERAGE_DIR=coverage-report