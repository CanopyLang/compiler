module Main exposing (main)

import Html exposing (..)
import Html.Attributes exposing (..)
import Html.Events exposing (..)
import Math exposing (..)
import Time exposing (..)
import Browser


-- Main application
main : Program () Model Msg
main =
    Browser.element
        { init = init
        , update = update
        , subscriptions = subscriptions
        , view = view
        }


type alias Model =
    { result : String
    , timestamp : String
    }


type Msg
    = TestAdd
    | TestMultiply
    | TestGetTimestamp
    | TestCreateElement


init : () -> ( Model, Cmd Msg )
init _ =
    ( { result = "", timestamp = "" }, Cmd.none )


update : Msg -> Model -> ( Model, Cmd Msg )
update msg model =
    case msg of
        TestAdd ->
            let
                result = Math.add 5 3
            in
            ( { model | result = "5 + 3 = " ++ String.fromInt result }, Cmd.none )

        TestMultiply ->
            let
                result = Math.multiply 4 7
            in
            ( { model | result = "4 * 7 = " ++ String.fromInt result }, Cmd.none )

        TestGetTimestamp ->
            let
                timestamp = Time.getCurrentTimestamp
            in
            ( { model | timestamp = "Current timestamp: " ++ String.fromInt timestamp }, Cmd.none )

        TestCreateElement ->
            let
                _ = Math.createElement "div"
            in
            ( { model | result = "Element created successfully" }, Cmd.none )


subscriptions : Model -> Sub Msg
subscriptions _ =
    Sub.none


view : Model -> Html Msg
view model =
    div [ style "padding" "20px", style "font-family" "Arial, sans-serif" ]
        [ h1 [] [ text "Canopy FFI Test Suite" ]
        , div [ style "margin" "20px 0" ]
            [ h2 [] [ text "Math FFI Tests" ]
            , button [ onClick TestAdd, style "margin" "5px" ] [ text "Test Math.add(5, 3)" ]
            , button [ onClick TestMultiply, style "margin" "5px" ] [ text "Test Math.multiply(4, 7)" ]
            , button [ onClick TestCreateElement, style "margin" "5px" ] [ text "Test Math.createElement('div')" ]
            ]
        , div [ style "margin" "20px 0" ]
            [ h2 [] [ text "Time FFI Tests" ]
            , button [ onClick TestGetTimestamp, style "margin" "5px" ] [ text "Test Time.getCurrentTimestamp()" ]
            ]
        , div [ style "margin" "20px 0" ]
            [ h2 [] [ text "Results" ]
            , div [ style "background-color" "#f0f0f0", style "padding" "10px", style "border-radius" "5px" ]
                [ p [] [ text model.result ]
                , p [] [ text model.timestamp ]
                ]
            ]
        ]