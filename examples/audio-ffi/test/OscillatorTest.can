module OscillatorTest exposing (main, suite)

{-| Unit Tests for Oscillator Functions

Tests all oscillator node creation and manipulation functions.

## Functions Tested

- createOscillator
- startOscillator
- stopOscillator
- setOscillatorFrequency
- setOscillatorDetune
- getOscillatorType
- getOscillatorFrequencyParam
- getOscillatorDetuneParam
- setOscillatorType
- setOscillatorPeriodicWave

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "Oscillator Functions"
        [ createOscillatorTests
        , oscillatorControlTests
        , oscillatorPropertyTests
        , oscillatorWaveformTests
        ]


-- ============================================================================
-- CREATE OSCILLATOR TESTS
-- ============================================================================


createOscillatorTests : Test
createOscillatorTests =
    describe "createOscillator"
        [ test "creates oscillator with valid frequency" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createOscillator ctx 440.0 "sine" of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "creates oscillator with minimum frequency" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createOscillator ctx 0.0 "sine" of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "creates oscillator with high frequency" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createOscillator ctx 20000.0 "sine" of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "creates oscillator with different waveforms" <|
            \_ ->
                withContext <| \ctx ->
                    let
                        sineResult = AudioFFI.createOscillator ctx 440.0 "sine"
                        squareResult = AudioFFI.createOscillator ctx 440.0 "square"
                        sawtoothResult = AudioFFI.createOscillator ctx 440.0 "sawtooth"
                        triangleResult = AudioFFI.createOscillator ctx 440.0 "triangle"
                    in
                    Expect.pass
        ]


-- ============================================================================
-- OSCILLATOR CONTROL TESTS
-- ============================================================================


oscillatorControlTests : Test
oscillatorControlTests =
    describe "oscillator controls"
        [ describe "startOscillator"
            [ test "starts oscillator at time 0" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                case AudioFFI.startOscillator osc 0.0 of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass

            , test "starts oscillator at future time" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                case AudioFFI.startOscillator osc 1.0 of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "stopOscillator"
            [ test "stops oscillator at specified time" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                case AudioFFI.startOscillator osc 0.0 of
                                    Ok _ ->
                                        case AudioFFI.stopOscillator osc 1.0 of
                                            Ok _ -> Expect.pass
                                            Err _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setOscillatorFrequency"
            [ test "sets frequency to new value" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                let
                                    _ = AudioFFI.setOscillatorFrequency osc 880.0 0.0
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setOscillatorDetune"
            [ test "sets detune in cents" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                let
                                    _ = AudioFFI.setOscillatorDetune osc 100.0 0.0
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- OSCILLATOR PROPERTY TESTS
-- ============================================================================


oscillatorPropertyTests : Test
oscillatorPropertyTests =
    describe "oscillator properties"
        [ describe "getOscillatorType"
            [ test "returns correct waveform type" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                Expect.equal "sine" (AudioFFI.getOscillatorType osc)
                            Err _ -> Expect.pass

            , test "returns square for square oscillator" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "square" of
                            Ok osc ->
                                Expect.equal "square" (AudioFFI.getOscillatorType osc)
                            Err _ -> Expect.pass
            ]

        , describe "getOscillatorFrequencyParam"
            [ test "returns valid audio param" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                let
                                    param = AudioFFI.getOscillatorFrequencyParam osc
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "getOscillatorDetuneParam"
            [ test "returns valid audio param" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                let
                                    param = AudioFFI.getOscillatorDetuneParam osc
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- OSCILLATOR WAVEFORM TESTS
-- ============================================================================


oscillatorWaveformTests : Test
oscillatorWaveformTests =
    describe "waveform types"
        [ test "sine waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createOscillator ctx 440.0 "sine" of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "square waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createOscillator ctx 440.0 "square" of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "sawtooth waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createOscillator ctx 440.0 "sawtooth" of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "triangle waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createOscillator ctx 440.0 "triangle" of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , describe "setOscillatorType"
            [ test "changes waveform type" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                case AudioFFI.setOscillatorType osc "square" of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err _ -> Expect.pass
