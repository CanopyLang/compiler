module OscillatorTest exposing (main, suite)

{-| Unit Tests for Oscillator Functions

Tests all oscillator node creation and manipulation functions.

## Functions Tested

- createOscillator
- startOscillator
- stopOscillator
- setOscillatorFrequency
- setOscillatorDetune
- getOscillatorType
- getOscillatorFrequencyParam
- getOscillatorDetuneParam
- setOscillatorType
- setOscillatorPeriodicWave

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, BrowserTest, describe, test, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser
        [ describe "Oscillator Functions"
            [ createOscillatorTests
            , oscillatorControlTests
            , oscillatorPropertyTests
            , oscillatorWaveformTests
            ]
        ]


suite : Test
suite =
    describe "Oscillator Functions"
        [ createOscillatorTests
        , oscillatorControlTests
        , oscillatorPropertyTests
        , oscillatorWaveformTests
        ]


-- ============================================================================
-- CREATE OSCILLATOR TESTS
-- ============================================================================


createOscillatorTests : Test
createOscillatorTests =
    describe "createOscillator"
        [ test "creates oscillator with 440Hz sine" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createOscillator 440 sine" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                        Expect.equal "sine" (AudioFFI.getOscillatorType osc)

        , test "creates oscillator with 0Hz sine" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createOscillator 0 sine" (AudioFFI.createOscillator ctx 0.0 "sine") <| \_ ->
                        Expect.pass

        , test "creates oscillator with 20000Hz sine" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createOscillator 20000 sine" (AudioFFI.createOscillator ctx 20000.0 "sine") <| \_ ->
                        Expect.pass

        , test "creates oscillator with different waveforms" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createOscillator square" (AudioFFI.createOscillator ctx 440.0 "square") <| \osc ->
                        Expect.equal "square" (AudioFFI.getOscillatorType osc)
        ]


-- ============================================================================
-- OSCILLATOR CONTROL TESTS
-- ============================================================================


oscillatorControlTests : Test
oscillatorControlTests =
    describe "oscillator controls"
        [ describe "startOscillator"
            [ test "starts oscillator at time 0" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            expectOk "startOscillator" (AudioFFI.startOscillator osc 0.0) <| \_ ->
                                Expect.pass

            , test "starts oscillator at future time" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            expectOk "startOscillator" (AudioFFI.startOscillator osc 1.0) <| \_ ->
                                Expect.pass
            ]

        , describe "stopOscillator"
            [ test "stops oscillator at specified time" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            expectOk "startOscillator" (AudioFFI.startOscillator osc 0.0) <| \_ ->
                                expectOk "stopOscillator" (AudioFFI.stopOscillator osc 1.0) <| \_ ->
                                    Expect.pass
            ]

        , describe "setOscillatorFrequency"
            [ test "sets frequency to new value" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            let
                                _ = AudioFFI.setOscillatorFrequency osc 880.0 0.0
                            in
                            Expect.pass
            ]

        , describe "setOscillatorDetune"
            [ test "sets detune in cents" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            let
                                _ = AudioFFI.setOscillatorDetune osc 100.0 0.0
                            in
                            Expect.pass
            ]
        ]


-- ============================================================================
-- OSCILLATOR PROPERTY TESTS
-- ============================================================================


oscillatorPropertyTests : Test
oscillatorPropertyTests =
    describe "oscillator properties"
        [ describe "getOscillatorType"
            [ test "returns sine for sine oscillator" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            Expect.equal "sine" (AudioFFI.getOscillatorType osc)

            , test "returns square for square oscillator" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "square") <| \osc ->
                            Expect.equal "square" (AudioFFI.getOscillatorType osc)
            ]

        , describe "getOscillatorFrequencyParam"
            [ test "returns param with frequency value" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            let
                                param = AudioFFI.getOscillatorFrequencyParam osc
                                value = AudioFFI.getAudioParamValue param
                            in
                            Expect.within (Expect.Absolute 0.01) 440.0 value
            ]

        , describe "getOscillatorDetuneParam"
            [ test "returns param with detune value 0" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            let
                                param = AudioFFI.getOscillatorDetuneParam osc
                                value = AudioFFI.getAudioParamValue param
                            in
                            Expect.within (Expect.Absolute 0.01) 0.0 value
            ]
        ]


-- ============================================================================
-- OSCILLATOR WAVEFORM TESTS
-- ============================================================================


oscillatorWaveformTests : Test
oscillatorWaveformTests =
    describe "waveform types"
        [ test "sine waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "sine" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                        Expect.equal "sine" (AudioFFI.getOscillatorType osc)

        , test "square waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "square" (AudioFFI.createOscillator ctx 440.0 "square") <| \osc ->
                        Expect.equal "square" (AudioFFI.getOscillatorType osc)

        , test "sawtooth waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "sawtooth" (AudioFFI.createOscillator ctx 440.0 "sawtooth") <| \osc ->
                        Expect.equal "sawtooth" (AudioFFI.getOscillatorType osc)

        , test "triangle waveform creates successfully" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "triangle" (AudioFFI.createOscillator ctx 440.0 "triangle") <| \osc ->
                        Expect.equal "triangle" (AudioFFI.getOscillatorType osc)

        , describe "setOscillatorType"
            [ test "changes waveform type from sine to square" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            expectOk "setOscillatorType" (AudioFFI.setOscillatorType osc "square") <| \_ ->
                                Expect.equal "square" (AudioFFI.getOscillatorType osc)
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err err -> Expect.fail ("withContext: createAudioContext failed: " ++ errorToString err)


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
