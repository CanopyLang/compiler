                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setConeInnerAngle panner 360.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 360.0 (AudioFFI.getPannerConeInnerAngle panner)

            , test "sets inner angle to 90 and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setConeInnerAngle panner 90.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 90.0 (AudioFFI.getPannerConeInnerAngle panner)
            ]

        , describe "setConeOuterAngle"
            [ test "sets outer angle and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setConeOuterAngle panner 270.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 270.0 (AudioFFI.getPannerConeOuterAngle panner)
            ]

        , describe "setConeOuterGain"
            [ test "sets outer gain to 0.25 and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setConeOuterGain panner 0.25 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 0.25 (AudioFFI.getPannerConeOuterGain panner)

            , test "sets outer gain to 0.5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setConeOuterGain panner 0.5 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 0.5 (AudioFFI.getPannerConeOuterGain panner)
            ]
        ]


-- ============================================================================
-- LISTENER TESTS
-- ============================================================================


listenerTests : Test
listenerTests =
    describe "Audio Listener"
        [ describe "getAudioListener"
            [ test "returns audio listener" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            listener = AudioFFI.getAudioListener ctx
                        in
                        Expect.pass
            ]

        , describe "getContextAudioListener"
            [ test "returns context audio listener" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            listener = AudioFFI.getContextAudioListener ctx
                        in
                        Expect.pass
            ]

        , describe "setListenerPosition"
            [ test "sets listener at origin" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            listener = AudioFFI.getAudioListener ctx
                            _ = AudioFFI.setListenerPosition listener 0.0 0.0 0.0
                        in
                        Expect.pass

            , test "sets listener position" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            listener = AudioFFI.getAudioListener ctx
                            _ = AudioFFI.setListenerPosition listener 1.0 2.0 3.0
                        in
                        Expect.pass
            ]

        , describe "setListenerForward"
            [ test "sets listener forward direction" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            listener = AudioFFI.getAudioListener ctx
                            _ = AudioFFI.setListenerForward listener 0.0 0.0 (-1.0)
                        in
                        Expect.pass
            ]

        , describe "setListenerUp"
            [ test "sets listener up direction" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            listener = AudioFFI.getAudioListener ctx
                            _ = AudioFFI.setListenerUp listener 0.0 1.0 0.0
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err err -> Expect.fail ("withRawContext: createAudioContext failed: " ++ errorToString err)


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
