module SpatialTest exposing (main, suite)

{-| Unit Tests for Spatial Audio Functions

Tests 3D panner node and audio listener functions.

## Functions Tested

- createPanner
- setPannerPosition
- setPannerOrientation
- setPannerOrientationDirect
- setPanningModel
- setDistanceModel
- setRefDistance
- setMaxDistance
- setRolloffFactor
- setConeInnerAngle
- setConeOuterAngle
- setConeOuterGain
- getPannerPositionX/Y/Z
- getPannerOrientationX/Y/Z
- getPannerDistanceModel
- getPannerPanningModel
- getPannerRefDistance
- getPannerMaxDistance
- getPannerRolloffFactor
- getPannerConeInnerAngle
- getPannerConeOuterAngle
- getPannerConeOuterGain
- getAudioListener
- setListenerPosition
- setListenerForward
- setListenerUp
- getContextAudioListener

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests, BrowserTest, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser [ suite ]


suite : Test
suite =
    describe "Spatial Audio Functions"
        [ pannerCreationTests
        , pannerPositionTests
        , pannerModelTests
        , pannerDistanceTests
        , pannerConeTests
        , listenerTests
        ]


-- ============================================================================
-- PANNER CREATION TESTS
-- ============================================================================


pannerCreationTests : Test
pannerCreationTests =
    describe "createPanner"
        [ test "creates panner with default equalpower model" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        panner = AudioFFI.createPanner ctx
                    in
                    Expect.equal "equalpower" (AudioFFI.getPannerPanningModel panner)

        , test "creates panner with default inverse distance model" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        panner = AudioFFI.createPanner ctx
                    in
                    Expect.equal "inverse" (AudioFFI.getPannerDistanceModel panner)

        , test "creates panner with default orientation X=1" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        panner = AudioFFI.createPanner ctx
                    in
                    Expect.within (Expect.Absolute 0.01) 1.0 (AudioFFI.getAudioParamValue (AudioFFI.getPannerOrientationX panner))

        , test "creates panner with default cone inner angle 360" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        panner = AudioFFI.createPanner ctx
                    in
                    Expect.within (Expect.Absolute 0.01) 360.0 (AudioFFI.getPannerConeInnerAngle panner)

        , test "creates panner with default cone outer angle 360" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        panner = AudioFFI.createPanner ctx
                    in
                    Expect.within (Expect.Absolute 0.01) 360.0 (AudioFFI.getPannerConeOuterAngle panner)

        , test "creates panner with default cone outer gain 0" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        panner = AudioFFI.createPanner ctx
                    in
                    Expect.within (Expect.Absolute 0.01) 0.0 (AudioFFI.getPannerConeOuterGain panner)

        , test "creates panner with default rolloff factor 1" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        panner = AudioFFI.createPanner ctx
                    in
                    Expect.within (Expect.Absolute 0.01) 1.0 (AudioFFI.getPannerRolloffFactor panner)
        ]


-- ============================================================================
-- PANNER POSITION TESTS
-- ============================================================================


pannerPositionTests : Test
pannerPositionTests =
    describe "panner position"
        [ describe "setPannerPosition"
            [ test "sets position at origin and reads back X=0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPannerPosition panner 0.0 0.0 0.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 0.0 (AudioFFI.getAudioParamValue (AudioFFI.getPannerPositionX panner))

            , test "sets position left and reads back X=-5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPannerPosition panner (-5.0) 0.0 0.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) (-5.0) (AudioFFI.getAudioParamValue (AudioFFI.getPannerPositionX panner))

            , test "sets position right and reads back X=5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPannerPosition panner 5.0 0.0 0.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 5.0 (AudioFFI.getAudioParamValue (AudioFFI.getPannerPositionX panner))

            , test "sets position above and reads back Y=5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPannerPosition panner 0.0 5.0 0.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 5.0 (AudioFFI.getAudioParamValue (AudioFFI.getPannerPositionY panner))

            , test "sets position in front and reads back Z=-5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPannerPosition panner 0.0 0.0 (-5.0) of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) (-5.0) (AudioFFI.getAudioParamValue (AudioFFI.getPannerPositionZ panner))
            ]

        , describe "getPannerPositionX/Y/Z"
            [ test "gets X position param with default 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                            param = AudioFFI.getPannerPositionX panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value

            , test "gets Y position param with default 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                            param = AudioFFI.getPannerPositionY panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value

            , test "gets Z position param with default 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                            param = AudioFFI.getPannerPositionZ panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]

        , describe "panner orientation"
            [ test "sets orientation and reads back X=0 Y=1 Z=0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPannerOrientation panner 0.0 1.0 0.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 1.0 (AudioFFI.getAudioParamValue (AudioFFI.getPannerOrientationY panner))

            , test "sets orientation direct and reads back Z=-1" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        expectOk "setPannerOrientationDirect" (AudioFFI.setPannerOrientationDirect panner 0.0 0.0 (-1.0)) <| \_ ->
                            Expect.within (Expect.Absolute 0.01) (-1.0) (AudioFFI.getAudioParamValue (AudioFFI.getPannerOrientationZ panner))

            , test "gets orientation X param with default 1" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                            param = AudioFFI.getPannerOrientationX panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 1.0 value

            , test "gets orientation Y param with default 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                            param = AudioFFI.getPannerOrientationY panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value

            , test "gets orientation Z param with default 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                            param = AudioFFI.getPannerOrientationZ panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]
        ]


-- ============================================================================
-- PANNER MODEL TESTS
-- ============================================================================


pannerModelTests : Test
pannerModelTests =
    describe "panner models"
        [ describe "setPanningModel"
            [ test "sets equalpower panning and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPanningModel panner "equalpower" of
                            _ ->
                                Expect.equal "equalpower" (AudioFFI.getPannerPanningModel panner)

            , test "sets HRTF panning and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setPanningModel panner "HRTF" of
                            _ ->
                                Expect.equal "HRTF" (AudioFFI.getPannerPanningModel panner)
            ]

        , describe "setDistanceModel"
            [ test "sets linear distance and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setDistanceModel panner "linear" of
                            _ ->
                                Expect.equal "linear" (AudioFFI.getPannerDistanceModel panner)

            , test "sets inverse distance and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setDistanceModel panner "inverse" of
                            _ ->
                                Expect.equal "inverse" (AudioFFI.getPannerDistanceModel panner)

            , test "sets exponential distance and verifies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setDistanceModel panner "exponential" of
                            _ ->
                                Expect.equal "exponential" (AudioFFI.getPannerDistanceModel panner)
            ]
        ]


-- ============================================================================
-- PANNER DISTANCE TESTS
-- ============================================================================


pannerDistanceTests : Test
pannerDistanceTests =
    describe "panner distance settings"
        [ describe "default distances"
            [ test "default refDistance is 1" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        Expect.within (Expect.Absolute 0.01) 1.0 (AudioFFI.getPannerRefDistance panner)

            , test "default maxDistance is 10000" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        Expect.within (Expect.Absolute 0.01) 10000.0 (AudioFFI.getPannerMaxDistance panner)
            ]

        , describe "setRefDistance"
            [ test "sets reference distance to 2" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setRefDistance panner 2.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 2.0 (AudioFFI.getPannerRefDistance panner)

            , test "sets reference distance to 0.5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setRefDistance panner 0.5 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 0.5 (AudioFFI.getPannerRefDistance panner)
            ]

        , describe "setMaxDistance"
            [ test "sets max distance to 1000" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setMaxDistance panner 1000.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 1000.0 (AudioFFI.getPannerMaxDistance panner)

            , test "sets max distance to 500" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setMaxDistance panner 500.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 500.0 (AudioFFI.getPannerMaxDistance panner)
            ]

        , describe "setRolloffFactor"
            [ test "sets rolloff factor to 0.5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setRolloffFactor panner 0.5 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 0.5 (AudioFFI.getPannerRolloffFactor panner)

            , test "sets rolloff factor to 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createPanner ctx
                        in
                        case AudioFFI.setRolloffFactor panner 0.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.01) 0.0 (AudioFFI.getPannerRolloffFactor panner)
            ]
        ]


