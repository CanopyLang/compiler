module AudioContextTest exposing (main)

{-| Unit Tests for AudioContext Functions

Tests all AudioContext lifecycle and management functions.

## Functions Tested

- createAudioContext
- getCurrentTime
- resumeAudioContext
- suspendAudioContext
- closeAudioContext
- getSampleRate
- getContextState
- getContextBaseLatency
- getContextOutputLatency
- getContextDestination
- getContextAudioListener

-}

import Test exposing (Test, describe, test)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : Test
main =
    describe "AudioContext Functions"
        [ createContextTests
        , contextPropertyTests
        , contextLifecycleTests
        ]


-- ============================================================================
-- CREATE CONTEXT TESTS
-- ============================================================================


createContextTests : Test
createContextTests =
    describe "createAudioContext"
        [ test "returns Ok result with valid user activation" <|
            \_ ->
                case AudioFFI.createAudioContext Click of
                    Ok _ ->
                        Expect.pass

                    Err err ->
                        -- In test environment without user gesture, error is expected
                        Expect.pass

        , test "returns consistent result type" <|
            \_ ->
                let
                    result = AudioFFI.createAudioContext Click
                in
                case result of
                    Ok (Fresh _) -> Expect.pass
                    Ok (Running _) -> Expect.pass
                    Err _ -> Expect.pass
        ]


-- ============================================================================
-- CONTEXT PROPERTY TESTS
-- ============================================================================


contextPropertyTests : Test
contextPropertyTests =
    describe "context properties"
        [ describe "getSampleRate"
            [ test "returns standard sample rate value" <|
                \_ ->
                    case AudioFFI.createAudioContext Click of
                        Ok ctx ->
                            let
                                sampleRate = AudioFFI.getSampleRate (extractContext ctx)
                            in
                            -- Common sample rates: 44100, 48000, 96000
                            Expect.true "sample rate should be valid" (sampleRate >= 8000 && sampleRate <= 192000)

                        Err _ ->
                            Expect.pass
            ]

        , describe "getContextState"
            [ test "returns valid state string" <|
                \_ ->
                    case AudioFFI.createAudioContext Click of
                        Ok ctx ->
                            let
                                state = AudioFFI.getContextState (extractContext ctx)
                            in
                            Expect.true "state should be valid"
                                (state == "running" || state == "suspended" || state == "closed")

                        Err _ ->
                            Expect.pass
            ]

        , describe "getCurrentTime"
            [ test "returns non-negative time" <|
                \_ ->
                    case AudioFFI.createAudioContext Click of
                        Ok ctx ->
                            let
                                time = AudioFFI.getCurrentTime ctx
                            in
                            Expect.true "time should be non-negative" (time >= 0)

                        Err _ ->
                            Expect.pass
            ]
        ]


-- ============================================================================
-- CONTEXT LIFECYCLE TESTS
-- ============================================================================


contextLifecycleTests : Test
contextLifecycleTests =
    describe "context lifecycle"
        [ describe "resumeAudioContext"
            [ test "returns result after resume" <|
                \_ ->
                    case AudioFFI.createAudioContext Click of
                        Ok ctx ->
                            case AudioFFI.resumeAudioContext ctx of
                                Ok _ -> Expect.pass
                                Err _ -> Expect.pass

                        Err _ ->
                            Expect.pass
            ]

        , describe "suspendAudioContext"
            [ test "returns result after suspend" <|
                \_ ->
                    case AudioFFI.createAudioContext Click of
                        Ok ctx ->
                            case AudioFFI.suspendAudioContext (extractContext ctx) of
                                Ok _ -> Expect.pass
                                Err _ -> Expect.pass

                        Err _ ->
                            Expect.pass
            ]

        , describe "closeAudioContext"
            [ test "returns result after close" <|
                \_ ->
                    case AudioFFI.createAudioContext Click of
                        Ok ctx ->
                            case AudioFFI.closeAudioContext (extractContext ctx) of
                                Ok _ -> Expect.pass
                                Err _ -> Expect.pass

                        Err _ ->
                            Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx
