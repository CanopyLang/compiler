module AudioContextTest exposing (main)

{-| Unit Tests for AudioContext Functions

Tests all AudioContext lifecycle and management functions.

## Functions Tested

- createAudioContext
- getCurrentTime
- resumeAudioContext
- suspendAudioContext
- closeAudioContext
- getSampleRate
- getContextState
- getContextBaseLatency
- getContextOutputLatency
- getContextDestination
- getContextAudioListener

-}

import Test exposing (Test, BrowserTest, inBrowser, describe, test)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser
        [ describe "AudioContext Functions"
            [ createContextTests
            , contextPropertyTests
            , contextLifecycleTests
            ]
        ]


-- ============================================================================
-- CREATE CONTEXT TESTS
-- ============================================================================


createContextTests : Test
createContextTests =
    describe "createAudioContext"
        [ test "returns Ok with Fresh context" <|
            \_ ->
                case AudioFFI.createAudioContext Click of
                    Ok (Fresh _) ->
                        Expect.pass

                    Ok _ ->
                        Expect.fail "expected Fresh context"

                    Err err ->
                        Expect.fail ("createAudioContext failed: " ++ errorToString err)

        , test "returns consistent Fresh result" <|
            \_ ->
                let
                    result = AudioFFI.createAudioContext Click
                in
                case result of
                    Ok (Fresh _) -> Expect.pass
                    Ok (Running _) -> Expect.fail "expected Fresh, got Running"
                    Err err -> Expect.fail ("createAudioContext failed: " ++ errorToString err)
        ]


-- ============================================================================
-- CONTEXT PROPERTY TESTS
-- ============================================================================


contextPropertyTests : Test
contextPropertyTests =
    describe "context properties"
        [ describe "getSampleRate"
            [ test "returns standard sample rate" <|
                \_ ->
                    withContext <| \ctx ->
                        let
                            sampleRate = AudioFFI.getSampleRate (extractContext ctx)
                        in
                        Expect.equal 48000 sampleRate
            ]

        , describe "getContextState"
            [ test "returns running state" <|
                \_ ->
                    withContext <| \ctx ->
                        let
                            state = AudioFFI.getContextState (extractContext ctx)
                        in
                        Expect.equal "running" state
            ]

        , describe "getCurrentTime"
            [ test "returns non-negative time" <|
                \_ ->
                    withContext <| \ctx ->
                        let
                            time = AudioFFI.getCurrentTime ctx
                        in
                        Expect.within (Expect.Absolute 0.001) 0.0 time
            ]
        ]


-- ============================================================================
-- CONTEXT LIFECYCLE TESTS
-- ============================================================================


contextLifecycleTests : Test
contextLifecycleTests =
    describe "context lifecycle"
        [ describe "resumeAudioContext"
            [ test "returns Ok with Running context" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.resumeAudioContext ctx of
                            Ok (Running _) -> Expect.pass
                            Ok _ -> Expect.fail "expected Running after resume"
                            Err err -> Expect.fail ("resumeAudioContext failed: " ++ errorToString err)
            ]

        , describe "suspendAudioContext"
            [ test "returns Ok after suspend" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.suspendAudioContext (extractContext ctx) of
                            Ok _ -> Expect.pass
                            Err err -> Expect.fail ("suspendAudioContext failed: " ++ errorToString err)
            ]

        , describe "closeAudioContext"
            [ test "returns Ok after close" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.closeAudioContext (extractContext ctx) of
                            Ok _ -> Expect.pass
                            Err err -> Expect.fail ("closeAudioContext failed: " ++ errorToString err)
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err err -> Expect.fail ("withContext: createAudioContext failed: " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
