module BufferTest exposing (main, suite)

{-| Unit Tests for AudioBuffer Functions

Tests all audio buffer creation, manipulation, and source functions.

## Functions Tested

- createBufferSource
- createSilentBuffer
- createEmptyBuffer
- createAudioBuffer
- cloneAudioBuffer
- getChannelData
- copyToChannel
- copyFromChannel
- reverseAudioBuffer
- normalizeAudioBuffer
- mixAudioBuffers
- trimSilence
- getBufferPeak
- getBufferRMS
- getBufferLength
- getBufferDuration
- getBufferSampleRate
- getBufferChannels
- getBufferAsArray
- startBufferSource
- stopBufferSource
- setBufferSourceBuffer
- setBufferSourceLoop
- getBufferSourceBuffer
- getBufferSourceLoop
- getBufferSourceLoopStart
- getBufferSourceLoopEnd
- setBufferSourceLoopStart
- setBufferSourceLoopEnd
- setBufferSourcePlaybackRate
- setBufferSourceDetune
- getBufferSourcePlaybackRate
- getBufferSourceDetune

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, BrowserTest, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser [ suite ]


suite : Test
suite =
    describe "AudioBuffer Functions"
        [ bufferCreationTests
        , bufferPropertyTests
        , bufferManipulationTests
        , bufferSourceTests
        , bufferSourcePropertyTests
        ]


-- ============================================================================
-- BUFFER CREATION TESTS
-- ============================================================================


bufferCreationTests : Test
bufferCreationTests =
    describe "buffer creation"
        [ describe "createEmptyBuffer"
            [ test "creates empty stereo buffer with 2 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                        in
                        Expect.equal 2 (AudioFFI.getBufferChannels buffer)

            , test "creates empty mono buffer with 1 channel" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createEmptyBuffer ctx 1 0.5 48000
                        in
                        Expect.equal 1 (AudioFFI.getBufferChannels buffer)
            ]

        , describe "createSilentBuffer"
            [ test "creates silent buffer with correct length" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createSilentBuffer ctx 2 44100 44100.0
                            length = AudioFFI.getBufferLength buffer
                        in
                        Expect.equal 44100 length
            ]

        , describe "createAudioBuffer"
            [ test "creates buffer with correct properties" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createAudioBuffer ctx 2 44100 44100.0
                        in
                        Expect.equal 2 (AudioFFI.getBufferChannels buffer)
            ]

        , describe "cloneAudioBuffer"
            [ test "clones buffer preserving properties" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            original = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                        in
                        expectOk "cloneAudioBuffer" (AudioFFI.cloneAudioBuffer original) <| \clone ->
                            Expect.equal (AudioFFI.getBufferChannels original) (AudioFFI.getBufferChannels clone)
            ]
        ]


-- ============================================================================
-- BUFFER PROPERTY TESTS
-- ============================================================================


bufferPropertyTests : Test
bufferPropertyTests =
    describe "buffer properties"
        [ describe "getBufferLength"
            [ test "returns correct sample count" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createAudioBuffer ctx 2 44100 44100.0
                            length = AudioFFI.getBufferLength buffer
                        in
                        Expect.equal 44100 length
            ]

        , describe "getBufferDuration"
            [ test "returns duration in seconds" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createAudioBuffer ctx 2 44100 44100.0
                            duration = AudioFFI.getBufferDuration buffer
                        in
                        Expect.within (Expect.Absolute 0.01) 1.0 duration
            ]

        , describe "getBufferSampleRate"
            [ test "returns correct sample rate" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createAudioBuffer ctx 2 44100 44100.0
                            sampleRate = AudioFFI.getBufferSampleRate buffer
                        in
                        Expect.equal 44100.0 sampleRate
            ]

        , describe "getBufferChannels"
            [ test "returns correct channel count" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createAudioBuffer ctx 2 44100 44100.0
                            channels = AudioFFI.getBufferChannels buffer
                        in
                        Expect.equal 2 channels
            ]

        , describe "getBufferPeak"
            [ test "returns 0 for silent buffer" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createSilentBuffer ctx 2 44100 44100.0
                            peak = AudioFFI.getBufferPeak buffer
                        in
                        Expect.within (Expect.Absolute 0.001) 0.0 peak
            ]

        , describe "getBufferRMS"
            [ test "returns 0 for silent buffer" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createSilentBuffer ctx 2 44100 44100.0
                            rms = AudioFFI.getBufferRMS buffer
                        in
                        Expect.within (Expect.Absolute 0.001) 0.0 rms
            ]
        ]


-- ============================================================================
-- BUFFER MANIPULATION TESTS
-- ============================================================================


bufferManipulationTests : Test
bufferManipulationTests =
    describe "buffer manipulation"
        [ describe "getChannelData"
            [ test "retrieves channel data successfully" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                        in
                        expectOk "getChannelData" (AudioFFI.getChannelData buffer 0) <| \_ ->
                            Expect.pass
            ]

        , describe "getBufferAsArray"
            [ test "returns samples as list" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createEmptyBuffer ctx 2 0.1 44100
                            samples = AudioFFI.getBufferAsArray buffer 0
                        in
                        Expect.true "should have samples" (List.length samples > 0)
            ]

        , describe "reverseAudioBuffer"
            [ test "reverses buffer successfully" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                        in
                        expectOk "reverseAudioBuffer" (AudioFFI.reverseAudioBuffer buffer) <| \_ ->
                            Expect.pass
            ]

        , describe "normalizeAudioBuffer"
            [ test "normalizes buffer successfully" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                        in
                        expectOk "normalizeAudioBuffer" (AudioFFI.normalizeAudioBuffer buffer 1.0) <| \_ ->
                            Expect.pass
            ]

        , describe "trimSilence"
            [ test "trims silent buffer" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            buffer = AudioFFI.createSilentBuffer ctx 2 44100 44100.0
                        in
                        expectOk "trimSilence" (AudioFFI.trimSilence buffer 0.001) <| \_ ->
                            Expect.pass
            ]
        ]


-- ============================================================================
-- BUFFER SOURCE TESTS
-- ============================================================================


bufferSourceTests : Test
bufferSourceTests =
    describe "buffer source"
        [ describe "createBufferSource"
            [ test "creates buffer source node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                        in
                        Expect.pass
            ]

        , describe "startBufferSource"
            [ test "starts playback at time 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                            _ = AudioFFI.setBufferSourceBuffer source buffer
                        in
                        expectOk "startBufferSource" (AudioFFI.startBufferSource source 0.0) <| \_ ->
                            Expect.pass
            ]

        , describe "stopBufferSource"
            [ test "stops playback" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                            _ = AudioFFI.setBufferSourceBuffer source buffer
                        in
                        expectOk "startBufferSource" (AudioFFI.startBufferSource source 0.0) <| \_ ->
                            expectOk "stopBufferSource" (AudioFFI.stopBufferSource source 0.5) <| \_ ->
                                Expect.pass
            ]

        , describe "setBufferSourceBuffer"
            [ test "assigns buffer to source" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                            _ = AudioFFI.setBufferSourceBuffer source buffer
                        in
                        Expect.pass
            ]

        , describe "setBufferSourceLoop"
            [ test "enables looping" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            _ = AudioFFI.setBufferSourceLoop source True
                            loop = AudioFFI.getBufferSourceLoop source
                        in
                        Expect.equal True loop

            , test "disables looping" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            _ = AudioFFI.setBufferSourceLoop source False
                            loop = AudioFFI.getBufferSourceLoop source
                        in
                        Expect.equal False loop
            ]
        ]


-- ============================================================================
-- BUFFER SOURCE PROPERTY TESTS
-- ============================================================================


bufferSourcePropertyTests : Test
bufferSourcePropertyTests =
    describe "buffer source properties"
        [ describe "loop start/end"
            [ test "sets and gets loop start" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            _ = AudioFFI.setBufferSourceLoopStart source 0.5
                            loopStart = AudioFFI.getBufferSourceLoopStart source
                        in
                        Expect.within (Expect.Absolute 0.01) 0.5 loopStart

            , test "sets and gets loop end" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            _ = AudioFFI.setBufferSourceLoopEnd source 2.0
                            loopEnd = AudioFFI.getBufferSourceLoopEnd source
                        in
                        Expect.within (Expect.Absolute 0.01) 2.0 loopEnd
            ]

        , describe "playback rate and detune"
            [ test "gets playback rate param with default 1" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            param = AudioFFI.getBufferSourcePlaybackRate source
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 1.0 value

            , test "gets detune param with default 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            source = AudioFFI.createBufferSource ctx
                            param = AudioFFI.getBufferSourceDetune source
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err err -> Expect.fail ("withContext: createAudioContext failed: " ++ errorToString err)


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err err -> Expect.fail ("withRawContext: createAudioContext failed: " ++ errorToString err)


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
