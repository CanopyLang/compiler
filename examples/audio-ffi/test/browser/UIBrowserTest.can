module UIBrowserTest exposing (tests)

{-| UI interaction tests for the Audio FFI example.

These tests verify that all UI elements are functional, accessible,
and respond correctly to user interactions.

-}

import Browser.Test exposing (..)
import Test exposing (Test)


{-| UI browser tests.
-}
tests : BrowserTest
tests =
    describe "UI Browser Tests"
        [ browserTest "page loads successfully"
            [ visit "http://localhost:8000/index.html"
            , seeText "Complete Audio FFI System"
            , see "[data-testid=ffi-validation]"
            , see "[data-testid=status-section]"
            ]

        , browserTest "mode selection buttons are functional"
            [ visit "http://localhost:8000/index.html"
            , see "[data-testid=mode-simplified]"
            , see "[data-testid=mode-typesafe]"
            , see "[data-testid=mode-comparison]"
            , click "[data-testid=mode-typesafe]"
            , waitFor "[data-testid=typesafe-interface]"
            , click "[data-testid=mode-simplified]"
            , waitFor "[data-testid=simplified-interface]"
            ]

        , browserTest "controls section shows frequency slider"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=audio-controls]"
            , see "[data-testid=frequency-slider]"
            , see "[data-testid=frequency-value]"
            ]

        , browserTest "controls section shows volume slider"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=audio-controls]"
            , see "[data-testid=volume-slider]"
            , see "[data-testid=volume-value]"
            ]

        , browserTest "waveform selection buttons"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=waveform-controls]"
            , click "[data-testid=waveform-square]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=waveform-sine]"
            , waitFor "[data-testid=status]"
            ]

        , browserTest "advanced section toggle"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=toggle-advanced]"
            , waitFor "[data-testid=advanced-section]"
            , seeText "Type Signatures Used"
            , click "[data-testid=toggle-advanced]"
            , dontSee "[data-testid=advanced-section]"
            ]

        , browserTest "operation log updates"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=init-audio-simple]"
            , waitFor "[data-testid=operation-log]"
            , click "[data-testid=clear-log]"
            ]

        , browserTest "status displays current state"
            [ visit "http://localhost:8000/index.html"
            , see "[data-testid=status]"
            , seeText "Ready"
            , click "[data-testid=init-audio-simple]"
            , waitFor "[data-testid=status]"
            ]
        ]
