module OscillatorBrowserTest exposing (tests)

{-| Oscillator and audio playback tests for the Audio FFI example.

These tests verify that oscillator creation, playback, and parameter
changes work correctly in a real browser environment.

-}

import Browser.Test exposing (..)
import Test exposing (Test)


{-| Oscillator browser tests.
-}
tests : BrowserTest
tests =
    describe "Oscillator Browser Tests"
        [ browserTest "play sine wave via simplified interface"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=init-audio-simple]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=play-audio-simple]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=stop-audio-simple]"
            ]

        , browserTest "change waveform during playback"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=init-audio-simple]"
            , click "[data-testid=play-audio-simple]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=waveform-square]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=waveform-sawtooth]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=stop-audio-simple]"
            ]

        , browserTest "create oscillator in type-safe mode"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=mode-typesafe]"
            , waitFor "[data-testid=typesafe-interface]"
            , click "[data-testid=init-audio-typesafe]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=create-nodes-typesafe]"
            , waitFor "[data-testid=status]"
            , click "[data-testid=toggle-advanced]"
            , waitFor "[data-testid=advanced-section]"
            , seeText "OscillatorNode: Created"
            ]

        , browserTest "full type-safe playback cycle"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=mode-typesafe]"
            , waitFor "[data-testid=init-audio-typesafe]"
            , click "[data-testid=init-audio-typesafe]"
            , click "[data-testid=create-nodes-typesafe]"
            , click "[data-testid=play-audio-typesafe]"
            , waitFor "[data-testid=status]"
            , seeText "playing"
            , click "[data-testid=stop-audio-typesafe]"
            , waitFor "[data-testid=status]"
            , seeText "stopped"
            ]

        , browserTest "waveform button triangle selection"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=waveform-triangle]"
            , waitFor "[data-testid=status]"
            , seeText "triangle"
            ]
        ]
