module AudioContextBrowserTest exposing (tests)

{-| AudioContext lifecycle tests for the Audio FFI example.

These tests verify that AudioContext creation, state transitions, and cleanup
work correctly in a real browser environment.

-}

import Browser.Test exposing (..)
import Test exposing (Test)


{-| AudioContext browser tests.
-}
tests : BrowserTest
tests =
    describe "AudioContext Browser Tests"
        [ browserTest "AudioContext requires user activation"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=mode-typesafe]"
            , click "[data-testid=mode-typesafe]"
            , waitFor "[data-testid=init-audio-typesafe]"
            , click "[data-testid=init-audio-typesafe]"
            , waitFor "[data-testid=status]"
            , seeText "AudioContext"
            ]

        , browserTest "context shows running state after creation"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=mode-typesafe]"
            , waitFor "[data-testid=init-audio-typesafe]"
            , click "[data-testid=init-audio-typesafe]"
            , click "[data-testid=toggle-advanced]"
            , waitFor "[data-testid=advanced-section]"
            , seeText "AudioContext: Initialized"
            ]

        , browserTest "AudioContext in simplified mode"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=init-audio-simple]"
            , click "[data-testid=init-audio-simple]"
            , waitFor "[data-testid=status]"
            ]

        , browserTest "status updates on AudioContext creation"
            [ visit "http://localhost:8000/index.html"
            , click "[data-testid=mode-typesafe]"
            , waitFor "[data-testid=init-audio-typesafe]"
            , click "[data-testid=init-audio-typesafe]"
            , see "[data-testid=operation-log]"
            , seeText "AudioContext"
            ]
        ]
