module FFIValidationBrowserTest exposing (tests)

{-| FFI validation tests for the Audio FFI example.

These tests verify that the FFI bindings work correctly, including
basic function calls and Web Audio API availability detection.

-}

import Browser.Test exposing (..)
import Test exposing (Test)


{-| FFI validation browser tests.
-}
tests : BrowserTest
tests =
    describe "FFI Validation Browser Tests"
        [ browserTest "simpleTest FFI function returns doubled value"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=ffi-simple-test]"
            , seeText "simpleTest(42) = 84"
            ]

        , browserTest "Web Audio API is supported in browser"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=ffi-web-audio]"
            , seeText "Web Audio"
            ]

        , browserTest "FFI validation section is visible"
            [ visit "http://localhost:8000/index.html"
            , see "[data-testid=ffi-validation]"
            , see "[data-testid=ffi-simple-test]"
            , see "[data-testid=ffi-web-audio]"
            ]

        , browserTest "FFI functions are callable from Canopy"
            [ visit "http://localhost:8000/index.html"
            , waitFor "[data-testid=ffi-validation]"
            , seeText "84"
            ]
        ]
