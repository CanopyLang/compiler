module EffectsTest exposing (main, suite)

{-| Unit Tests for Audio Effects Functions

Tests delay, convolver, compressor, wave shaper, and stereo panner.

## Functions Tested

- createDelay
- setDelayTime
- getDelayDelayTimeParam
- getDelayMaxDelayTime
- createConvolver
- setConvolverBuffer
- setConvolverNormalize
- getConvolverBuffer
- getConvolverNormalize
- createDynamicsCompressor
- setCompressorThreshold
- setCompressorKnee
- setCompressorRatio
- setCompressorAttack
- setCompressorRelease
- getCompressorReduction
- getCompressorThresholdParam
- getCompressorKneeParam
- getCompressorRatioParam
- getCompressorAttackParam
- getCompressorReleaseParam
- setCompressorAttackDirect
- setCompressorReleaseDirect
- createWaveShaper
- setWaveShaperCurve
- setWaveShaperOversample
- getWaveShaperCurve
- getWaveShaperOversample
- makeDistortionCurve
- createStereoPanner
- setPan
- getStereoPannerPan

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "Audio Effects Functions"
        [ delayTests
        , convolverTests
        , compressorTests
        , waveShaperTests
        , stereoPannerTests
        ]


-- ============================================================================
-- DELAY TESTS
-- ============================================================================


delayTests : Test
delayTests =
    describe "Delay Node"
        [ describe "createDelay"
            [ test "creates delay with max time" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 1.0
                        in
                        Expect.pass

            , test "creates delay with 5 second max" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 5.0
                        in
                        Expect.pass
            ]

        , describe "setDelayTime"
            [ test "sets delay time" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 1.0
                            _ = AudioFFI.setDelayTime delay 0.5 0.0
                        in
                        Expect.pass
            ]

        , describe "getDelayDelayTimeParam"
            [ test "returns delay time param" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 1.0
                            param = AudioFFI.getDelayDelayTimeParam delay
                        in
                        Expect.pass
            ]

        ]


-- ============================================================================
-- CONVOLVER TESTS
-- ============================================================================


convolverTests : Test
convolverTests =
    describe "Convolver Node"
        [ describe "createConvolver"
            [ test "creates convolver node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                        in
                        Expect.pass
            ]

        , describe "setConvolverBuffer"
            [ test "sets impulse response buffer" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                        in
                        case AudioFFI.setConvolverBuffer convolver buffer of
                            Ok _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setConvolverNormalize"
            [ test "enables normalization and returns True" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                            normalize = AudioFFI.setConvolverNormalize convolver True
                        in
                        Expect.equal True normalize

            , test "disables normalization and returns False" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                            normalize = AudioFFI.setConvolverNormalize convolver False
                        in
                        Expect.equal False normalize
            ]
        ]


-- ============================================================================
-- COMPRESSOR TESTS
-- ============================================================================


compressorTests : Test
compressorTests =
    describe "Dynamics Compressor"
        [ describe "createDynamicsCompressor"
            [ test "creates compressor node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                        in
                        Expect.pass
            ]

        , describe "compressor settings"
            [ test "sets threshold" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            _ = AudioFFI.setCompressorThreshold compressor (-24.0) 0.0
                        in
                        Expect.pass

            , test "sets knee" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            _ = AudioFFI.setCompressorKnee compressor 30.0 0.0
                        in
                        Expect.pass

            , test "sets ratio" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            _ = AudioFFI.setCompressorRatio compressor 12.0 0.0
                        in
                        Expect.pass

            , test "sets attack" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            _ = AudioFFI.setCompressorAttack compressor 0.003 0.0
                        in
                        Expect.pass

            , test "sets release" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            _ = AudioFFI.setCompressorRelease compressor 0.25 0.0
                        in
                        Expect.pass
            ]

        , describe "compressor params"
            [ test "gets threshold param" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorThresholdParam compressor
                        in
                        Expect.pass

            , test "gets knee param" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorKneeParam compressor
                        in
                        Expect.pass

            , test "gets ratio param" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorRatioParam compressor
                        in
                        Expect.pass

            , test "gets reduction meter" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            reduction = AudioFFI.getCompressorReduction compressor
                        in
                        Expect.true "reduction should be <= 0" (reduction <= 0)
            ]
        ]


-- ============================================================================
-- WAVE SHAPER TESTS
-- ============================================================================


waveShaperTests : Test
waveShaperTests =
    describe "Wave Shaper"
        [ describe "createWaveShaper"
            [ test "creates wave shaper node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                        in
                        Expect.pass
            ]

        , describe "setWaveShaperCurve"
            [ test "sets distortion curve" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                            curve = [-1.0, -0.5, 0.0, 0.5, 1.0]
                        in
                        case AudioFFI.setWaveShaperCurve shaper curve of
                            Ok _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setWaveShaperOversample"
            [ test "sets oversample to none and returns value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                            oversample = AudioFFI.setWaveShaperOversample shaper "none"
                        in
                        Expect.equal "none" oversample

            , test "sets oversample to 2x and returns value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                            oversample = AudioFFI.setWaveShaperOversample shaper "2x"
                        in
                        Expect.equal "2x" oversample

            , test "sets oversample to 4x and returns value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                            oversample = AudioFFI.setWaveShaperOversample shaper "4x"
                        in
                        Expect.equal "4x" oversample
            ]

        , describe "makeDistortionCurve"
            [ test "generates distortion curve" <|
                \_ ->
                    let
                        curve = AudioFFI.makeDistortionCurve 50.0 256
                    in
                    Expect.true "curve should have samples" (List.length curve > 0)
            ]
        ]


-- ============================================================================
-- STEREO PANNER TESTS
-- ============================================================================


stereoPannerTests : Test
stereoPannerTests =
    describe "Stereo Panner"
        [ describe "createStereoPanner"
            [ test "creates stereo panner node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                        in
                        Expect.pass
            ]

        , describe "setPan"
            [ test "pans to center" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                            _ = AudioFFI.setPan panner 0.0 0.0
                        in
                        Expect.pass

            , test "pans to left" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                            _ = AudioFFI.setPan panner (-1.0) 0.0
                        in
                        Expect.pass

            , test "pans to right" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                            _ = AudioFFI.setPan panner 1.0 0.0
                        in
                        Expect.pass
            ]

        , describe "getStereoPannerPan"
            [ test "returns pan param" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                            param = AudioFFI.getStereoPannerPan panner
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err _ -> Expect.pass


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx
