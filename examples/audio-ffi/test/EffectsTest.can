module EffectsTest exposing (main, suite)

{-| Unit Tests for Audio Effects Functions

Tests delay, convolver, compressor, wave shaper, and stereo panner.

## Functions Tested

- createDelay
- setDelayTime
- getDelayDelayTimeParam
- getDelayMaxDelayTime
- createConvolver
- setConvolverBuffer
- setConvolverNormalize
- getConvolverBuffer
- getConvolverNormalize
- createDynamicsCompressor
- setCompressorThreshold
- setCompressorKnee
- setCompressorRatio
- setCompressorAttack
- setCompressorRelease
- getCompressorReduction
- getCompressorThresholdParam
- getCompressorKneeParam
- getCompressorRatioParam
- getCompressorAttackParam
- getCompressorReleaseParam
- setCompressorAttackDirect
- setCompressorReleaseDirect
- createWaveShaper
- setWaveShaperCurve
- setWaveShaperOversample
- getWaveShaperCurve
- getWaveShaperOversample
- makeDistortionCurve
- createStereoPanner
- setPan
- getStereoPannerPan

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, BrowserTest, describe, test, runTests, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser
        [ suite
        ]


suite : Test
suite =
    describe "Audio Effects Functions"
        [ delayTests
        , convolverTests
        , compressorTests
        , waveShaperTests
        , stereoPannerTests
        ]


-- ============================================================================
-- DELAY TESTS
-- ============================================================================


delayTests : Test
delayTests =
    describe "Delay Node"
        [ describe "createDelay"
            [ test "creates delay with 1 second max" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 1.0
                            maxTime = AudioFFI.getDelayMaxDelayTime delay
                        in
                        Expect.within (Expect.Absolute 0.01) 1.0 maxTime

            , test "creates delay with 5 second max" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 5.0
                            maxTime = AudioFFI.getDelayMaxDelayTime delay
                        in
                        Expect.within (Expect.Absolute 0.01) 5.0 maxTime
            ]

        , describe "setDelayTime"
            [ test "sets delay time to 0.5 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 1.0
                        in
                        case AudioFFI.setDelayTime delay 0.5 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getDelayDelayTimeParam delay
                                    value = AudioFFI.getAudioParamValue param
                                in
                                Expect.within (Expect.Absolute 0.01) 0.5 value
            ]

        , describe "getDelayDelayTimeParam"
            [ test "returns delay time param" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            delay = AudioFFI.createDelay ctx 1.0
                            param = AudioFFI.getDelayDelayTimeParam delay
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]

        ]


-- ============================================================================
-- CONVOLVER TESTS
-- ============================================================================


convolverTests : Test
convolverTests =
    describe "Convolver Node"
        [ describe "createConvolver"
            [ test "creates convolver with normalize true by default" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                        in
                        Expect.equal True (AudioFFI.getConvolverNormalize convolver)
            ]

        , describe "setConvolverBuffer"
            [ test "sets impulse response buffer and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                            buffer = AudioFFI.createEmptyBuffer ctx 2 1.0 44100
                        in
                        expectOk "setConvolverBuffer" (AudioFFI.setConvolverBuffer convolver buffer) <| \_ ->
                            case AudioFFI.getConvolverBuffer convolver of
                                Just b ->
                                    Expect.equal (AudioFFI.getBufferLength buffer) (AudioFFI.getBufferLength b)

                                Nothing ->
                                    Expect.fail "expected convolver buffer to be set"
            ]

        , describe "setConvolverNormalize"
            [ test "enables normalization" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                        in
                        case AudioFFI.setConvolverNormalize convolver True of
                            _ ->
                                Expect.equal True (AudioFFI.getConvolverNormalize convolver)

            , test "disables normalization" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            convolver = AudioFFI.createConvolver ctx
                        in
                        case AudioFFI.setConvolverNormalize convolver False of
                            _ ->
                                Expect.equal False (AudioFFI.getConvolverNormalize convolver)
            ]
        ]


-- ============================================================================
-- COMPRESSOR TESTS
-- ============================================================================


compressorTests : Test
compressorTests =
    describe "Dynamics Compressor"
        [ describe "createDynamicsCompressor"
            [ test "creates compressor with default threshold" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorThresholdParam compressor
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) (-24.0) value
            ]

        , describe "compressor settings"
            [ test "sets threshold to -30 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                        in
                        case AudioFFI.setCompressorThreshold compressor (-30.0) 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getCompressorThresholdParam compressor
                                in
                                Expect.within (Expect.Absolute 0.01) (-30.0) (AudioFFI.getAudioParamValue param)

            , test "sets knee to 20 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                        in
                        case AudioFFI.setCompressorKnee compressor 20.0 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getCompressorKneeParam compressor
                                in
                                Expect.within (Expect.Absolute 0.01) 20.0 (AudioFFI.getAudioParamValue param)

            , test "sets ratio to 8 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                        in
                        case AudioFFI.setCompressorRatio compressor 8.0 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getCompressorRatioParam compressor
                                in
                                Expect.within (Expect.Absolute 0.01) 8.0 (AudioFFI.getAudioParamValue param)

            , test "sets attack to 0.01 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                        in
                        case AudioFFI.setCompressorAttack compressor 0.01 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getCompressorAttackParam compressor
                                in
                                Expect.within (Expect.Absolute 0.001) 0.01 (AudioFFI.getAudioParamValue param)

            , test "sets release to 0.1 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                        in
                        case AudioFFI.setCompressorRelease compressor 0.1 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getCompressorReleaseParam compressor
                                in
                                Expect.within (Expect.Absolute 0.01) 0.1 (AudioFFI.getAudioParamValue param)
            ]

        , describe "compressor params"
            [ test "gets threshold param with default -24" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorThresholdParam compressor
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) (-24.0) value

            , test "gets knee param with default 30" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorKneeParam compressor
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 30.0 value

            , test "gets ratio param with default 12" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorRatioParam compressor
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 12.0 value

            , test "gets attack param with default 0.003" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorAttackParam compressor
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.001) 0.003 value

            , test "gets release param with default 0.25" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            param = AudioFFI.getCompressorReleaseParam compressor
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.25 value

            , test "gets reduction meter at 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            compressor = AudioFFI.createDynamicsCompressor ctx
                            reduction = AudioFFI.getCompressorReduction compressor
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 reduction
            ]
        ]


-- ============================================================================
-- WAVE SHAPER TESTS
-- ============================================================================


waveShaperTests : Test
waveShaperTests =
    describe "Wave Shaper"
        [ describe "createWaveShaper"
            [ test "creates wave shaper with oversample none" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                        in
                        Expect.equal "none" (AudioFFI.getWaveShaperOversample shaper)
            ]

        , describe "setWaveShaperCurve"
            [ test "sets distortion curve and reads back length" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                            curve = [-1.0, -0.5, 0.0, 0.5, 1.0]
                        in
                        expectOk "setWaveShaperCurve" (AudioFFI.setWaveShaperCurve shaper curve) <| \_ ->
                            case AudioFFI.getWaveShaperCurve shaper of
                                Just readCurve ->
                                    Expect.equal 5 (List.length readCurve)

                                Nothing ->
                                    Expect.fail "expected wave shaper curve to be set"
            ]

        , describe "setWaveShaperOversample"
            [ test "sets oversample to none" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                        in
                        case AudioFFI.setWaveShaperOversample shaper "none" of
                            _ ->
                                Expect.equal "none" (AudioFFI.getWaveShaperOversample shaper)

            , test "sets oversample to 2x" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                        in
                        case AudioFFI.setWaveShaperOversample shaper "2x" of
                            _ ->
                                Expect.equal "2x" (AudioFFI.getWaveShaperOversample shaper)

            , test "sets oversample to 4x" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            shaper = AudioFFI.createWaveShaper ctx
                        in
                        case AudioFFI.setWaveShaperOversample shaper "4x" of
                            _ ->
                                Expect.equal "4x" (AudioFFI.getWaveShaperOversample shaper)
            ]

        , describe "makeDistortionCurve"
            [ test "generates curve with 256 samples" <|
                \_ ->
                    let
                        curve = AudioFFI.makeDistortionCurve 50.0 256
                    in
                    Expect.equal 256 (List.length curve)
            ]
        ]


-- ============================================================================
-- STEREO PANNER TESTS
-- ============================================================================


stereoPannerTests : Test
stereoPannerTests =
    describe "Stereo Panner"
        [ describe "createStereoPanner"
            [ test "creates stereo panner with pan at 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                            param = AudioFFI.getStereoPannerPan panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]

        , describe "setPan"
            [ test "pans to center and reads back 0.0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                        in
                        case AudioFFI.setPan panner 0.0 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getStereoPannerPan panner
                                    value = AudioFFI.getAudioParamValue param
                                in
                                Expect.within (Expect.Absolute 0.01) 0.0 value

            , test "pans to left and reads back -1.0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                        in
                        case AudioFFI.setPan panner (-1.0) 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getStereoPannerPan panner
                                    value = AudioFFI.getAudioParamValue param
                                in
                                Expect.within (Expect.Absolute 0.01) (-1.0) value

            , test "pans to right and reads back 1.0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                        in
                        case AudioFFI.setPan panner 1.0 0.0 of
                            _ ->
                                let
                                    param = AudioFFI.getStereoPannerPan panner
                                    value = AudioFFI.getAudioParamValue param
                                in
                                Expect.within (Expect.Absolute 0.01) 1.0 value
            ]

        , describe "getStereoPannerPan"
            [ test "returns pan param with default 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            panner = AudioFFI.createStereoPanner ctx
                            param = AudioFFI.getStereoPannerPan panner
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err err -> Expect.fail ("withRawContext: createAudioContext failed: " ++ errorToString err)


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
