module AnalyserTest exposing (main, suite)

{-| Unit Tests for AnalyserNode Functions

Tests all analyser node creation and analysis functions.

## Functions Tested

- createAnalyser
- getByteTimeDomainData
- getByteFrequencyData
- getFloatTimeDomainData
- getFloatFrequencyData
- setAnalyserFFTSize
- getAnalyserFFTSize
- getAnalyserFrequencyBinCount
- setAnalyserMinDecibels
- setAnalyserMaxDecibels
- getAnalyserMinDecibels
- getAnalyserMaxDecibels
- setAnalyserSmoothingTimeConstant
- getAnalyserSmoothingTimeConstant
- setAnalyserSmoothing
- getFrequencyBinCount

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "AnalyserNode Functions"
        [ createAnalyserTests
        , analyserDataTests
        , analyserConfigTests
        , analyserPropertyTests
        ]


-- ============================================================================
-- CREATE ANALYSER TESTS
-- ============================================================================


createAnalyserTests : Test
createAnalyserTests =
    describe "createAnalyser"
        [ test "creates analyser node" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        analyser = AudioFFI.createAnalyser ctx
                    in
                    Expect.pass
        ]


-- ============================================================================
-- ANALYSER DATA TESTS
-- ============================================================================


analyserDataTests : Test
analyserDataTests =
    describe "analyser data retrieval"
        [ describe "getByteTimeDomainData"
            [ test "returns time domain data" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            data = AudioFFI.getByteTimeDomainData analyser
                        in
                        Expect.true "should return list" (True)
            ]

        , describe "getByteFrequencyData"
            [ test "returns frequency data" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            data = AudioFFI.getByteFrequencyData analyser
                        in
                        Expect.true "should return list" (True)
            ]

        , describe "getFloatTimeDomainData"
            [ test "returns float time domain data" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            data = AudioFFI.getFloatTimeDomainData analyser
                        in
                        Expect.true "should return list" (True)
            ]

        , describe "getFloatFrequencyData"
            [ test "returns float frequency data" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            data = AudioFFI.getFloatFrequencyData analyser
                        in
                        Expect.true "should return list" (True)
            ]
        ]


-- ============================================================================
-- ANALYSER CONFIG TESTS
-- ============================================================================


analyserConfigTests : Test
analyserConfigTests =
    describe "analyser configuration"
        [ describe "setAnalyserFFTSize"
            [ test "sets FFT size to 2048" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserFFTSize analyser 2048
                            fftSize = AudioFFI.getAnalyserFFTSize analyser
                        in
                        Expect.equal 2048 fftSize

            , test "sets FFT size to 256" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserFFTSize analyser 256
                            fftSize = AudioFFI.getAnalyserFFTSize analyser
                        in
                        Expect.equal 256 fftSize

            , test "sets FFT size to 4096" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserFFTSize analyser 4096
                            fftSize = AudioFFI.getAnalyserFFTSize analyser
                        in
                        Expect.equal 4096 fftSize

            , test "handles FFT size setting" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserFFTSize analyser 1024
                            fftSize = AudioFFI.getAnalyserFFTSize analyser
                        in
                        Expect.true "FFT size should be positive" (fftSize > 0)
            ]

        , describe "setAnalyserMinDecibels"
            [ test "sets min decibels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserMinDecibels analyser (-100.0) of
                            Ok _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setAnalyserMaxDecibels"
            [ test "sets max decibels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserMaxDecibels analyser (-30.0) of
                            Ok _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setAnalyserSmoothingTimeConstant"
            [ test "sets smoothing to 0.8" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserSmoothingTimeConstant analyser 0.8 of
                            Ok _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setAnalyserSmoothing"
            [ test "sets smoothing value 0.5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserSmoothing analyser 0.5
                            smoothing = AudioFFI.getAnalyserSmoothingTimeConstant analyser
                        in
                        Expect.within (Expect.Absolute 0.1) 0.5 smoothing

            , test "sets smoothing to 0.0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserSmoothing analyser 0.0
                            smoothing = AudioFFI.getAnalyserSmoothingTimeConstant analyser
                        in
                        Expect.within (Expect.Absolute 0.1) 0.0 smoothing

            , test "sets smoothing to 1.0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserSmoothing analyser 1.0
                            smoothing = AudioFFI.getAnalyserSmoothingTimeConstant analyser
                        in
                        Expect.within (Expect.Absolute 0.1) 1.0 smoothing

            , test "smoothing values are clamped to valid range" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserSmoothing analyser 0.8
                            smoothing = AudioFFI.getAnalyserSmoothingTimeConstant analyser
                        in
                        Expect.true "smoothing should be in 0-1 range" (smoothing >= 0 && smoothing <= 1)
            ]
        ]


-- ============================================================================
-- ANALYSER PROPERTY TESTS
-- ============================================================================


analyserPropertyTests : Test
analyserPropertyTests =
    describe "analyser properties"
        [ describe "getAnalyserFFTSize"
            [ test "returns FFT size" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserFFTSize analyser 2048
                            fftSize = AudioFFI.getAnalyserFFTSize analyser
                        in
                        Expect.equal 2048 fftSize
            ]

        , describe "getAnalyserFrequencyBinCount"
            [ test "returns half of FFT size" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            _ = AudioFFI.setAnalyserFFTSize analyser 2048
                            binCount = AudioFFI.getAnalyserFrequencyBinCount analyser
                        in
                        Expect.equal 1024 binCount
            ]

        , describe "getFrequencyBinCount"
            [ test "returns frequency bin count" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            binCount = AudioFFI.getFrequencyBinCount analyser
                        in
                        Expect.true "bin count should be positive" (binCount > 0)
            ]

        , describe "getAnalyserMinDecibels"
            [ test "returns min decibels value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            minDb = AudioFFI.getAnalyserMinDecibels analyser
                        in
                        Expect.true "min dB should be negative" (minDb < 0)
            ]

        , describe "getAnalyserMaxDecibels"
            [ test "returns max decibels value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            maxDb = AudioFFI.getAnalyserMaxDecibels analyser
                        in
                        Expect.true "max dB should be less than 0" (maxDb <= 0)
            ]

        , describe "getAnalyserSmoothingTimeConstant"
            [ test "returns smoothing value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            smoothing = AudioFFI.getAnalyserSmoothingTimeConstant analyser
                        in
                        Expect.true "smoothing should be 0-1" (smoothing >= 0 && smoothing <= 1)
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err _ -> Expect.pass


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx
