module AnalyserTest exposing (main, suite)

{-| Unit Tests for AnalyserNode Functions

Tests all analyser node creation and analysis functions.

## Functions Tested

- createAnalyser
- getByteTimeDomainData
- getByteFrequencyData
- getFloatTimeDomainData
- getFloatFrequencyData
- setAnalyserFFTSize
- getAnalyserFFTSize
- getAnalyserFrequencyBinCount
- setAnalyserMinDecibels
- setAnalyserMaxDecibels
- getAnalyserMinDecibels
- getAnalyserMaxDecibels
- setAnalyserSmoothingTimeConstant
- getAnalyserSmoothingTimeConstant
- setAnalyserSmoothing
- getFrequencyBinCount

-}

import Test exposing (Test, describe, test, BrowserTest, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser [ suite ]


suite : Test
suite =
    describe "AnalyserNode Functions"
        [ createAnalyserTests
        , analyserDataTests
        , analyserConfigTests
        , analyserPropertyTests
        ]


-- ============================================================================
-- CREATE ANALYSER TESTS
-- ============================================================================


createAnalyserTests : Test
createAnalyserTests =
    describe "createAnalyser"
        [ test "creates analyser with default FFT size 2048" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        analyser = AudioFFI.createAnalyser ctx
                        fftSize = AudioFFI.getAnalyserFFTSize analyser
                    in
                    Expect.equal 2048 fftSize
        ]


-- ============================================================================
-- ANALYSER DATA TESTS
-- ============================================================================


analyserDataTests : Test
analyserDataTests =
    describe "analyser data retrieval"
        [ describe "getByteTimeDomainData"
            [ test "returns list with fftSize elements" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            dataList = AudioFFI.getByteTimeDomainData analyser
                        in
                        Expect.equal 2048 (List.length dataList)
            ]

        , describe "getByteFrequencyData"
            [ test "returns list with frequencyBinCount elements" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            dataList = AudioFFI.getByteFrequencyData analyser
                        in
                        Expect.equal 1024 (List.length dataList)
            ]

        , describe "getFloatTimeDomainData"
            [ test "returns list with fftSize elements" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            dataList = AudioFFI.getFloatTimeDomainData analyser
                        in
                        Expect.equal 2048 (List.length dataList)
            ]

        , describe "getFloatFrequencyData"
            [ test "returns list with frequencyBinCount elements" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            dataList = AudioFFI.getFloatFrequencyData analyser
                        in
                        Expect.equal 1024 (List.length dataList)
            ]
        ]


-- ============================================================================
-- ANALYSER CONFIG TESTS
-- ============================================================================


analyserConfigTests : Test
analyserConfigTests =
    describe "analyser configuration"
        [ describe "setAnalyserFFTSize"
            [ test "sets FFT size to 2048" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserFFTSize analyser 2048 of
                            _ ->
                                Expect.equal 2048 (AudioFFI.getAnalyserFFTSize analyser)

            , test "sets FFT size to 256" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserFFTSize analyser 256 of
                            _ ->
                                Expect.equal 256 (AudioFFI.getAnalyserFFTSize analyser)

            , test "sets FFT size to 4096" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserFFTSize analyser 4096 of
                            _ ->
                                Expect.equal 4096 (AudioFFI.getAnalyserFFTSize analyser)

            , test "sets FFT size to 1024" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserFFTSize analyser 1024 of
                            _ ->
                                Expect.equal 1024 (AudioFFI.getAnalyserFFTSize analyser)
            ]

        , describe "setAnalyserMinDecibels"
            [ test "sets min decibels to -100" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        expectOk "setAnalyserMinDecibels" (AudioFFI.setAnalyserMinDecibels analyser (-100.0)) <| \_ ->
                            let
                                minDb = AudioFFI.getAnalyserMinDecibels analyser
                            in
                            Expect.within (Expect.Absolute 0.01) (-100.0) minDb
            ]

        , describe "setAnalyserMaxDecibels"
            [ test "sets max decibels to -30" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        expectOk "setAnalyserMaxDecibels" (AudioFFI.setAnalyserMaxDecibels analyser (-30.0)) <| \_ ->
                            let
                                maxDb = AudioFFI.getAnalyserMaxDecibels analyser
                            in
                            Expect.within (Expect.Absolute 0.01) (-30.0) maxDb
            ]

        , describe "setAnalyserSmoothingTimeConstant"
            [ test "sets smoothing to 0.8 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        expectOk "setAnalyserSmoothingTimeConstant" (AudioFFI.setAnalyserSmoothingTimeConstant analyser 0.8) <| \_ ->
                            Expect.within (Expect.Absolute 0.01) 0.8 (AudioFFI.getAnalyserSmoothingTimeConstant analyser)

            , test "sets smoothing to 0.5 and reads back" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        expectOk "setAnalyserSmoothingTimeConstant" (AudioFFI.setAnalyserSmoothingTimeConstant analyser 0.5) <| \_ ->
                            Expect.within (Expect.Absolute 0.01) 0.5 (AudioFFI.getAnalyserSmoothingTimeConstant analyser)
            ]

        , describe "error cases"
            [ test "setAnalyserMinDecibels above maxDecibels returns Err" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserMinDecibels analyser 0.0 of
                            Ok _ ->
                                Expect.fail "expected Err when minDecibels >= maxDecibels"

                            Err _ ->
                                Expect.pass
            ]

        , describe "setAnalyserSmoothing"
            [ test "sets smoothing value 0.5" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserSmoothing analyser 0.5 of
                            _ ->
                                Expect.within (Expect.Absolute 0.1) 0.5 (AudioFFI.getAnalyserSmoothingTimeConstant analyser)

            , test "sets smoothing to 0.0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserSmoothing analyser 0.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.1) 0.0 (AudioFFI.getAnalyserSmoothingTimeConstant analyser)

            , test "sets smoothing to 1.0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserSmoothing analyser 1.0 of
                            _ ->
                                Expect.within (Expect.Absolute 0.1) 1.0 (AudioFFI.getAnalyserSmoothingTimeConstant analyser)

            , test "smoothing default is 0.8" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            smoothing = AudioFFI.getAnalyserSmoothingTimeConstant analyser
                        in
                        Expect.within (Expect.Absolute 0.01) 0.8 smoothing
            ]
        ]


-- ============================================================================
-- ANALYSER PROPERTY TESTS
-- ============================================================================


analyserPropertyTests : Test
analyserPropertyTests =
    describe "analyser properties"
        [ describe "getAnalyserFFTSize"
            [ test "returns FFT size 2048 by default" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            fftSize = AudioFFI.getAnalyserFFTSize analyser
                        in
                        Expect.equal 2048 fftSize
            ]

        , describe "getAnalyserFrequencyBinCount"
            [ test "returns half of FFT size" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                        in
                        case AudioFFI.setAnalyserFFTSize analyser 2048 of
                            _ ->
                                Expect.equal 1024 (AudioFFI.getAnalyserFrequencyBinCount analyser)
            ]

        , describe "getFrequencyBinCount"
            [ test "returns 1024 for default 2048 FFT" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            binCount = AudioFFI.getFrequencyBinCount analyser
                        in
                        Expect.equal 1024 binCount
            ]

        , describe "getAnalyserMinDecibels"
            [ test "returns default -100" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            minDb = AudioFFI.getAnalyserMinDecibels analyser
                        in
                        Expect.within (Expect.Absolute 0.01) (-100.0) minDb
            ]

        , describe "getAnalyserMaxDecibels"
            [ test "returns default -30" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            maxDb = AudioFFI.getAnalyserMaxDecibels analyser
                        in
                        Expect.within (Expect.Absolute 0.01) (-30.0) maxDb
            ]

        , describe "getAnalyserSmoothingTimeConstant"
            [ test "returns default 0.8" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            analyser = AudioFFI.createAnalyser ctx
                            smoothing = AudioFFI.getAnalyserSmoothingTimeConstant analyser
                        in
                        Expect.within (Expect.Absolute 0.01) 0.8 smoothing
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err err -> Expect.fail ("withRawContext: createAudioContext failed: " ++ errorToString err)


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
