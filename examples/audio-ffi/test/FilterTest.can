module FilterTest exposing (main, suite)

{-| Unit Tests for Filter Functions

Tests all biquad filter and IIR filter functions.

## Functions Tested

- createBiquadFilter
- setFilterFrequency
- setFilterQ
- setFilterGain
- getBiquadFilterType
- setBiquadFilterTypeDirect
- getBiquadFilterFrequencyParam
- getBiquadFilterQParam
- getBiquadFilterGainParam
- getBiquadFilterDetuneParam
- createIIRFilter
- getIIRFilterResponse
- getIIRFilterResponseAtFrequency

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests, BrowserTest, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser
        [ suite
        ]


suite : Test
suite =
    describe "Filter Functions"
        [ biquadFilterTests
        , biquadFilterTypeTests
        , biquadFilterParamTests
        , iirFilterTests
        ]


-- ============================================================================
-- BIQUAD FILTER TESTS
-- ============================================================================


biquadFilterTests : Test
biquadFilterTests =
    describe "createBiquadFilter"
        [ test "creates lowpass filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "lowpass"
                    in
                    Expect.equal "lowpass" (AudioFFI.getBiquadFilterType filter)

        , test "creates highpass filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "highpass"
                    in
                    Expect.equal "highpass" (AudioFFI.getBiquadFilterType filter)

        , test "creates bandpass filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "bandpass"
                    in
                    Expect.equal "bandpass" (AudioFFI.getBiquadFilterType filter)

        , test "creates notch filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "notch"
                    in
                    Expect.equal "notch" (AudioFFI.getBiquadFilterType filter)

        , test "creates peaking filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "peaking"
                    in
                    Expect.equal "peaking" (AudioFFI.getBiquadFilterType filter)

        , test "creates lowshelf filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "lowshelf"
                    in
                    Expect.equal "lowshelf" (AudioFFI.getBiquadFilterType filter)

        , test "creates highshelf filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "highshelf"
                    in
                    Expect.equal "highshelf" (AudioFFI.getBiquadFilterType filter)

        , test "creates allpass filter" <|
            \_ ->
                withRawContext <| \ctx ->
                    let
                        filter = AudioFFI.createBiquadFilter ctx "allpass"
                    in
                    Expect.equal "allpass" (AudioFFI.getBiquadFilterType filter)
        ]


-- ============================================================================
-- BIQUAD FILTER TYPE TESTS
-- ============================================================================


biquadFilterTypeTests : Test
biquadFilterTypeTests =
    describe "biquad filter type operations"
        [ describe "getBiquadFilterType"
            [ test "returns correct filter type" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "lowpass"
                        in
                        Expect.equal "lowpass" (AudioFFI.getBiquadFilterType filter)
            ]

        , describe "setBiquadFilterTypeDirect"
            [ test "changes filter type to highpass" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "lowpass"
                        in
                        expectOk "setBiquadFilterTypeDirect" (AudioFFI.setBiquadFilterTypeDirect filter "highpass") <| \_ ->
                            Expect.equal "highpass" (AudioFFI.getBiquadFilterType filter)
            ]

        , describe "setFilterFrequency"
            [ test "sets cutoff frequency" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "lowpass"
                            _ = AudioFFI.setFilterFrequency filter 1000.0 0.0
                        in
                        Expect.pass
            ]

        , describe "setFilterQ"
            [ test "sets Q (resonance)" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "lowpass"
                            _ = AudioFFI.setFilterQ filter 10.0 0.0
                        in
                        Expect.pass
            ]

        , describe "setFilterGain"
            [ test "sets gain for peaking filters" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "peaking"
                            _ = AudioFFI.setFilterGain filter 6.0 0.0
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- BIQUAD FILTER PARAM TESTS
-- ============================================================================


biquadFilterParamTests : Test
biquadFilterParamTests =
    describe "biquad filter AudioParams"
        [ describe "getBiquadFilterFrequencyParam"
            [ test "returns frequency param with value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "lowpass"
                            param = AudioFFI.getBiquadFilterFrequencyParam filter
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.true "frequency param should be positive" (value > 0)
            ]

        , describe "getBiquadFilterQParam"
            [ test "returns Q param with value" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "lowpass"
                            param = AudioFFI.getBiquadFilterQParam filter
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 1.0 value
            ]

        , describe "getBiquadFilterGainParam"
            [ test "returns gain param with value 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "peaking"
                            param = AudioFFI.getBiquadFilterGainParam filter
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]

        , describe "getBiquadFilterDetuneParam"
            [ test "returns detune param with value 0" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            filter = AudioFFI.createBiquadFilter ctx "lowpass"
                            param = AudioFFI.getBiquadFilterDetuneParam filter
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value
            ]
        ]


-- ============================================================================
-- IIR FILTER TESTS
-- ============================================================================


iirFilterTests : Test
iirFilterTests =
    describe "IIR Filter"
        [ describe "createIIRFilter"
            [ test "creates IIR filter with coefficients" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            feedforward = [0.0675, 0.1349, 0.0675]
                            feedback = [1.0, -1.1430, 0.4128]
                        in
                        expectOk "createIIRFilter" (AudioFFI.createIIRFilter ctx feedforward feedback) <| \_ ->
                            Expect.pass
            ]

        , describe "getIIRFilterResponse"
            [ test "gets frequency response for frequencies" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            feedforward = [0.0675, 0.1349, 0.0675]
                            feedback = [1.0, -1.1430, 0.4128]
                        in
                        expectOk "createIIRFilter" (AudioFFI.createIIRFilter ctx feedforward feedback) <| \filter ->
                            let
                                frequencies = [100.0, 1000.0, 5000.0]
                            in
                            expectOk "getIIRFilterResponse" (AudioFFI.getIIRFilterResponse filter frequencies) <| \_ ->
                                Expect.pass
            ]

        , describe "getIIRFilterResponseAtFrequency"
            [ test "gets response at single frequency" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            feedforward = [0.0675, 0.1349, 0.0675]
                            feedback = [1.0, -1.1430, 0.4128]
                        in
                        expectOk "createIIRFilter" (AudioFFI.createIIRFilter ctx feedforward feedback) <| \filter ->
                            let
                                (magnitude, phase) = AudioFFI.getIIRFilterResponseAtFrequency filter 1000.0
                            in
                            Expect.true "magnitude should be positive" (magnitude > 0)
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err err -> Expect.fail ("withRawContext: createAudioContext failed: " ++ errorToString err)


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
