module GainTest exposing (main, suite)

{-| Unit Tests for GainNode Functions

Tests all gain node creation and manipulation functions.

## Functions Tested

- createGainNode
- setGain
- rampGainLinear
- rampGainExponential
- getGainNodeGainParam
- getGainParam

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests, BrowserTest, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser
        [ suite
        ]


suite : Test
suite =
    describe "GainNode Functions"
        [ createGainNodeTests
        , gainControlTests
        , gainRampTests
        , gainParamTests
        ]


-- ============================================================================
-- CREATE GAIN NODE TESTS
-- ============================================================================


createGainNodeTests : Test
createGainNodeTests =
    describe "createGainNode"
        [ test "creates gain node with gain 1.0" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createGainNode 1.0" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                        let
                            param = AudioFFI.getGainParam gainNode
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 1.0 value

        , test "creates gain node with gain 0.0 (muted)" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createGainNode 0.0" (AudioFFI.createGainNode ctx 0.0) <| \gainNode ->
                        let
                            param = AudioFFI.getGainParam gainNode
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.0 value

        , test "creates gain node with gain 0.5 (half volume)" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createGainNode 0.5" (AudioFFI.createGainNode ctx 0.5) <| \gainNode ->
                        let
                            param = AudioFFI.getGainParam gainNode
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 0.5 value

        , test "creates gain node with gain 2.0 (boost)" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createGainNode 2.0" (AudioFFI.createGainNode ctx 2.0) <| \gainNode ->
                        let
                            param = AudioFFI.getGainParam gainNode
                            value = AudioFFI.getAudioParamValue param
                        in
                        Expect.within (Expect.Absolute 0.01) 2.0 value
        ]


-- ============================================================================
-- GAIN CONTROL TESTS
-- ============================================================================


gainControlTests : Test
gainControlTests =
    describe "setGain"
        [ test "sets gain to 0.5 and reads back" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                        expectOk "setGain" (AudioFFI.setGain gainNode 0.5 0.0) <| \_ ->
                            let
                                param = AudioFFI.getGainParam gainNode
                                value = AudioFFI.getAudioParamValue param
                            in
                            Expect.within (Expect.Absolute 0.01) 0.5 value

        , test "sets gain to 0 (mute) and reads back" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                        expectOk "setGain" (AudioFFI.setGain gainNode 0.0 0.0) <| \_ ->
                            let
                                param = AudioFFI.getGainParam gainNode
                                value = AudioFFI.getAudioParamValue param
                            in
                            Expect.within (Expect.Absolute 0.01) 0.0 value

        , test "sets gain to 0.75 at time 0 and reads back" <|
            \_ ->
                withContext <| \ctx ->
                    expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                        expectOk "setGain" (AudioFFI.setGain gainNode 0.75 0.0) <| \_ ->
                            let
                                param = AudioFFI.getGainParam gainNode
                                value = AudioFFI.getAudioParamValue param
                            in
                            Expect.within (Expect.Absolute 0.01) 0.75 value
        ]


-- ============================================================================
-- GAIN RAMP TESTS
-- ============================================================================


gainRampTests : Test
gainRampTests =
    describe "gain ramping"
        [ describe "rampGainLinear"
            [ test "ramps gain linearly to 0.0 at endTime 0.0 and reads back" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                            expectOk "rampGainLinear" (AudioFFI.rampGainLinear gainNode 0.0 0.0) <| \_ ->
                                let
                                    param = AudioFFI.getGainParam gainNode
                                    value = AudioFFI.getAudioParamValue param
                                in
                                Expect.within (Expect.Absolute 0.01) 0.0 value

            , test "ramps gain linearly to future time (invocation only)" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 0.1) <| \gainNode ->
                            expectOk "rampGainLinear" (AudioFFI.rampGainLinear gainNode 1.0 2.0) <| \_ ->
                                Expect.pass
            ]

        , describe "rampGainExponential"
            [ test "ramps gain exponentially to target (future time)" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                            expectOk "rampGainExponential" (AudioFFI.rampGainExponential gainNode 0.01 1.0) <| \_ ->
                                Expect.pass

            , test "exponential ramp to zero returns Err" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                            case AudioFFI.rampGainExponential gainNode 0.0 1.0 of
                                Ok _ ->
                                    Expect.fail "expected Err for exponential ramp to 0"

                                Err _ ->
                                    Expect.pass
            ]
        ]


-- ============================================================================
-- GAIN PARAM TESTS
-- ============================================================================


gainParamTests : Test
gainParamTests =
    describe "gain AudioParam"
        [ describe "getGainNodeGainParam"
            [ test "returns param with correct value" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gainNode ->
                            let
                                param = AudioFFI.getGainNodeGainParam gainNode
                                value = AudioFFI.getAudioParamValue param
                            in
                            Expect.within (Expect.Absolute 0.01) 1.0 value
            ]

        , describe "getGainParam"
            [ test "returns param with 0.75 value" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 0.75) <| \gainNode ->
                            let
                                param = AudioFFI.getGainParam gainNode
                                value = AudioFFI.getAudioParamValue param
                            in
                            Expect.within (Expect.Absolute 0.01) 0.75 value
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err err -> Expect.fail ("withContext: createAudioContext failed: " ++ errorToString err)


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
