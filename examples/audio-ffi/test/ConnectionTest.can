module ConnectionTest exposing (main, suite)

{-| Unit Tests for Audio Node Connection Functions

Tests all node connection and disconnection functions.

## Functions Tested

- connectNodes
- connectToDestination
- disconnectNode
- connectNodesWithChannels
- disconnectNodeFromDestination
- disconnectNodeOutput
- disconnectNodeFromNodeChannel
- createChannelSplitter
- createChannelMerger
- getContextDestination

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, BrowserTest, describe, test, runTests, inBrowser)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : BrowserTest
main =
    inBrowser
        [ describe "Connection Functions"
            [ basicConnectionTests
            , disconnectionTests
            , channelTests
            ]
        ]


suite : Test
suite =
    describe "Connection Functions"
        [ basicConnectionTests
        , disconnectionTests
        , channelTests
        ]


-- ============================================================================
-- BASIC CONNECTION TESTS
-- ============================================================================


basicConnectionTests : Test
basicConnectionTests =
    describe "basic connections"
        [ describe "connectNodes"
            [ test "connects oscillator to gain" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createOscillator" (AudioFFI.createOscillator ctx 440.0 "sine") <| \osc ->
                            expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gain ->
                                expectOk "connectNodes" (AudioFFI.connectNodes osc gain) <| \_ ->
                                    Expect.pass
            ]

        , describe "connectToDestination"
            [ test "connects gain to destination" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gain ->
                            expectOk "connectToDestination" (AudioFFI.connectToDestination gain ctx) <| \_ ->
                                Expect.pass
            ]

        , describe "getContextDestination"
            [ test "returns destination node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            dest = AudioFFI.getContextDestination ctx
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- DISCONNECTION TESTS
-- ============================================================================


disconnectionTests : Test
disconnectionTests =
    describe "disconnection"
        [ describe "disconnectNode"
            [ test "disconnects gain node" <|
                \_ ->
                    withContext <| \ctx ->
                        expectOk "createGainNode" (AudioFFI.createGainNode ctx 1.0) <| \gain ->
                            let
                                _ = AudioFFI.disconnectNode gain
                            in
                            Expect.pass
            ]
        ]


-- ============================================================================
-- CHANNEL TESTS
-- ============================================================================


channelTests : Test
channelTests =
    describe "channel operations"
        [ describe "createChannelSplitter"
            [ test "creates splitter with 2 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            splitter = AudioFFI.createChannelSplitter ctx 2
                        in
                        Expect.pass

            , test "creates splitter with 6 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            splitter = AudioFFI.createChannelSplitter ctx 6
                        in
                        Expect.pass
            ]

        , describe "createChannelMerger"
            [ test "creates merger with 2 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            merger = AudioFFI.createChannelMerger ctx 2
                        in
                        Expect.pass

            , test "creates merger with 6 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            merger = AudioFFI.createChannelMerger ctx 6
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err err -> Expect.fail ("withContext: createAudioContext failed: " ++ errorToString err)


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err err -> Expect.fail ("withRawContext: createAudioContext failed: " ++ errorToString err)


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


expectOk : String -> Result CapabilityError a -> (a -> Expect.Expectation) -> Expect.Expectation
expectOk label result fn =
    case result of
        Ok value -> fn value
        Err err -> Expect.fail (label ++ ": " ++ errorToString err)


errorToString : CapabilityError -> String
errorToString err =
    case err of
        UserActivationRequired msg -> "UserActivationRequired: " ++ msg
        InitializationRequired msg -> "InitializationRequired: " ++ msg
        FeatureNotAvailable msg -> "FeatureNotAvailable: " ++ msg
        NotSupportedError msg -> "NotSupportedError: " ++ msg
        InvalidStateError msg -> "InvalidStateError: " ++ msg
        RangeError msg -> "RangeError: " ++ msg
        _ -> "Unknown error"
