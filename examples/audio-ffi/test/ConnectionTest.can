module ConnectionTest exposing (main, suite)

{-| Unit Tests for Audio Node Connection Functions

Tests all node connection and disconnection functions.

## Functions Tested

- connectNodes
- connectToDestination
- disconnectNode
- connectNodesWithChannels
- disconnectNodeFromDestination
- disconnectNodeOutput
- disconnectNodeFromNodeChannel
- createChannelSplitter
- createChannelMerger
- getContextDestination

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "Connection Functions"
        [ basicConnectionTests
        , disconnectionTests
        , channelTests
        ]


-- ============================================================================
-- BASIC CONNECTION TESTS
-- ============================================================================


basicConnectionTests : Test
basicConnectionTests =
    describe "basic connections"
        [ describe "connectNodes"
            [ test "connects oscillator to gain" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                case AudioFFI.createGainNode ctx 1.0 of
                                    Ok gain ->
                                        case AudioFFI.connectNodes osc gain of
                                            Ok _ -> Expect.pass
                                            Err _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "connectToDestination"
            [ test "connects gain to destination" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                case AudioFFI.connectToDestination gain ctx of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "getContextDestination"
            [ test "returns destination node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            dest = AudioFFI.getContextDestination ctx
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- DISCONNECTION TESTS
-- ============================================================================


disconnectionTests : Test
disconnectionTests =
    describe "disconnection"
        [ describe "disconnectNode"
            [ test "disconnects gain node" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                let
                                    _ = AudioFFI.disconnectNode gain
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- CHANNEL TESTS
-- ============================================================================


channelTests : Test
channelTests =
    describe "channel operations"
        [ describe "createChannelSplitter"
            [ test "creates splitter with 2 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            splitter = AudioFFI.createChannelSplitter ctx 2
                        in
                        Expect.pass

            , test "creates splitter with 6 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            splitter = AudioFFI.createChannelSplitter ctx 6
                        in
                        Expect.pass
            ]

        , describe "createChannelMerger"
            [ test "creates merger with 2 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            merger = AudioFFI.createChannelMerger ctx 2
                        in
                        Expect.pass

            , test "creates merger with 6 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            merger = AudioFFI.createChannelMerger ctx 6
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err _ -> Expect.pass


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err _ -> Expect.pass


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx
