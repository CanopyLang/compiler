module ConnectionTest exposing (main, suite)

{-| Unit Tests for Audio Node Connection Functions

Tests all node connection and disconnection functions.

## Functions Tested

- connectNodes
- connectToDestination
- disconnectNode
- connectNodesWithChannels
- disconnectNodeFromDestination
- disconnectNodeOutput
- disconnectNodeFromNodeChannel
- createChannelSplitter
- createChannelMerger
- getNodeChannelCount
- setNodeChannelCount
- getNodeChannelCountMode
- setNodeChannelCountMode
- getNodeChannelInterpretation
- setNodeChannelInterpretation
- getNodeNumberOfInputs
- getNodeNumberOfOutputs
- getNodeContext
- getContextDestination

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "Connection Functions"
        [ basicConnectionTests
        , disconnectionTests
        , channelTests
        , nodePropertyTests
        ]


-- ============================================================================
-- BASIC CONNECTION TESTS
-- ============================================================================


basicConnectionTests : Test
basicConnectionTests =
    describe "basic connections"
        [ describe "connectNodes"
            [ test "connects oscillator to gain" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createOscillator ctx 440.0 "sine" of
                            Ok osc ->
                                case AudioFFI.createGainNode ctx 1.0 of
                                    Ok gain ->
                                        case AudioFFI.connectNodes osc gain of
                                            Ok _ -> Expect.pass
                                            Err _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "connectToDestination"
            [ test "connects gain to destination" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                case AudioFFI.connectToDestination gain ctx of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "getContextDestination"
            [ test "returns destination node" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            dest = AudioFFI.getContextDestination ctx
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- DISCONNECTION TESTS
-- ============================================================================


disconnectionTests : Test
disconnectionTests =
    describe "disconnection"
        [ describe "disconnectNode"
            [ test "disconnects gain node" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                let
                                    _ = AudioFFI.disconnectNode gain
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- CHANNEL TESTS
-- ============================================================================


channelTests : Test
channelTests =
    describe "channel operations"
        [ describe "createChannelSplitter"
            [ test "creates splitter with 2 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            splitter = AudioFFI.createChannelSplitter ctx 2
                        in
                        Expect.pass

            , test "creates splitter with 6 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            splitter = AudioFFI.createChannelSplitter ctx 6
                        in
                        Expect.pass
            ]

        , describe "createChannelMerger"
            [ test "creates merger with 2 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            merger = AudioFFI.createChannelMerger ctx 2
                        in
                        Expect.pass

            , test "creates merger with 6 channels" <|
                \_ ->
                    withRawContext <| \ctx ->
                        let
                            merger = AudioFFI.createChannelMerger ctx 6
                        in
                        Expect.pass
            ]
        ]


-- ============================================================================
-- NODE PROPERTY TESTS
-- ============================================================================


nodePropertyTests : Test
nodePropertyTests =
    describe "node properties"
        [ describe "getNodeNumberOfInputs"
            [ test "returns input count" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                let
                                    inputs = AudioFFI.getNodeNumberOfInputs (toAudioNode gain)
                                in
                                Expect.true "should have at least 1 input" (inputs >= 1)
                            Err _ -> Expect.pass
            ]

        , describe "getNodeNumberOfOutputs"
            [ test "returns output count" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                let
                                    outputs = AudioFFI.getNodeNumberOfOutputs (toAudioNode gain)
                                in
                                Expect.true "should have at least 1 output" (outputs >= 1)
                            Err _ -> Expect.pass
            ]

        , describe "getNodeChannelCount"
            [ test "returns channel count" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                let
                                    channels = AudioFFI.getNodeChannelCount (toAudioNode gain)
                                in
                                Expect.true "should have valid channel count" (channels > 0)
                            Err _ -> Expect.pass
            ]

        , describe "getNodeChannelCountMode"
            [ test "returns channel count mode" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                let
                                    mode = AudioFFI.getNodeChannelCountMode (toAudioNode gain)
                                in
                                Expect.true "should be valid mode"
                                    (mode == "max" || mode == "clamped-max" || mode == "explicit")
                            Err _ -> Expect.pass
            ]

        , describe "getNodeChannelInterpretation"
            [ test "returns channel interpretation" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                let
                                    interp = AudioFFI.getNodeChannelInterpretation (toAudioNode gain)
                                in
                                Expect.true "should be valid interpretation"
                                    (interp == "speakers" || interp == "discrete")
                            Err _ -> Expect.pass
            ]

        , describe "setNodeChannelCount"
            [ test "sets channel count" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                case AudioFFI.setNodeChannelCount (toAudioNode gain) 2 of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setNodeChannelCountMode"
            [ test "sets channel count mode" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                case AudioFFI.setNodeChannelCountMode (toAudioNode gain) "explicit" of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "setNodeChannelInterpretation"
            [ test "sets channel interpretation" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gain ->
                                case AudioFFI.setNodeChannelInterpretation (toAudioNode gain) "speakers" of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err _ -> Expect.pass


withRawContext : (AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withRawContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn (extractContext ctx)
        Err _ -> Expect.pass


extractContext : Initialized AudioFFI.AudioContext -> AudioFFI.AudioContext
extractContext initialized =
    case initialized of
        Fresh ctx -> ctx
        Running ctx -> ctx


-- Note: These type coercions would need proper FFI support
-- For now, we assume GainNode can be treated as AudioNode
toAudioNode : AudioFFI.GainNode -> AudioFFI.AudioNode
toAudioNode gain =
    -- In a real implementation, this would use proper type coercion
    -- For testing purposes, we assume the FFI handles this
    unsafeCoerce gain


unsafeCoerce : a -> b
unsafeCoerce =
    -- This is a placeholder - in real code, the FFI would handle this
    -- JavaScript doesn't have these type restrictions
    nativeCoerce


nativeCoerce : a -> b
nativeCoerce _ =
    -- Placeholder for native coercion
    Debug.todo "Native coercion needed"
