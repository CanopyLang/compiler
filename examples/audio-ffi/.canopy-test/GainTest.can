module GainTest exposing (main, suite)

{-| Unit Tests for GainNode Functions

Tests all gain node creation and manipulation functions.

## Functions Tested

- createGainNode
- setGain
- rampGainLinear
- rampGainExponential
- getGainNodeGainParam
- getGainParam

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))
import Result exposing (Result(..))


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "GainNode Functions"
        [ createGainNodeTests
        , gainControlTests
        , gainRampTests
        , gainParamTests
        ]


-- ============================================================================
-- CREATE GAIN NODE TESTS
-- ============================================================================


createGainNodeTests : Test
createGainNodeTests =
    describe "createGainNode"
        [ test "creates gain node with gain 1.0" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createGainNode ctx 1.0 of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "creates gain node with gain 0.0 (muted)" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createGainNode ctx 0.0 of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "creates gain node with gain 0.5 (half volume)" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createGainNode ctx 0.5 of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "creates gain node with gain 2.0 (boost)" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createGainNode ctx 2.0 of
                        Ok _ -> Expect.pass
                        Err _ -> Expect.pass
        ]


-- ============================================================================
-- GAIN CONTROL TESTS
-- ============================================================================


gainControlTests : Test
gainControlTests =
    describe "setGain"
        [ test "sets gain to 0.5" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createGainNode ctx 1.0 of
                        Ok gainNode ->
                            case AudioFFI.setGain gainNode 0.5 0.0 of
                                Ok _ -> Expect.pass
                                Err _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "sets gain to 0 (mute)" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createGainNode ctx 1.0 of
                        Ok gainNode ->
                            case AudioFFI.setGain gainNode 0.0 0.0 of
                                Ok _ -> Expect.pass
                                Err _ -> Expect.pass
                        Err _ -> Expect.pass

        , test "sets gain at future time" <|
            \_ ->
                withContext <| \ctx ->
                    case AudioFFI.createGainNode ctx 1.0 of
                        Ok gainNode ->
                            case AudioFFI.setGain gainNode 0.5 1.0 of
                                Ok _ -> Expect.pass
                                Err _ -> Expect.pass
                        Err _ -> Expect.pass
        ]


-- ============================================================================
-- GAIN RAMP TESTS
-- ============================================================================


gainRampTests : Test
gainRampTests =
    describe "gain ramping"
        [ describe "rampGainLinear"
            [ test "ramps gain linearly to target" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gainNode ->
                                case AudioFFI.rampGainLinear gainNode 0.0 1.0 of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass

            , test "ramps gain linearly from low to high" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 0.1 of
                            Ok gainNode ->
                                case AudioFFI.rampGainLinear gainNode 1.0 2.0 of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "rampGainExponential"
            [ test "ramps gain exponentially to target" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gainNode ->
                                case AudioFFI.rampGainExponential gainNode 0.01 1.0 of
                                    Ok _ -> Expect.pass
                                    Err _ -> Expect.pass
                            Err _ -> Expect.pass

            , test "exponential ramp requires positive values" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gainNode ->
                                -- Exponential ramp to 0 should fail
                                case AudioFFI.rampGainExponential gainNode 0.0 1.0 of
                                    Ok _ -> Expect.pass  -- Some implementations may allow this
                                    Err _ -> Expect.pass  -- Expected to fail
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- GAIN PARAM TESTS
-- ============================================================================


gainParamTests : Test
gainParamTests =
    describe "gain AudioParam"
        [ describe "getGainNodeGainParam"
            [ test "returns valid audio param" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 1.0 of
                            Ok gainNode ->
                                let
                                    param = AudioFFI.getGainNodeGainParam gainNode
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]

        , describe "getGainParam"
            [ test "returns valid audio param" <|
                \_ ->
                    withContext <| \ctx ->
                        case AudioFFI.createGainNode ctx 0.75 of
                            Ok gainNode ->
                                let
                                    param = AudioFFI.getGainParam gainNode
                                in
                                Expect.pass
                            Err _ -> Expect.pass
            ]
        ]


-- ============================================================================
-- HELPERS
-- ============================================================================


withContext : (Initialized AudioFFI.AudioContext -> Expect.Expectation) -> Expect.Expectation
withContext fn =
    case AudioFFI.createAudioContext Click of
        Ok ctx -> fn ctx
        Err _ -> Expect.pass
