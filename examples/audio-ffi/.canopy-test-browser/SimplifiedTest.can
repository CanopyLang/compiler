module SimplifiedTest exposing (main, suite)

{-| Unit Tests for Simplified Audio Interface

Tests the string-based simplified interface for quick prototyping.

## Functions Tested

- checkWebAudioSupport
- simpleTest
- createAudioContextSimplified
- playToneSimplified
- stopAudioSimplified
- updateFrequency
- updateVolume
- updateWaveform

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import AudioFFI


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "Simplified Interface Functions"
        [ webAudioSupportTests
        , simpleTestTests
        , simplifiedAudioTests
        , updateFunctionTests
        ]


-- ============================================================================
-- WEB AUDIO SUPPORT TESTS
-- ============================================================================


webAudioSupportTests : Test
webAudioSupportTests =
    describe "checkWebAudioSupport"
        [ test "returns support status string" <|
            \_ ->
                let
                    result = AudioFFI.checkWebAudioSupport ()
                in
                Expect.true "should return non-empty string" (String.length result > 0)

        , test "returns valid support status" <|
            \_ ->
                let
                    result = AudioFFI.checkWebAudioSupport ()
                in
                -- Should contain either "supported" or "not supported" type message
                Expect.true "should contain support info" (True)
        ]


-- ============================================================================
-- SIMPLE TEST TESTS
-- ============================================================================


simpleTestTests : Test
simpleTestTests =
    describe "simpleTest"
        [ test "returns doubled value for positive input" <|
            \_ ->
                let
                    result = AudioFFI.simpleTest 21
                in
                Expect.equal 42 result

        , test "returns doubled value for zero" <|
            \_ ->
                let
                    result = AudioFFI.simpleTest 0
                in
                Expect.equal 0 result

        , test "returns doubled value for negative" <|
            \_ ->
                let
                    result = AudioFFI.simpleTest (-5)
                in
                Expect.equal (-10) result

        , test "returns doubled value for large number" <|
            \_ ->
                let
                    result = AudioFFI.simpleTest 1000
                in
                Expect.equal 2000 result
        ]


-- ============================================================================
-- SIMPLIFIED AUDIO TESTS
-- ============================================================================


simplifiedAudioTests : Test
simplifiedAudioTests =
    describe "simplified audio functions"
        [ describe "createAudioContextSimplified"
            [ test "returns status string" <|
                \_ ->
                    let
                        result = AudioFFI.createAudioContextSimplified ()
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)
            ]

        , describe "playToneSimplified"
            [ test "returns status for 440Hz sine" <|
                \_ ->
                    let
                        result = AudioFFI.playToneSimplified 440.0 "sine"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "returns status for 880Hz square" <|
                \_ ->
                    let
                        result = AudioFFI.playToneSimplified 880.0 "square"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "returns status for low frequency" <|
                \_ ->
                    let
                        result = AudioFFI.playToneSimplified 100.0 "sawtooth"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "returns status for high frequency" <|
                \_ ->
                    let
                        result = AudioFFI.playToneSimplified 2000.0 "triangle"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)
            ]

        , describe "stopAudioSimplified"
            [ test "returns status string" <|
                \_ ->
                    let
                        result = AudioFFI.stopAudioSimplified ()
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)
            ]
        ]


-- ============================================================================
-- UPDATE FUNCTION TESTS
-- ============================================================================


updateFunctionTests : Test
updateFunctionTests =
    describe "update functions"
        [ describe "updateFrequency"
            [ test "updates to 440Hz" <|
                \_ ->
                    let
                        result = AudioFFI.updateFrequency 440.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to 880Hz" <|
                \_ ->
                    let
                        result = AudioFFI.updateFrequency 880.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to low frequency" <|
                \_ ->
                    let
                        result = AudioFFI.updateFrequency 100.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to high frequency" <|
                \_ ->
                    let
                        result = AudioFFI.updateFrequency 5000.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)
            ]

        , describe "updateVolume"
            [ test "updates to full volume" <|
                \_ ->
                    let
                        result = AudioFFI.updateVolume 100.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to half volume" <|
                \_ ->
                    let
                        result = AudioFFI.updateVolume 50.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to muted" <|
                \_ ->
                    let
                        result = AudioFFI.updateVolume 0.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to quarter volume" <|
                \_ ->
                    let
                        result = AudioFFI.updateVolume 25.0
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)
            ]

        , describe "updateWaveform"
            [ test "updates to sine" <|
                \_ ->
                    let
                        result = AudioFFI.updateWaveform "sine"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to square" <|
                \_ ->
                    let
                        result = AudioFFI.updateWaveform "square"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to sawtooth" <|
                \_ ->
                    let
                        result = AudioFFI.updateWaveform "sawtooth"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)

            , test "updates to triangle" <|
                \_ ->
                    let
                        result = AudioFFI.updateWaveform "triangle"
                    in
                    Expect.true "should return non-empty string" (String.length result > 0)
            ]
        ]
