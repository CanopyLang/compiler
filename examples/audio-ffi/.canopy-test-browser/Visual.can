module Visual exposing
    ( test
    , snapshot
    , snapshotElement
    , matchesBaseline
    , matchesBaselineWithThreshold
    , forEachViewport
    , Viewport
    , mobile
    , tablet
    , desktop
    , custom
    , diff
    , updateBaseline
    )

{-| Visual regression testing with screenshot comparison.

## Quick Start

    import Visual

    suite : Test
    suite =
        Visual.test "homepage looks correct" <|
            \browser ->
                browser
                    |> Page.goto "http://localhost:3000"
                    |> Visual.snapshot "homepage"
                    |> Visual.matchesBaseline

## Element Screenshots

    Visual.test "button styling" <|
        \browser ->
            browser
                |> Page.goto "http://localhost:3000"
                |> Visual.snapshotElement "#primary-btn" "primary-button"
                |> Visual.matchesBaseline

## Responsive Testing

    Visual.test "responsive design" <|
        \browser ->
            Visual.forEachViewport
                [ Visual.mobile
                , Visual.tablet
                , Visual.desktop
                ]
                (\viewport name ->
                    browser
                        |> Page.setViewport viewport.width viewport.height
                        |> Page.goto "http://localhost:3000"
                        |> Visual.snapshot ("homepage-" ++ name)
                        |> Visual.matchesBaseline
                )

-}

import Browser exposing (Browser)
import Test exposing (Test)
import Expect exposing (Expectation)


{-| A viewport configuration for responsive testing.
-}
type alias Viewport =
    { width : Int
    , height : Int
    , name : String
    }


{-| Result of taking a snapshot.
-}
type SnapshotResult
    = SnapshotResult
        { name : String
        , path : String
        , width : Int
        , height : Int
        }


{-| Result of comparing snapshots.
-}
type ComparisonResult
    = Match
    | Mismatch
        { diffPath : String
        , diffPixels : Int
        , diffPercentage : Float
        }
    | NoBaseline


{-| Create a visual regression test.
-}
test : String -> (Browser -> Expectation) -> Test
test description testFn =
    Browser.test description testFn


{-| Take a full-page screenshot.

Screenshots are saved to `test-output/snapshots/{name}.png`

    browser
        |> Page.goto "http://localhost:3000"
        |> Visual.snapshot "homepage"

-}
snapshot : String -> Browser -> SnapshotResult
snapshot name browser =
    -- Kernel: await page.screenshot({ path, fullPage: true })
    SnapshotResult
        { name = name
        , path = "test-output/snapshots/" ++ name ++ ".png"
        , width = 0
        , height = 0
        }


{-| Take a screenshot of a specific element.

    browser
        |> Visual.snapshotElement "#hero-section" "hero"

-}
snapshotElement : String -> String -> Browser -> SnapshotResult
snapshotElement selector name browser =
    -- Kernel: await page.locator(selector).screenshot({ path })
    SnapshotResult
        { name = name
        , path = "test-output/snapshots/" ++ name ++ ".png"
        , width = 0
        , height = 0
        }


{-| Assert that a snapshot matches the baseline image.

On first run, creates the baseline. On subsequent runs, compares.

    browser
        |> Visual.snapshot "homepage"
        |> Visual.matchesBaseline

-}
matchesBaseline : SnapshotResult -> Expectation
matchesBaseline result =
    matchesBaselineWithThreshold 0.01 result


{-| Assert snapshot matches baseline within a threshold.

Threshold is the percentage of pixels that can differ (0.0 to 1.0).

    browser
        |> Visual.snapshot "homepage"
        |> Visual.matchesBaselineWithThreshold 0.05  -- Allow 5% difference

-}
matchesBaselineWithThreshold : Float -> SnapshotResult -> Expectation
matchesBaselineWithThreshold threshold (SnapshotResult result) =
    -- Kernel: compare with pixelmatch
    let
        comparison =
            compareWithBaseline result.name result.path threshold
    in
    case comparison of
        Match ->
            Expect.pass

        Mismatch info ->
            Expect.fail
                ("Visual mismatch for '" ++ result.name ++ "':\n" ++
                 "  Diff: " ++ String.fromFloat (info.diffPercentage * 100) ++ "% (" ++
                 String.fromInt info.diffPixels ++ " pixels)\n" ++
                 "  See: " ++ info.diffPath)

        NoBaseline ->
            Expect.pass  -- First run creates baseline


compareWithBaseline : String -> String -> Float -> ComparisonResult
compareWithBaseline name path threshold =
    -- Kernel implementation
    Match


{-| Run tests across multiple viewports.

    Visual.forEachViewport
        [ Visual.mobile, Visual.tablet, Visual.desktop ]
        (\viewport name ->
            browser
                |> Page.setViewport viewport.width viewport.height
                |> Visual.snapshot ("page-" ++ name)
                |> Visual.matchesBaseline
        )

-}
forEachViewport : List Viewport -> (Viewport -> String -> Expectation) -> Expectation
forEachViewport viewports testFn =
    let
        results =
            List.map (\vp -> testFn vp vp.name) viewports

        failures =
            List.filter isFailure results
    in
    case failures of
        [] ->
            Expect.pass

        first :: _ ->
            first


isFailure : Expectation -> Bool
isFailure exp =
    case exp of
        Expect.Pass ->
            False

        Expect.Fail _ ->
            True


{-| Mobile viewport (375x667 - iPhone SE).
-}
mobile : Viewport
mobile =
    { width = 375, height = 667, name = "mobile" }


{-| Tablet viewport (768x1024 - iPad).
-}
tablet : Viewport
tablet =
    { width = 768, height = 1024, name = "tablet" }


{-| Desktop viewport (1920x1080).
-}
desktop : Viewport
desktop =
    { width = 1920, height = 1080, name = "desktop" }


{-| Custom viewport.

    Visual.custom 1440 900 "laptop"

-}
custom : Int -> Int -> String -> Viewport
custom width height name =
    { width = width, height = height, name = name }


{-| Get the diff image path for a snapshot comparison.
-}
diff : SnapshotResult -> String
diff (SnapshotResult result) =
    "test-output/diffs/" ++ result.name ++ "-diff.png"


{-| Update the baseline image for a snapshot.

Run with `canopy test --update-snapshots` to update all baselines.

-}
updateBaseline : SnapshotResult -> SnapshotResult
updateBaseline (SnapshotResult result) =
    -- Kernel: copy current to baseline
    SnapshotResult result
