module BrowserTestMain exposing (main)

import Html exposing (Html, pre, text, div, node)
import Html.Attributes exposing (attribute)
import Test exposing (Test, runTests)
import FilterTest exposing (suite)
import BufferTest exposing (suite)
import ConnectionTest exposing (suite)
import AudioContextTest exposing (suite)
import AnalyserTest exposing (suite)
import OscillatorTest exposing (suite)
import SimplifiedTest exposing (suite)
import EffectsTest exposing (suite)
import SpatialTest exposing (suite)
import GainTest exposing (suite)
import AudioParamTest exposing (suite)


main : Html msg
main =
    let
        allSuites =
            [ FilterTest.suite
            , BufferTest.suite
            , ConnectionTest.suite
            , AudioContextTest.suite
            , AnalyserTest.suite
            , OscillatorTest.suite
            , SimplifiedTest.suite
            , EffectsTest.suite
            , SpatialTest.suite
            , GainTest.suite
            , AudioParamTest.suite
            ]

        report =
            runTests allSuites
    in
    div
        [ attribute "data-test-complete" "true" ]
        [ pre [] [ text report ]
        , node "script" [] [ text (logResultsScript report) ]
        ]


logResultsScript : String -> String
logResultsScript report =
    "console.log('CANOPY_TEST_RESULTS_START');" ++
    "console.log(" ++ escapeForJs report ++ ");" ++
    "console.log('CANOPY_TEST_RESULTS_END');"


escapeForJs : String -> String
escapeForJs str =
    "'" ++ String.replace "\\" "\\\\" (String.replace "'" "\\'" (String.replace "\n" "\\n" str)) ++ "'"
