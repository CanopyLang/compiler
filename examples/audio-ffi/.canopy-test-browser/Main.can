module Main exposing (main)

{-| Complete Interactive Audio FFI Demonstration

This application demonstrates the complete Canopy Foreign Function Interface (FFI) system
for Web Audio API integration, showcasing both:

- **Type-safe Result-based interface**: Production-ready with proper capability handling
- **Simplified string interface**: Easy-to-use functions for quick prototyping

## 🎵 COMPLETE FEATURES DEMONSTRATED:

### FFI System Validation
- Basic function binding and type conversion testing
- Web Audio API availability detection

### Type-Safe Audio Operations (Result-based)
- User activation requirement enforcement
- AudioContext lifecycle management with Initialized wrapper
- Type-safe audio node creation (OscillatorNode, GainNode)
- Audio graph connection management
- Precise timing control with error handling
- Capability-based security constraints

### Simplified Audio Interface
- Real-time audio synthesis with status reporting
- Interactive frequency, volume, and waveform controls
- Live audio parameter updates during playback

### Interactive User Interface
- Professional UI with real-time controls
- Comprehensive status reporting and error display
- Multiple demo modes showcasing different aspects

## 🏗️ ARCHITECTURE DEMONSTRATION:

```
User Interaction → Elm Architecture → AudioFFI.can → external/audio.js → Web Audio API
        ↑                ↑                ↑                ↑
   UI Events         Result          Capabilities      Native Browser
```

This proves Canopy can build production-ready, type-safe web applications with complex browser APIs.

@docs main
-}

import Browser
import Html exposing (Html)
import Html.Attributes as Attr
import Html.Events as Events
import Result exposing (Result(..))
import AudioFFI
import Capability exposing (UserActivated(..), Initialized(..), CapabilityError(..))

-- ============================================================================
-- MODEL (Application State)
-- ============================================================================

type alias Model =
    { -- Audio State Management
      audioContext : Maybe (Initialized AudioFFI.AudioContext)
    , currentOscillator : Maybe AudioFFI.OscillatorNode
    , currentGainNode : Maybe AudioFFI.GainNode
    , isPlaying : Bool

    -- Real-time Controls
    , frequency : Float
    , volume : Float
    , waveform : String

    -- Status and Error Reporting
    , status : String
    , lastError : Maybe String
    , operationLog : List String

    -- UI State
    , demoMode : DemoMode
    , showAdvanced : Bool
    }

type DemoMode
    = SimplifiedInterface    -- Uses simplified String-based functions
    | TypeSafeInterface     -- Uses proper Task-based functions
    | ComparisonMode        -- Shows both side-by-side

initialModel : Model
initialModel =
    { audioContext = Nothing
    , currentOscillator = Nothing
    , currentGainNode = Nothing
    , isPlaying = False

    , frequency = 440.0
    , volume = 30.0
    , waveform = "sine"

    , status = "Ready - Click 'Initialize Audio' to begin"
    , lastError = Nothing
    , operationLog = []

    , demoMode = SimplifiedInterface
    , showAdvanced = False
    }

-- ============================================================================
-- MESSAGES (User Actions and System Events)
-- ============================================================================

type Msg
    = -- User Interface Actions
      SetDemoMode DemoMode
    | ToggleAdvancedMode
    | ClearLog

    -- Audio Control Actions (Simplified Interface)
    | InitializeAudioSimple
    | PlayAudioSimple
    | StopAudioSimple
    | SetFrequency String
    | SetVolume String
    | SetWaveform String

    -- Audio Control Actions (Type-Safe Interface)
    | InitializeAudioTypeSafe
    | CreateAudioNodesTypeSafe
    | PlayAudioTypeSafe
    | StopAudioTypeSafe

-- ============================================================================
-- UPDATE (State Management and Side Effects)
-- ============================================================================

update : Msg -> Model -> ( Model, Cmd Msg )
update msg model =
    case msg of
        -- UI State Changes
        SetDemoMode mode ->
            ( { model | demoMode = mode, status = "Demo mode changed to " ++ demoModeString mode }
            , Cmd.none
            )

        ToggleAdvancedMode ->
            ( { model | showAdvanced = not model.showAdvanced }
            , Cmd.none
            )

        ClearLog ->
            ( { model | operationLog = [], lastError = Nothing }
            , Cmd.none
            )

        -- Simplified Interface Operations
        InitializeAudioSimple ->
            let
                result = AudioFFI.createAudioContextSimplified ()
            in
            ( { model
              | status = result
              , operationLog = result :: model.operationLog
              }
            , Cmd.none
            )

        PlayAudioSimple ->
            let
                result = AudioFFI.playToneSimplified model.frequency model.waveform
            in
            ( { model
              | status = result
              , isPlaying = True
              , operationLog = result :: model.operationLog
              }
            , Cmd.none
            )

        StopAudioSimple ->
            let
                result = AudioFFI.stopAudioSimplified ()
            in
            ( { model
              | status = result
              , isPlaying = False
              , operationLog = result :: model.operationLog
              }
            , Cmd.none
            )

        SetFrequency freqString ->
            case String.toFloat freqString of
                Just freq ->
                    let
                        updateResult = if model.isPlaying then AudioFFI.updateFrequency freq else "Frequency set to " ++ String.fromFloat freq ++ " Hz"
                    in
                    ( { model
                      | frequency = freq
                      , status = updateResult
                      , operationLog = updateResult :: model.operationLog
                      }
                    , Cmd.none
                    )
                Nothing ->
                    ( model, Cmd.none )

        SetVolume volString ->
            case String.toFloat volString of
                Just vol ->
                    let
                        updateResult = if model.isPlaying then AudioFFI.updateVolume vol else "Volume set to " ++ String.fromFloat vol ++ "%"
                    in
                    ( { model
                      | volume = vol
                      , status = updateResult
                      , operationLog = updateResult :: model.operationLog
                      }
                    , Cmd.none
                    )
                Nothing ->
                    ( model, Cmd.none )

        SetWaveform waveform ->
            let
                updateResult = if model.isPlaying then AudioFFI.updateWaveform waveform else "Waveform set to " ++ waveform
            in
            ( { model
              | waveform = waveform
              , status = updateResult
              , operationLog = updateResult :: model.operationLog
              }
            , Cmd.none
            )

        -- Type-Safe Interface Operations
        InitializeAudioTypeSafe ->
            case AudioFFI.createAudioContext Click of
                Ok initializedContext ->
                    ( { model
                      | audioContext = Just initializedContext
                      , status = "✅ AudioContext created successfully"
                      , operationLog = "AudioContext initialized" :: model.operationLog
                      , lastError = Nothing
                      }
                    , Cmd.none
                    )
                Err error ->
                    ( { model
                      | status = "❌ AudioContext creation failed: " ++ capabilityErrorString error
                      , lastError = Just (capabilityErrorString error)
                      , operationLog = ("AudioContext error: " ++ capabilityErrorString error) :: model.operationLog
                      }
                    , Cmd.none
                    )

        CreateAudioNodesTypeSafe ->
            case model.audioContext of
                Just initializedContext ->
                    case (AudioFFI.createOscillator initializedContext model.frequency model.waveform, AudioFFI.createGainNode initializedContext (model.volume / 100.0)) of
                        (Ok oscillator, Ok gainNode) ->
                            case (AudioFFI.connectNodes oscillator gainNode, AudioFFI.connectToDestination gainNode initializedContext) of
                                (Ok _, Ok _) ->
                                    ( { model
                                      | currentOscillator = Just oscillator
                                      , currentGainNode = Just gainNode
                                      , status = "✅ Audio nodes created and connected - ready to play"
                                      , operationLog = "Audio graph connected" :: "GainNode created" :: "OscillatorNode created" :: model.operationLog
                                      , lastError = Nothing
                                      }
                                    , Cmd.none
                                    )
                                (Err error, _) ->
                                    ( { model
                                      | status = "❌ Node connection failed: " ++ capabilityErrorString error
                                      , lastError = Just (capabilityErrorString error)
                                      }
                                    , Cmd.none
                                    )
                                (_, Err error) ->
                                    ( { model
                                      | status = "❌ Destination connection failed: " ++ capabilityErrorString error
                                      , lastError = Just (capabilityErrorString error)
                                      }
                                    , Cmd.none
                                    )
                        (Err error, _) ->
                            ( { model
                              | status = "❌ Oscillator creation failed: " ++ capabilityErrorString error
                              , lastError = Just (capabilityErrorString error)
                              }
                            , Cmd.none
                            )
                        (_, Err error) ->
                            ( { model
                              | status = "❌ Gain node creation failed: " ++ capabilityErrorString error
                              , lastError = Just (capabilityErrorString error)
                              }
                            , Cmd.none
                            )
                Nothing ->
                    ( { model | status = "Error: No AudioContext available", lastError = Just "AudioContext must be created first" }
                    , Cmd.none
                    )

        PlayAudioTypeSafe ->
            case (model.currentOscillator, model.audioContext) of
                (Just oscillator, Just audioContext) ->
                    let
                        currentTime = AudioFFI.getCurrentTime audioContext
                    in
                    case AudioFFI.startOscillator oscillator currentTime of
                        Ok _ ->
                            ( { model
                              | status = "🔊 Audio playing with type-safe interface!"
                              , isPlaying = True
                              , operationLog = "Audio playback started" :: model.operationLog
                              , lastError = Nothing
                              }
                            , Cmd.none
                            )
                        Err error ->
                            ( { model
                              | status = "❌ Audio start failed: " ++ capabilityErrorString error
                              , lastError = Just (capabilityErrorString error)
                              }
                            , Cmd.none
                            )
                _ ->
                    ( { model | status = "Error: Audio nodes not ready", lastError = Just "Create audio nodes first" }
                    , Cmd.none
                    )

        StopAudioTypeSafe ->
            case (model.currentOscillator, model.audioContext) of
                (Just oscillator, Just audioContext) ->
                    let
                        currentTime = AudioFFI.getCurrentTime audioContext
                    in
                    case AudioFFI.stopOscillator oscillator currentTime of
                        Ok _ ->
                            ( { model
                              | status = "⏹️ Audio stopped"
                              , isPlaying = False
                              , currentOscillator = Nothing
                              , operationLog = "Audio playback stopped" :: model.operationLog
                              , lastError = Nothing
                              }
                            , Cmd.none
                            )
                        Err error ->
                            ( { model
                              | status = "❌ Audio stop failed: " ++ capabilityErrorString error
                              , lastError = Just (capabilityErrorString error)
                              }
                            , Cmd.none
                            )
                _ ->
                    ( { model | status = "No audio to stop" }
                    , Cmd.none
                    )


-- ============================================================================
-- VIEW (User Interface)
-- ============================================================================

view : Model -> Html Msg
view model =
    Html.div
        [ Attr.style "padding" "20px"
        , Attr.style "font-family" "system-ui, -apple-system, sans-serif"
        , Attr.style "max-width" "1200px"
        , Attr.style "margin" "0 auto"
        , Attr.style "background" "linear-gradient(135deg, #667eea 0%, #764ba2 100%)"
        , Attr.style "min-height" "100vh"
        , Attr.style "color" "white"
        ]
        [ -- Header
          Html.header []
            [ Html.h1
                [ Attr.style "text-align" "center"
                , Attr.style "margin-bottom" "30px"
                , Attr.style "text-shadow" "2px 2px 4px rgba(0,0,0,0.3)"
                ]
                [ Html.text "🎵 Complete Audio FFI System - Interactive Demo" ]
            , Html.p
                [ Attr.style "text-align" "center"
                , Attr.style "font-size" "18px"
                , Attr.style "margin-bottom" "30px"
                , Attr.style "opacity" "0.9"
                ]
                [ Html.text "Demonstrates both type-safe Result-based and simplified string-based FFI interfaces" ]
            ]

        -- Demo Mode Selection
        , demoModeSelector model

        -- FFI Validation Section
        , ffiValidationSection model

        -- Main Demo Interface
        , case model.demoMode of
            SimplifiedInterface -> simplifiedInterfaceDemo model
            TypeSafeInterface -> typeSafeInterfaceDemo model
            ComparisonMode -> comparisonModeDemo model

        -- Status and Logging
        , statusSection model

        -- Advanced Information (collapsible)
        , if model.showAdvanced then advancedInfoSection model else Html.text ""
        ]

demoModeSelector : Model -> Html Msg
demoModeSelector model =
    Html.div
        [ Attr.style "background" "rgba(255,255,255,0.1)"
        , Attr.style "padding" "20px"
        , Attr.style "border-radius" "10px"
        , Attr.style "margin-bottom" "20px"
        , Attr.style "text-align" "center"
        ]
        [ Html.h3 [] [ Html.text "🎛️ Demo Mode Selection" ]
        , Html.div
            [ Attr.style "display" "flex"
            , Attr.style "justify-content" "center"
            , Attr.style "gap" "10px"
            , Attr.style "flex-wrap" "wrap"
            ]
            [ modeButton "Simplified Interface" SimplifiedInterface model.demoMode
            , modeButton "Type-Safe Interface" TypeSafeInterface model.demoMode
            , modeButton "Comparison Mode" ComparisonMode model.demoMode
            ]
        ]

modeButton : String -> DemoMode -> DemoMode -> Html Msg
modeButton label mode currentMode =
    Html.button
        [ Events.onClick (SetDemoMode mode)
        , Attr.style "background" (if mode == currentMode then "#ffd700" else "rgba(255,255,255,0.2)")
        , Attr.style "color" (if mode == currentMode then "#000" else "#fff")
        , Attr.style "border" "2px solid #ffd700"
        , Attr.style "padding" "10px 15px"
        , Attr.style "border-radius" "5px"
        , Attr.style "cursor" "pointer"
        , Attr.style "font-weight" "bold"
        ]
        [ Html.text label ]

ffiValidationSection : Model -> Html Msg
ffiValidationSection model =
    Html.div
        [ Attr.style "background" "rgba(255,255,255,0.1)"
        , Attr.style "padding" "20px"
        , Attr.style "border-radius" "10px"
        , Attr.style "margin-bottom" "20px"
        ]
        [ Html.h3 [] [ Html.text "🔧 FFI System Validation" ]
        , Html.div
            [ Attr.style "display" "grid"
            , Attr.style "grid-template-columns" "1fr 1fr"
            , Attr.style "gap" "15px"
            ]
            [ validationItem "Basic FFI Test" ("simpleTest(42) = " ++ String.fromInt (AudioFFI.simpleTest 42))
            , validationItem "Web Audio Support" (AudioFFI.checkWebAudioSupport ())
            ]
        ]

validationItem : String -> String -> Html Msg
validationItem label result =
    Html.div
        [ Attr.style "background" "rgba(0,0,0,0.2)"
        , Attr.style "padding" "10px"
        , Attr.style "border-radius" "5px"
        ]
        [ Html.strong [] [ Html.text (label ++ ": ") ]
        , Html.span [ Attr.style "color" "#90EE90" ] [ Html.text result ]
        ]

simplifiedInterfaceDemo : Model -> Html Msg
simplifiedInterfaceDemo model =
    Html.div
        [ Attr.style "background" "rgba(255,255,255,0.1)"
        , Attr.style "padding" "25px"
        , Attr.style "border-radius" "10px"
        , Attr.style "margin-bottom" "20px"
        ]
        [ Html.h3 [] [ Html.text "🌊 Simplified String-Based Interface" ]
        , Html.p
            [ Attr.style "margin-bottom" "20px"
            , Attr.style "opacity" "0.9"
            ]
            [ Html.text "Easy-to-use functions that return status strings but still generate real audio." ]

        -- Audio Controls
        , Html.div
            [ Attr.style "display" "flex"
            , Attr.style "justify-content" "center"
            , Attr.style "gap" "10px"
            , Attr.style "margin-bottom" "20px"
            ]
            [ controlButton "🎛️ Initialize Audio" InitializeAudioSimple False
            , controlButton "▶️ Play Audio" PlayAudioSimple False
            , controlButton "⏹️ Stop Audio" StopAudioSimple False
            ]

        -- Real-time Controls
        , audioControlsSection model
        ]

typeSafeInterfaceDemo : Model -> Html Msg
typeSafeInterfaceDemo model =
    Html.div
        [ Attr.style "background" "rgba(255,255,255,0.1)"
        , Attr.style "padding" "25px"
        , Attr.style "border-radius" "10px"
        , Attr.style "margin-bottom" "20px"
        ]
        [ Html.h3 [] [ Html.text "🛡️ Type-Safe Result-Based Interface" ]
        , Html.p
            [ Attr.style "margin-bottom" "20px"
            , Attr.style "opacity" "0.9"
            ]
            [ Html.text "Production-ready interface with proper Result types, capability constraints, and error handling." ]

        -- Step-by-step interface
        , Html.div []
            [ Html.h4 [] [ Html.text "Step 1: Initialize AudioContext (requires user activation)" ]
            , Html.div
                [ Attr.style "margin-bottom" "20px" ]
                [ controlButton "🎛️ Create AudioContext" InitializeAudioTypeSafe (model.audioContext /= Nothing)
                , Html.span
                    [ Attr.style "margin-left" "10px"
                    , Attr.style "opacity" "0.8"
                    ]
                    [ Html.text (if model.audioContext /= Nothing then "✅ Ready" else "⏳ Required") ]
                ]

            , Html.h4 [] [ Html.text "Step 2: Create Audio Nodes" ]
            , Html.div
                [ Attr.style "margin-bottom" "20px" ]
                [ controlButton "🎵 Create Oscillator & Gain" CreateAudioNodesTypeSafe (model.audioContext == Nothing || (model.currentOscillator /= Nothing && model.currentGainNode /= Nothing))
                , Html.span
                    [ Attr.style "margin-left" "10px"
                    , Attr.style "opacity" "0.8"
                    ]
                    [ Html.text (if model.currentOscillator /= Nothing && model.currentGainNode /= Nothing then "✅ Ready" else "⏳ Required") ]
                ]

            , Html.h4 [] [ Html.text "Step 3: Audio Playback Control" ]
            , Html.div []
                [ controlButton "▶️ Start Audio" PlayAudioTypeSafe (model.currentOscillator == Nothing || model.isPlaying)
                , controlButton "⏹️ Stop Audio" StopAudioTypeSafe (not model.isPlaying)
                ]
            ]
        ]

comparisonModeDemo : Model -> Html Msg
comparisonModeDemo model =
    Html.div []
        [ Html.div
            [ Attr.style "display" "grid"
            , Attr.style "grid-template-columns" "1fr 1fr"
            , Attr.style "gap" "20px"
            ]
            [ Html.div
                [ Attr.style "background" "rgba(255,255,255,0.1)"
                , Attr.style "padding" "20px"
                , Attr.style "border-radius" "10px"
                ]
                [ Html.h3 [] [ Html.text "🌊 Simplified Interface" ]
                , Html.p [ Attr.style "font-size" "14px", Attr.style "opacity" "0.8" ]
                    [ Html.text "String-based, easy to use" ]
                , controlButton "Play (Simple)" PlayAudioSimple False
                ]
            , Html.div
                [ Attr.style "background" "rgba(255,255,255,0.1)"
                , Attr.style "padding" "20px"
                , Attr.style "border-radius" "10px"
                ]
                [ Html.h3 [] [ Html.text "🛡️ Type-Safe Interface" ]
                , Html.p [ Attr.style "font-size" "14px", Attr.style "opacity" "0.8" ]
                    [ Html.text "Result-based, production-ready" ]
                , controlButton "Initialize & Play (Safe)" InitializeAudioTypeSafe False
                ]
            ]
        ]

audioControlsSection : Model -> Html Msg
audioControlsSection model =
    Html.div []
        [ Html.h4 [] [ Html.text "🎚️ Real-Time Audio Controls" ]

        -- Frequency Control
        , controlGroup "🌊 Frequency"
            [ Html.div
                [ Attr.style "display" "flex"
                , Attr.style "align-items" "center"
                , Attr.style "gap" "10px"
                ]
                [ Html.input
                    [ Attr.type_ "range"
                    , Attr.min "20"
                    , Attr.max "2000"
                    , Attr.step "10"
                    , Attr.value (String.fromFloat model.frequency)
                    , Events.onInput SetFrequency
                    , sliderStyle
                    ] []
                , Html.span
                    [ Attr.style "min-width" "80px"
                    , Attr.style "font-weight" "bold"
                    , Attr.style "color" "#ffd700"
                    ]
                    [ Html.text (String.fromFloat model.frequency ++ " Hz") ]
                ]
            ]

        -- Volume Control
        , controlGroup "🔊 Volume"
            [ Html.div
                [ Attr.style "display" "flex"
                , Attr.style "align-items" "center"
                , Attr.style "gap" "10px"
                ]
                [ Html.input
                    [ Attr.type_ "range"
                    , Attr.min "0"
                    , Attr.max "100"
                    , Attr.step "5"
                    , Attr.value (String.fromFloat model.volume)
                    , Events.onInput SetVolume
                    , sliderStyle
                    ] []
                , Html.span
                    [ Attr.style "min-width" "50px"
                    , Attr.style "font-weight" "bold"
                    , Attr.style "color" "#ffd700"
                    ]
                    [ Html.text (String.fromFloat model.volume ++ "%") ]
                ]
            ]

        -- Waveform Selection
        , controlGroup "⚡ Waveform"
            [ Html.div
                [ Attr.style "display" "flex"
                , Attr.style "gap" "10px"
                ]
                [ waveformButton "🌊 Sine" "sine" model.waveform
                , waveformButton "⬜ Square" "square" model.waveform
                , waveformButton "🪚 Sawtooth" "sawtooth" model.waveform
                , waveformButton "🔺 Triangle" "triangle" model.waveform
                ]
            ]
        ]

controlGroup : String -> List (Html Msg) -> Html Msg
controlGroup title content =
    Html.div
        [ Attr.style "margin-bottom" "15px" ]
        (Html.h5
            [ Attr.style "margin" "0 0 10px 0"
            , Attr.style "color" "#ffd700"
            ]
            [ Html.text title ] :: content)

waveformButton : String -> String -> String -> Html Msg
waveformButton label waveType currentWave =
    Html.button
        [ Events.onClick (SetWaveform waveType)
        , Attr.style "background" (if currentWave == waveType then "#ffd700" else "rgba(255,255,255,0.2)")
        , Attr.style "color" (if currentWave == waveType then "#000" else "#fff")
        , Attr.style "border" "2px solid #ffd700"
        , Attr.style "padding" "8px 12px"
        , Attr.style "border-radius" "5px"
        , Attr.style "cursor" "pointer"
        , Attr.style "font-size" "12px"
        , Attr.style "font-weight" "bold"
        ]
        [ Html.text label ]

statusSection : Model -> Html Msg
statusSection model =
    Html.div
        [ Attr.style "background" "rgba(0,0,0,0.3)"
        , Attr.style "padding" "20px"
        , Attr.style "border-radius" "10px"
        , Attr.style "margin-bottom" "20px"
        ]
        [ Html.h3 [] [ Html.text "📊 System Status" ]
        , Html.div
            [ Attr.style "background" "rgba(0,0,0,0.2)"
            , Attr.style "padding" "15px"
            , Attr.style "border-radius" "5px"
            , Attr.style "margin-bottom" "15px"
            , Attr.style "font-family" "monospace"
            ]
            [ Html.text model.status ]

        , case model.lastError of
            Just error ->
                Html.div
                    [ Attr.style "background" "rgba(220,53,69,0.2)"
                    , Attr.style "border" "1px solid rgba(220,53,69,0.5)"
                    , Attr.style "padding" "10px"
                    , Attr.style "border-radius" "5px"
                    , Attr.style "margin-bottom" "15px"
                    ]
                    [ Html.strong [] [ Html.text "❌ Last Error: " ]
                    , Html.text error
                    ]
            Nothing -> Html.text ""

        , Html.div
            [ Attr.style "display" "flex"
            , Attr.style "justify-content" "space-between"
            , Attr.style "align-items" "center"
            , Attr.style "margin-bottom" "15px"
            ]
            [ Html.h4 [] [ Html.text "🔍 Operation Log" ]
            , Html.div []
                [ controlButton "🧹 Clear Log" ClearLog False
                , Html.button
                    [ Events.onClick ToggleAdvancedMode
                    , Attr.style "background" "rgba(255,255,255,0.2)"
                    , Attr.style "color" "white"
                    , Attr.style "border" "1px solid rgba(255,255,255,0.3)"
                    , Attr.style "padding" "5px 10px"
                    , Attr.style "border-radius" "3px"
                    , Attr.style "cursor" "pointer"
                    , Attr.style "margin-left" "10px"
                    ]
                    [ Html.text (if model.showAdvanced then "Hide Advanced" else "Show Advanced") ]
                ]
            ]

        , Html.div
            [ Attr.style "background" "rgba(0,0,0,0.2)"
            , Attr.style "padding" "10px"
            , Attr.style "border-radius" "5px"
            , Attr.style "max-height" "200px"
            , Attr.style "overflow-y" "auto"
            , Attr.style "font-family" "monospace"
            , Attr.style "font-size" "12px"
            ]
            (List.map (\log ->
                Html.div
                    [ Attr.style "padding" "2px 0"
                    , Attr.style "border-bottom" "1px solid rgba(255,255,255,0.1)"
                    ]
                    [ Html.text log ]
            ) (List.take 50 model.operationLog))
        ]

advancedInfoSection : Model -> Html Msg
advancedInfoSection model =
    Html.div
        [ Attr.style "background" "rgba(0,0,0,0.3)"
        , Attr.style "padding" "20px"
        , Attr.style "border-radius" "10px"
        ]
        [ Html.h3 [] [ Html.text "🔬 Advanced Information" ]

        , Html.h4 [] [ Html.text "Type Signatures Used:" ]
        , Html.pre
            [ Attr.style "background" "rgba(0,0,0,0.4)"
            , Attr.style "padding" "10px"
            , Attr.style "border-radius" "5px"
            , Attr.style "font-size" "11px"
            , Attr.style "overflow-x" "auto"
            ]
            [ Html.text """createAudioContext : UserActivated -> Result CapabilityError (Initialized AudioContext)
createOscillator : Initialized AudioContext -> Float -> String -> Result CapabilityError OscillatorNode
connectNodes : a -> b -> Result CapabilityError Int
startOscillator : OscillatorNode -> Float -> Result CapabilityError Int""" ]

        , Html.h4 [] [ Html.text "Current State:" ]
        , Html.ul []
            [ Html.li [] [ Html.text ("AudioContext: " ++ (if model.audioContext /= Nothing then "Initialized" else "Not created")) ]
            , Html.li [] [ Html.text ("OscillatorNode: " ++ (if model.currentOscillator /= Nothing then "Created" else "Not created")) ]
            , Html.li [] [ Html.text ("GainNode: " ++ (if model.currentGainNode /= Nothing then "Created" else "Not created")) ]
            , Html.li [] [ Html.text ("Audio Playing: " ++ (if model.isPlaying then "Yes" else "No")) ]
            ]
        ]

-- Helper Functions

controlButton : String -> Msg -> Bool -> Html Msg
controlButton label msg disabled =
    Html.button
        [ Events.onClick msg
        , Attr.disabled disabled
        , Attr.style "background" (if disabled then "rgba(100,100,100,0.5)" else "rgba(40,167,69,0.8)")
        , Attr.style "color" "white"
        , Attr.style "border" "none"
        , Attr.style "padding" "10px 15px"
        , Attr.style "border-radius" "5px"
        , Attr.style "cursor" (if disabled then "not-allowed" else "pointer")
        , Attr.style "font-weight" "bold"
        ]
        [ Html.text label ]

sliderStyle : Html.Attribute Msg
sliderStyle =
    Attr.style "flex" "1"

demoModeString : DemoMode -> String
demoModeString mode =
    case mode of
        SimplifiedInterface -> "Simplified Interface"
        TypeSafeInterface -> "Type-Safe Interface"
        ComparisonMode -> "Comparison Mode"

capabilityErrorString : CapabilityError -> String
capabilityErrorString error =
    case error of
        UserActivationRequired msg -> "User activation required: " ++ msg
        PermissionRequired msg -> "Permission required: " ++ msg
        InitializationRequired msg -> "Initialization required: " ++ msg
        FeatureNotAvailable msg -> "Feature not available: " ++ msg
        CapabilityRevoked msg -> "Capability revoked: " ++ msg

-- ============================================================================
-- MAIN APPLICATION
-- ============================================================================

init : () -> ( Model, Cmd Msg )
init _ =
    ( initialModel, Cmd.none )

subscriptions : Model -> Sub Msg
subscriptions _ =
    Sub.none

main : Program () Model Msg
main =
    Browser.element
        { init = init
        , view = view
        , update = update
        , subscriptions = subscriptions
        }