                    ]
                , div [ style "margin" "8px 0", style "padding" "10px", style "background-color" "#ffffff", style "border-left" "4px solid #dc3545" ]
                    [ strong [ style "color" "#721c24" ] [ text "❌ Real Audio: " ]
                    , text "Cannot create actual AudioContext or play real sounds"
                    , div [ style "font-size" "14px", style "color" "#666", style "margin-top" "4px" ]
