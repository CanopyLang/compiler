module MinimalAudioFFI exposing (AudioContext, createAudioContext)

{-| Minimal Audio FFI for testing compiler
-}

-- Foreign import declaration for external JavaScript
foreign import javascript "external/audio.js" as AudioFFI

-- Opaque type for AudioContext
type AudioContext = AudioContext

-- Simple function that calls the FFI
createAudioContext : () -> AudioContext
createAudioContext _ =
    AudioFFI.createAudioContext