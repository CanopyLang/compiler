module TestCapability exposing (main)

import Capability exposing (UserActivated(..), CapabilityError(..))

main : String
main = "Testing capability types - basic compilation check"

testUserActivation : UserActivated -> String
testUserActivation activation =
    case activation of
        Click -> "click"
        Keypress -> "keypress"
        Touch -> "touch"
        Drag -> "drag"
        Focus -> "focus"
        Transient -> "transient"