module Browser.Page exposing
    ( goto
    , url
    , title
    , reload
    , goBack
    , goForward
    , waitForSelector
    , waitForHidden
    , waitForNavigation
    , waitForLoadState
    , waitForTimeout
    , waitForFunction
    , setViewport
    , getViewport
    , screenshot
    , screenshotViewport
    , screenshotElement
    , pdf
    , evaluate
    , evaluateFloat
    , evaluateBool
    , blockRequests
    , mockResponse
    , clearRoutes
    , scrollToTop
    , scrollToBottom
    , scrollIntoView
    )

{-| Page-level browser operations.

This module provides navigation, screenshots, viewport control,
and JavaScript evaluation capabilities.

## Navigation

    Browser.launch config
        |> Task.andThen (Page.goto "http://localhost:3000")
        |> Task.andThen Page.waitForLoadState
        |> Task.andThen (Page.goto "/about")
        |> Task.andThen Page.goBack

## Screenshots

    Browser.launch config
        |> Task.andThen (Page.goto "http://localhost:3000")
        |> Task.andThen (Page.screenshot "homepage")

## Viewport Control

    Browser.launch config
        |> Task.andThen (Page.setViewport 375 667)  -- Mobile size
        |> Task.andThen (Page.goto "http://localhost:3000")
        |> Task.andThen (Page.screenshot "mobile-view")

## JavaScript Evaluation

    Browser.launch config
        |> Task.andThen (Page.goto "http://localhost:3000")
        |> Task.andThen (Page.evaluate "document.title")

-}

import Browser exposing (Browser, BrowserError)
import Task exposing (Task)

-- FFI import
foreign import javascript "../external/playwright.js" as Playwright


-- ============================================================================
-- Navigation
-- ============================================================================


{-| Navigate to a URL.

Waits for the page to fully load before resolving.

    Page.goto "http://localhost:3000" browser

-}
goto : String -> Browser -> Task BrowserError Browser
goto pageUrl browser =
    Playwright.goto pageUrl browser


{-| Get the current page URL.

This is a synchronous operation.

    let currentUrl = Page.url browser

-}
url : Browser -> String
url browser =
    Playwright.url browser


{-| Get the page title.

    Page.title browser
        |> Task.map (\t -> "Title is: " ++ t)

-}
title : Browser -> Task BrowserError String
title browser =
    Playwright.title browser


{-| Reload the current page.

    browser
        |> Page.reload
        |> Task.andThen (Element.waitForSelector "#content")

-}
reload : Browser -> Task BrowserError Browser
reload browser =
    Playwright.reload browser


{-| Navigate back in browser history.
-}
goBack : Browser -> Task BrowserError Browser
goBack browser =
    Playwright.goBack browser


{-| Navigate forward in browser history.
-}
goForward : Browser -> Task BrowserError Browser
goForward browser =
    Playwright.goForward browser


-- ============================================================================
-- Waiting
-- ============================================================================


{-| Wait for an element to be visible.

    browser
        |> Page.goto "http://localhost:3000"
        |> Task.andThen (Page.waitForSelector "#loaded-content")

-}
waitForSelector : String -> Browser -> Task BrowserError Browser
waitForSelector selector browser =
    Playwright.waitForSelector selector browser


{-| Wait for an element to be hidden or removed.

    browser
        |> Element.click "#close-modal"
        |> Task.andThen (Page.waitForHidden "#modal")

-}
waitForHidden : String -> Browser -> Task BrowserError Browser
waitForHidden selector browser =
    Playwright.waitForHidden selector browser


{-| Wait for navigation to complete.

Use after clicking links that cause page navigation.

    browser
        |> Element.click "#nav-link"
        |> Task.andThen Page.waitForNavigation

-}
waitForNavigation : Browser -> Task BrowserError Browser
waitForNavigation browser =
    Playwright.waitForNavigation browser


{-| Wait for network to be idle.

Useful for SPAs that make AJAX requests on load.

    browser
        |> Page.goto "http://localhost:3000"
        |> Task.andThen Page.waitForLoadState

-}
waitForLoadState : Browser -> Task BrowserError Browser
waitForLoadState browser =
    Playwright.waitForLoadState browser


{-| Wait for specified milliseconds.

Use sparingly - prefer waitForSelector or waitForFunction.

    browser
        |> Page.waitForTimeout 1000  -- Wait 1 second

-}
waitForTimeout : Int -> Browser -> Task BrowserError Browser
waitForTimeout ms browser =
    Playwright.waitForTimeout ms browser


{-| Wait for a JavaScript expression to return truthy.

    -- Wait for data to load
    browser
        |> Page.waitForFunction "window.dataLoaded === true"

-}
waitForFunction : String -> Browser -> Task BrowserError Browser
waitForFunction script browser =
    Playwright.waitForFunction script browser


-- ============================================================================
-- Screenshots
-- ============================================================================


{-| Take a full-page screenshot.

Screenshots are saved to test-output/screenshots/

    browser
        |> Page.screenshot "homepage"
        |> Task.map (\path -> "Saved to: " ++ path)

-}
screenshot : String -> Browser -> Task BrowserError String
screenshot name browser =
    Playwright.screenshot name browser


{-| Take a screenshot of the visible viewport only.

    browser
        |> Page.screenshotViewport "above-fold"

-}
screenshotViewport : String -> Browser -> Task BrowserError String
screenshotViewport name browser =
    Playwright.screenshotViewport name browser


{-| Take a screenshot of a specific element.

    browser
        |> Page.screenshotElement "#hero-section" "hero"

-}
screenshotElement : String -> String -> Browser -> Task BrowserError String
screenshotElement selector name browser =
    Playwright.screenshotElement selector name browser


-- ============================================================================
-- Viewport
-- ============================================================================


{-| Set the viewport size.

    -- Mobile viewport
    browser
        |> Page.setViewport 375 667

    -- Tablet viewport
    browser
        |> Page.setViewport 768 1024

    -- Desktop viewport
    browser
        |> Page.setViewport 1920 1080

-}
setViewport : Int -> Int -> Browser -> Task BrowserError Browser
setViewport width height browser =
    Playwright.setViewport width height browser


{-| Get the current viewport size.
-}
getViewport : Browser -> { width : Int, height : Int }
getViewport browser =
    Playwright.getViewport browser


-- ============================================================================
-- JavaScript Evaluation
-- ============================================================================


{-| Evaluate JavaScript in the page context.

Returns the result as a JSON string.

    browser
        |> Page.evaluate "document.querySelectorAll('li').length"

-}
evaluate : String -> Browser -> Task BrowserError String
evaluate script browser =
    Playwright.evaluate script browser


{-| Evaluate JavaScript and return a number.

    browser
        |> Page.evaluateFloat "window.scrollY"

-}
evaluateFloat : String -> Browser -> Task BrowserError Float
evaluateFloat script browser =
    Playwright.evaluateFloat script browser


{-| Evaluate JavaScript and return a boolean.

    browser
        |> Page.evaluateBool "document.hidden"

-}
evaluateBool : String -> Browser -> Task BrowserError Bool
evaluateBool script browser =
    Playwright.evaluateBool script browser


-- ============================================================================
-- PDF
-- ============================================================================


{-| Generate a PDF of the current page.

PDFs are saved to test-output/pdfs/

    browser
        |> Page.pdf "report"

-}
pdf : String -> Browser -> Task BrowserError String
pdf name browser =
    Playwright.pdf name browser


-- ============================================================================
-- Network Interception
-- ============================================================================


{-| Block requests matching a URL pattern.

Uses glob syntax for matching.

    browser
        |> Page.blockRequests "**/*.png"  -- Block all PNGs
        |> Task.andThen (Page.goto "http://localhost:3000")

-}
blockRequests : String -> Browser -> Task BrowserError Browser
blockRequests pattern browser =
    Playwright.blockRequests pattern browser


{-| Mock response for URL pattern.

    browser
        |> Page.mockResponse "**/api/user" "{\"name\": \"Test User\"}"
        |> Task.andThen (Page.goto "http://localhost:3000")

-}
mockResponse : String -> String -> Browser -> Task BrowserError Browser
mockResponse pattern body browser =
    Playwright.mockResponse pattern body browser


{-| Clear all route handlers.

    browser
        |> Page.clearRoutes

-}
clearRoutes : Browser -> Task BrowserError Browser
clearRoutes browser =
    Playwright.clearRoutes browser


-- ============================================================================
-- Scrolling
-- ============================================================================


{-| Scroll to top of page.
-}
scrollToTop : Browser -> Task BrowserError Browser
scrollToTop browser =
    Playwright.scrollToTop browser


{-| Scroll to bottom of page.
-}
scrollToBottom : Browser -> Task BrowserError Browser
scrollToBottom browser =
    Playwright.scrollToBottom browser


{-| Scroll element into view.

    browser
        |> Page.scrollIntoView "#footer"

-}
scrollIntoView : String -> Browser -> Task BrowserError Browser
scrollIntoView selector browser =
    Playwright.scrollIntoView selector browser
