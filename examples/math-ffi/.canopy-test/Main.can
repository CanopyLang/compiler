module Main exposing (main)

import Html exposing (Html, div, text, p, h1, button, pre)
import Html.Attributes exposing (style)
import Html.Events exposing (onClick)

-- Import our Math FFI functions
foreign import javascript "external/math.js" as Math

-- Simple message type for demo
type Msg = RunCalculations

-- Basic model
type alias Model = String

-- Initialize with welcome message
init : Model
init = "Click the button to run mathematical calculations!"

-- Update function
update : Msg -> Model -> Model
update msg model =
    case msg of
        RunCalculations ->
            runMathExamples

-- Main view
main : Html Msg
main =
    Html.div [ style "padding" "20px", style "font-family" "Arial, sans-serif" ]
        [ h1 [] [ text "Math FFI Example" ]
        , p [] [ text "Mathematical operations through Canopy's FFI system." ]
        , button
            [ onClick RunCalculations
            , style "padding" "10px 20px"
            , style "font-size" "16px"
            , style "background-color" "#007cba"
            , style "color" "white"
            , style "border" "none"
            , style "border-radius" "5px"
            , style "cursor" "pointer"
            ]
            [ text "Run Calculations" ]
        , pre [ style "margin-top" "20px", style "background-color" "#f5f5f5", style "padding" "10px" ]
            [ text init ]
        ]

-- Run various mathematical examples
runMathExamples : String
runMathExamples =
    let
        results =
            [ "=== FACTORIAL CALCULATIONS ==="
            , "5! = " ++ String.fromInt (Math.factorial 5)
            , "7! = " ++ String.fromInt (Math.factorial 7)
            , ""
            , "=== PRIME NUMBERS ==="
            , "Is 17 prime? " ++ boolToString (Math.isPrime 17)
            , "Is 18 prime? " ++ boolToString (Math.isPrime 18)
            , ""
            , "=== FIBONACCI SEQUENCE ==="
            , "fib(10) = " ++ String.fromInt (Math.fibonacci 10)
            , "fib(15) = " ++ String.fromInt (Math.fibonacci 15)
            , ""
            , "=== GCD ==="
            , "gcd(48, 18) = " ++ String.fromInt (Math.gcd 48 18)
            , ""
            , "=== POWER CALCULATIONS ==="
            , "2^8 = " ++ String.fromFloat (Math.power 2 8)
            , "3^4 = " ++ String.fromFloat (Math.power 3 4)
            ]
    in
    String.join "\n" results

-- Helper function to convert Bool to String
boolToString : Bool -> String
boolToString bool =
    if bool then "Yes" else "No"