module SimpleTest exposing (main)

{-| Simple test runner for Math FFI
Validates basic FFI functionality with the test framework.
Outputs results as HTML which can be captured by the test runner.
-}

import Html exposing (Html, div, text, pre)
import Test exposing (Test, describe, test, toRunner, RunnerResult)
import Expect

foreign import javascript "external/math.js" as FFI


-- | Main renders test results that the harness will capture
main : Html msg
main =
    let
        results = toRunner allTests
        output = formatResults results
    in
    pre [] [ text output ]


-- | All test cases
allTests : List Test
allTests =
    [ describe "Basic Math FFI Tests"
        [ test "factorial(5) = 120" <|
            \_ -> Expect.equal 120 (factorial 5)

        , test "fibonacci(10) = 55" <|
            \_ -> Expect.equal 55 (fibonacci 10)

        , test "gcd(48, 18) = 6" <|
            \_ -> Expect.equal 6 (gcd 48 18)

        , test "isPrime(17) = True" <|
            \_ -> Expect.equal True (isPrime 17)

        , test "power(2, 10) = 1024" <|
            \_ -> Expect.equal 1024.0 (power 2.0 10)
        ]
    ]


-- | Format test results for console output
formatResults : List RunnerResult -> String
formatResults results =
    let
        passed = List.filter .passed results
        failed = List.filter (\r -> not r.passed) results
        passedCount = List.length passed
        failedCount = List.length failed
        total = List.length results
    in
    String.join "\n"
        (List.map formatResult results
            ++ [ ""
               , String.fromInt total ++ " test(s) total, "
                   ++ String.fromInt passedCount ++ " passed, "
                   ++ String.fromInt failedCount ++ " failed."
               ]
        )


formatResult : RunnerResult -> String
formatResult r =
    if r.passed then
        "  PASS  " ++ r.name
    else
        "  FAIL  " ++ r.name ++ "\n        " ++ r.reason


-- FFI Wrappers
factorial : Int -> Int
factorial = FFI.factorial

fibonacci : Int -> Int
fibonacci = FFI.fibonacci

gcd : Int -> Int -> Int
gcd = FFI.gcd

isPrime : Int -> Bool
isPrime = FFI.isPrime

power : Float -> Int -> Float
power = FFI.power
