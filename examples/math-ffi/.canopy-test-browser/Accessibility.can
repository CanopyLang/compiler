module Accessibility exposing
    ( test
    , audit
    , auditElement
    , noViolations
    , checkLabels
    , checkContrast
    , checkHeadings
    , checkLandmarks
    , checkKeyboardNav
    , checkFocusOrder
    , checkAriaAttributes
    , meetsWcag
    , WcagLevel(..)
    , Violation
    , violationCount
    , violationsOfType
    , tabThrough
    , allFocusable
    )

{-| Accessibility testing powered by axe-core.

## Quick Start

    import Accessibility as A11y

    suite : Test
    suite =
        A11y.test "homepage is accessible" <|
            \browser ->
                browser
                    |> Page.goto "http://localhost:3000"
                    |> A11y.audit
                    |> A11y.noViolations

## WCAG Compliance

    A11y.test "meets WCAG AA" <|
        \browser ->
            browser
                |> Page.goto "http://localhost:3000"
                |> A11y.audit
                |> A11y.meetsWcag AA

## Specific Checks

    A11y.test "form labels are correct" <|
        \browser ->
            browser
                |> Page.goto "http://localhost:3000/form"
                |> A11y.checkLabels
                |> A11y.noViolations

-}

import Browser exposing (Browser)
import Test exposing (Test)
import Expect exposing (Expectation)


{-| WCAG conformance levels.
-}
type WcagLevel
    = A
    | AA
    | AAA


{-| An accessibility violation found during audit.
-}
type Violation
    = Violation ViolationRecord


type alias ViolationRecord =
    { id : String
    , impact : String
    , description : String
    , help : String
    , helpUrl : String
    , nodes : List ViolationNode
    }


type alias ViolationNode =
    { selector : String
    , html : String
    , failureSummary : String
    }


{-| Result of an accessibility audit.
-}
type AuditResult
    = AuditResult
        { violations : List Violation
        , passes : Int
        , incomplete : Int
        }


{-| Create an accessibility test.

    A11y.test "page is accessible" <|
        \browser ->
            browser
                |> Page.goto "http://localhost:3000"
                |> A11y.audit
                |> A11y.noViolations

-}
test : String -> (Browser -> Expectation) -> Test
test description testFn =
    Browser.test description testFn


{-| Run a full accessibility audit on the current page.

Uses axe-core to check for WCAG violations.

-}
audit : Browser -> AuditResult
audit browser =
    -- Kernel: return await axe.run()
    AuditResult
        { violations = []
        , passes = 0
        , incomplete = 0
        }


{-| Run an accessibility audit on a specific element.

    browser
        |> A11y.auditElement "#main-content"
        |> A11y.noViolations

-}
auditElement : String -> Browser -> AuditResult
auditElement selector browser =
    -- Kernel: return await axe.run(selector)
    AuditResult
        { violations = []
        , passes = 0
        , incomplete = 0
        }


{-| Assert that there are no accessibility violations.

    browser
        |> A11y.audit
        |> A11y.noViolations

-}
noViolations : AuditResult -> Expectation
noViolations (AuditResult result) =
    case result.violations of
        [] ->
            Expect.pass

        violations ->
            Expect.fail (formatViolations violations)


formatViolations : List Violation -> String
formatViolations violations =
    let
        count =
            List.length violations

        header =
            "Found " ++ String.fromInt count ++ " accessibility violation(s):\n\n"

        details =
            violations
                |> List.map formatViolation
                |> String.join "\n\n"
    in
    header ++ details


formatViolation : Violation -> String
formatViolation (Violation v) =
    "• " ++ v.id ++ " (" ++ v.impact ++ ")\n" ++
    "  " ++ v.description ++ "\n" ++
    "  Help: " ++ v.helpUrl


{-| Check that all form inputs have associated labels.
-}
checkLabels : Browser -> AuditResult
checkLabels browser =
    -- Kernel: return await axe.run({ runOnly: ['label'] })
    AuditResult { violations = [], passes = 0, incomplete = 0 }


{-| Check color contrast meets requirements.
-}
checkContrast : Browser -> AuditResult
checkContrast browser =
    -- Kernel: return await axe.run({ runOnly: ['color-contrast'] })
    AuditResult { violations = [], passes = 0, incomplete = 0 }


{-| Check heading hierarchy is correct.
-}
checkHeadings : Browser -> AuditResult
checkHeadings browser =
    -- Kernel: return await axe.run({ runOnly: ['heading-order'] })
    AuditResult { violations = [], passes = 0, incomplete = 0 }


{-| Check ARIA landmarks are present and correct.
-}
checkLandmarks : Browser -> AuditResult
checkLandmarks browser =
    -- Kernel: return await axe.run({ runOnly: ['landmark'] })
    AuditResult { violations = [], passes = 0, incomplete = 0 }


{-| Check keyboard navigation works correctly.
-}
checkKeyboardNav : Browser -> AuditResult
checkKeyboardNav browser =
    -- Kernel: custom keyboard navigation check
    AuditResult { violations = [], passes = 0, incomplete = 0 }


{-| Check focus order is logical.
-}
checkFocusOrder : Browser -> AuditResult
checkFocusOrder browser =
    -- Kernel: check tab order
    AuditResult { violations = [], passes = 0, incomplete = 0 }


{-| Check ARIA attributes are valid.
-}
checkAriaAttributes : Browser -> AuditResult
checkAriaAttributes browser =
    -- Kernel: return await axe.run({ runOnly: ['aria'] })
    AuditResult { violations = [], passes = 0, incomplete = 0 }


{-| Assert the page meets a WCAG conformance level.

    browser
        |> A11y.audit
        |> A11y.meetsWcag AA

-}
meetsWcag : WcagLevel -> AuditResult -> Expectation
meetsWcag level (AuditResult result) =
    let
        tags =
            case level of
                A ->
                    [ "wcag2a", "wcag21a" ]

                AA ->
                    [ "wcag2a", "wcag21a", "wcag2aa", "wcag21aa" ]

                AAA ->
                    [ "wcag2a", "wcag21a", "wcag2aa", "wcag21aa", "wcag2aaa", "wcag21aaa" ]

        relevantViolations =
            List.filter (violationMatchesTags tags) result.violations
    in
    case relevantViolations of
        [] ->
            Expect.pass

        violations ->
            Expect.fail ("Does not meet WCAG " ++ levelToString level ++ ":\n" ++ formatViolations violations)


violationMatchesTags : List String -> Violation -> Bool
violationMatchesTags tags (Violation v) =
    -- Check if violation matches any of the WCAG tags
    True


levelToString : WcagLevel -> String
levelToString level =
    case level of
        A ->
            "A"

        AA ->
            "AA"

        AAA ->
            "AAA"


{-| Count the number of violations.
-}
violationCount : AuditResult -> Int
violationCount (AuditResult result) =
    List.length result.violations


{-| Filter violations by type.

    browser
        |> A11y.audit
        |> A11y.violationsOfType "color-contrast"
        |> List.length
        |> Expect.equal 0

-}
violationsOfType : String -> AuditResult -> List Violation
violationsOfType violationType (AuditResult result) =
    List.filter (\(Violation v) -> v.id == violationType) result.violations


{-| Simulate tabbing through elements.

    browser
        |> A11y.tabThrough [ "#nav", "#main", "#footer" ]
        |> A11y.allFocusable

-}
tabThrough : List String -> Browser -> TabResult
tabThrough selectors browser =
    -- Kernel: tab through and record focus order
    TabResult { focusedElements = [], expectedOrder = selectors }


type TabResult
    = TabResult
        { focusedElements : List String
        , expectedOrder : List String
        }


{-| Assert all expected elements were focusable via tab.
-}
allFocusable : TabResult -> Expectation
allFocusable (TabResult result) =
    if result.focusedElements == result.expectedOrder then
        Expect.pass

    else
        Expect.fail
            ("Focus order mismatch.\n" ++
             "Expected: " ++ String.join " -> " result.expectedOrder ++ "\n" ++
             "Actual: " ++ String.join " -> " result.focusedElements)
