module Test.Runner exposing
    ( run
    , runWithConfig
    , Config
    , defaultConfig
    , withSeed
    , withFuzzRuns
    , withTimeout
    , withParallel
    , Report
    , Summary
    , TestResult(..)
    , formatConsole
    , formatJson
    , formatJunit
    )

{-| Test runner for executing test suites.

This module provides the test execution engine using the FFI system
(not kernel code) for JavaScript integration.

## Running Tests

    import Test.Runner as Runner
    import MyTests

    main =
        Runner.run MyTests.suite

## Configuration

    main =
        Runner.runWithConfig
            (Runner.defaultConfig
                |> Runner.withSeed 12345
                |> Runner.withFuzzRuns 1000
            )
            MyTests.suite

-}

import Test exposing (Test)
import Json.Encode as E

-- FFI import for test execution
foreign import javascript "external/test-runner.js" as TestRunnerFFI


{-| Configuration for test execution.
-}
type Config
    = Config ConfigRecord


type alias ConfigRecord =
    { seed : Maybe Int
    , fuzzRuns : Int
    , timeout : Int
    , parallel : Bool
    , reporter : ReportFormat
    }


type ReportFormat
    = Console
    | Json
    | Junit


{-| Default test configuration.
-}
defaultConfig : Config
defaultConfig =
    Config
        { seed = Nothing
        , fuzzRuns = 100
        , timeout = 30000
        , parallel = True
        , reporter = Console
        }


{-| Set a specific random seed for reproducibility.
-}
withSeed : Int -> Config -> Config
withSeed seed (Config config) =
    Config { config | seed = Just seed }


{-| Set the number of fuzz test iterations.
-}
withFuzzRuns : Int -> Config -> Config
withFuzzRuns runs (Config config) =
    Config { config | fuzzRuns = runs }


{-| Set the timeout for each test (milliseconds).
-}
withTimeout : Int -> Config -> Config
withTimeout ms (Config config) =
    Config { config | timeout = ms }


{-| Enable/disable parallel test execution.
-}
withParallel : Bool -> Config -> Config
withParallel parallel (Config config) =
    Config { config | parallel = parallel }


{-| Result of running a single test.
-}
type TestResult
    = Passed String Float
    | Failed String String Float
    | Skipped String
    | Todo String


{-| Complete test report.
-}
type alias Report =
    { results : List TestResult
    , summary : Summary
    , duration : Float
    }


{-| Summary statistics.
-}
type alias Summary =
    { total : Int
    , passed : Int
    , failed : Int
    , skipped : Int
    , todo : Int
    }


{-| Run tests with default configuration and print results.

    main =
        Runner.run MyTests.suite

-}
run : Test -> String
run suite =
    let
        report =
            runTests suite
    in
    formatConsole report


{-| Run tests with custom configuration.
-}
runWithConfig : Config -> Test -> String
runWithConfig config suite =
    -- Config will be used for seed, fuzzRuns, etc. in future
    -- For now, ignore config and use default behavior
    let
        _ = config
    in
    run suite


{-| Execute tests and get the report.
Uses FFI to call the JavaScript test runner.
-}
runTests : Test -> Report
runTests =
    TestRunnerFFI.runTests


{-| Format report for console output.
Uses FFI to call the JavaScript formatter.
-}
formatConsole : Report -> String
formatConsole =
    TestRunnerFFI.formatConsole


{-| Format report as JSON.
Uses FFI to call the JavaScript formatter.
-}
formatJson : Report -> String
formatJson =
    TestRunnerFFI.formatJson


{-| Format report as JUnit XML for CI integration.
-}
formatJunit : Report -> String
formatJunit report =
    let
        header =
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n" ++
            "<testsuites tests=\"" ++ String.fromInt report.summary.total ++ "\" " ++
            "failures=\"" ++ String.fromInt report.summary.failed ++ "\" " ++
            "time=\"" ++ String.fromFloat (report.duration / 1000) ++ "\">\n" ++
            "  <testsuite name=\"canopy-test\">\n"

        results =
            report.results
                |> List.map formatJunitResult
                |> String.join ""

        footer =
            "  </testsuite>\n" ++
            "</testsuites>"
    in
    header ++ results ++ footer


formatJunitResult : TestResult -> String
formatJunitResult result =
    case result of
        Passed name duration ->
            "    <testcase name=\"" ++ escapeXml name ++ "\" time=\"" ++
            String.fromFloat (duration / 1000) ++ "\"/>\n"

        Failed name message duration ->
            "    <testcase name=\"" ++ escapeXml name ++ "\" time=\"" ++
            String.fromFloat (duration / 1000) ++ "\">\n" ++
            "      <failure message=\"" ++ escapeXml message ++ "\"/>\n" ++
            "    </testcase>\n"

        Skipped name ->
            "    <testcase name=\"" ++ escapeXml name ++ "\">\n" ++
            "      <skipped/>\n" ++
            "    </testcase>\n"

        Todo name ->
            "    <testcase name=\"" ++ escapeXml name ++ "\">\n" ++
            "      <skipped message=\"TODO\"/>\n" ++
            "    </testcase>\n"


escapeXml : String -> String
escapeXml str =
    str
        |> String.replace "&" "&amp;"
        |> String.replace "<" "&lt;"
        |> String.replace ">" "&gt;"
        |> String.replace "\"" "&quot;"
        |> String.replace "'" "&apos;"
