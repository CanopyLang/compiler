module Test exposing
    ( Test
    , describe
    , test
    , concat
    , skip
    , todo
    , run
    , runTests
    , TestResult
    )

{-| Test framework for Canopy (similar to elm-explorations/test)

Provides core testing functionality for unit tests, property tests,
and integration tests.

## Creating Tests

    import Test exposing (Test, describe, test)
    import Expect

    suite : Test
    suite =
        describe "Math"
            [ test "addition" <|
                \_ -> Expect.equal 4 (2 + 2)
            , test "subtraction" <|
                \_ -> Expect.equal 0 (2 - 2)
            ]

## Combining Test Suites

    allTests : Test
    allTests =
        Test.concat
            [ MathTests.suite
            , StringTests.suite
            , ListTests.suite
            ]

## Skipping Tests

    suite : Test
    suite =
        describe "Work in Progress"
            [ skip <| test "not ready yet" <|
                \_ -> Expect.equal 1 2
            , todo "implement this later"
            ]

-}

import Expect exposing (Expectation)


{-| A Test is a collection of expectations or other tests.
The internal structure allows nesting and different test types.
-}
type Test
    = UnitTest String (() -> Expectation)
    | TestGroup String (List Test)
    | Skip Test
    | Todo String


{-| Create a group of tests with a description.

    describe "User Authentication"
        [ test "login with valid credentials" <| ...
        , test "login with invalid password" <| ...
        , test "logout clears session" <| ...
        ]

-}
describe : String -> List Test -> Test
describe description tests =
    TestGroup description tests


{-| Create a single test with a description and expectation.

    test "2 + 2 equals 4" <|
        \_ -> Expect.equal 4 (2 + 2)

-}
test : String -> (() -> Expectation) -> Test
test description expectationFn =
    UnitTest description expectationFn


{-| Combine multiple test suites into one.

    allTests : Test
    allTests =
        concat
            [ MathTests.suite
            , StringTests.suite
            ]

-}
concat : List Test -> Test
concat tests =
    TestGroup "Test Suite" tests


{-| Skip a test. It will be marked as skipped in the results.

    skip <| test "not working yet" <|
        \_ -> Expect.equal 1 2

-}
skip : Test -> Test
skip testToSkip =
    Skip testToSkip


{-| Mark something as needing to be implemented.

    todo "implement user registration test"

-}
todo : String -> Test
todo description =
    Todo description


{-| Test result type containing the outcome of running a test.
-}
type alias TestResult =
    { description : String
    , status : String
    , message : String
    , duration : Int
    }


{-| Run a test and get the results.
-}
run : Test -> TestResult
run testCase =
    case testCase of
        UnitTest description expectationFn ->
            runUnitTest description expectationFn

        TestGroup description tests ->
            runTestGroup description tests

        Skip innerTest ->
            runSkippedTest innerTest

        Todo description ->
            { description = description
            , status = "TODO"
            , message = "Not yet implemented"
            , duration = 0
            }


runUnitTest : String -> (() -> Expectation) -> TestResult
runUnitTest description expectationFn =
    let
        result =
            expectationFn ()
    in
    case result of
        Expect.Pass ->
            { description = description
            , status = "PASS"
            , message = ""
            , duration = 0
            }

        Expect.Fail reason ->
            { description = description
            , status = "FAIL"
            , message = reasonToString reason
            , duration = 0
            }


runTestGroup : String -> List Test -> TestResult
runTestGroup description tests =
    let
        results =
            List.map run tests

        failures =
            List.filter (\r -> r.status == "FAIL") results

        skipped =
            List.filter (\r -> r.status == "SKIP") results

        todos =
            List.filter (\r -> r.status == "TODO") results
    in
    { description = description
    , status =
        if List.isEmpty failures then
            "PASS"
        else
            "FAIL"
    , message =
        String.fromInt (List.length failures) ++ " failed, " ++
        String.fromInt (List.length skipped) ++ " skipped, " ++
        String.fromInt (List.length todos) ++ " todo"
    , duration = 0
    }


runSkippedTest : Test -> TestResult
runSkippedTest innerTest =
    case innerTest of
        UnitTest description _ ->
            { description = description
            , status = "SKIP"
            , message = "Skipped"
            , duration = 0
            }

        TestGroup description _ ->
            { description = description
            , status = "SKIP"
            , message = "Skipped"
            , duration = 0
            }

        Skip nestedTest ->
            runSkippedTest nestedTest

        Todo description ->
            { description = description
            , status = "SKIP"
            , message = "Skipped"
            , duration = 0
            }


{-| Convert reason to string.
-}
reasonToString : Expect.Reason -> String
reasonToString reason =
    case reason of
        Expect.Equality label expected actual ->
            label ++ "\n\nExpected:\n    " ++ expected ++ "\n\nActual:\n    " ++ actual

        Expect.Comparison label actual op threshold ->
            label ++ "\n\nExpected " ++ actual ++ " " ++ op ++ " " ++ threshold

        Expect.Custom message ->
            message


{-| Test runner that outputs results as a formatted string.
-}
runTests : List Test -> String
runTests tests =
    let
        allResults =
            List.concatMap collectResults tests

        totalTests =
            List.length allResults

        passedTests =
            List.length (List.filter (\r -> r.status == "PASS") allResults)

        failedTests =
            List.length (List.filter (\r -> r.status == "FAIL") allResults)

        skippedTests =
            List.length (List.filter (\r -> r.status == "SKIP") allResults)

        todoTests =
            List.length (List.filter (\r -> r.status == "TODO") allResults)
    in
    formatResults
        { total = totalTests
        , passed = passedTests
        , failed = failedTests
        , skipped = skippedTests
        , todo = todoTests
        , failures = List.filter (\r -> r.status == "FAIL") allResults
        }


collectResults : Test -> List TestResult
collectResults testCase =
    case testCase of
        UnitTest _ _ ->
            [ run testCase ]

        TestGroup _ tests ->
            List.concatMap collectResults tests

        Skip _ ->
            [ run testCase ]

        Todo _ ->
            [ run testCase ]


formatResults : { total : Int, passed : Int, failed : Int, skipped : Int, todo : Int, failures : List TestResult } -> String
formatResults stats =
    let
        header =
            "\n" ++ String.repeat 60 "─" ++ "\n" ++
            "  Test Results\n" ++
            String.repeat 60 "─" ++ "\n\n"

        summary =
            "  Passed: " ++ String.fromInt stats.passed ++ "\n" ++
            "  Failed: " ++ String.fromInt stats.failed ++ "\n" ++
            (if stats.skipped > 0 then "  Skipped: " ++ String.fromInt stats.skipped ++ "\n" else "") ++
            (if stats.todo > 0 then "  Todo: " ++ String.fromInt stats.todo ++ "\n" else "") ++
            "  Total: " ++ String.fromInt stats.total ++ "\n"

        failureDetails =
            if List.isEmpty stats.failures then
                "\n  All tests passed!\n"
            else
                "\n  Failures:\n\n" ++
                String.join "\n\n" (List.map formatFailure stats.failures) ++ "\n"

        footer =
            "\n" ++ String.repeat 60 "─" ++ "\n"
    in
    header ++ summary ++ failureDetails ++ footer


{-| Format a failure for display.
-}
formatFailure : TestResult -> String
formatFailure result =
    "  ✗ " ++ result.description ++ "\n" ++
    "    " ++ String.replace "\n" "\n    " result.message
