module BrowserTestMain exposing (main)

import Html exposing (Html, pre, text, div, node)
import Html.Attributes exposing (attribute)
import Test exposing (Test, runTests)
import MathTest exposing (suite)
import UtilsTest exposing (suite)


main : Html msg
main =
    let
        allSuites =
            [ MathTest.suite
            , UtilsTest.suite
            ]

        report =
            runTests allSuites
    in
    div
        [ attribute "data-test-complete" "true" ]
        [ pre [] [ text report ]
        , node "script" [] [ text (logResultsScript report) ]
        ]


logResultsScript : String -> String
logResultsScript report =
    "console.log('CANOPY_TEST_RESULTS_START');" ++
    "console.log(" ++ escapeForJs report ++ ");" ++
    "console.log('CANOPY_TEST_RESULTS_END');"


escapeForJs : String -> String
escapeForJs str =
    "'" ++ String.replace "\\" "\\\\" (String.replace "'" "\\'" (String.replace "\n" "\\n" str)) ++ "'"
