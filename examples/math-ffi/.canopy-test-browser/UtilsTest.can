module UtilsTest exposing (main, suite)

{-| Comprehensive Unit Tests for Utils FFI

This module provides 100% test coverage for all Utils FFI functions.

## Test Categories

- Random integer tests (range validation)
- Timestamp tests (validity checks)
- Console log tests (execution verification)

-}

import Html exposing (Html, pre, text)
import Test exposing (Test, describe, test, runTests)
import Expect
import Utils


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "Utils FFI Complete Test Suite"
        [ randomIntTests
        , timestampTests
        , consoleLogTests
        ]


-- ============================================================================
-- RANDOM INT TESTS
-- ============================================================================


randomIntTests : Test
randomIntTests =
    describe "randomInt"
        [ describe "range validation"
            [ test "randomInt 10 returns value less than 10" <|
                \_ ->
                    let
                        result = Utils.randomInt 10
                    in
                    Expect.true "should be less than 10" (result < 10)

            , test "randomInt 10 returns non-negative value" <|
                \_ ->
                    let
                        result = Utils.randomInt 10
                    in
                    Expect.true "should be >= 0" (result >= 0)

            , test "randomInt 100 returns value in range [0, 100)" <|
                \_ ->
                    let
                        result = Utils.randomInt 100
                    in
                    Expect.true "should be in range" (result >= 0 && result < 100)

            , test "randomInt 1 returns 0" <|
                \_ ->
                    let
                        result = Utils.randomInt 1
                    in
                    Expect.equal 0 result
            ]

        , describe "multiple calls produce valid results"
            [ test "five calls to randomInt 50 all produce valid results" <|
                \_ ->
                    let
                        r1 = Utils.randomInt 50
                        r2 = Utils.randomInt 50
                        r3 = Utils.randomInt 50
                        r4 = Utils.randomInt 50
                        r5 = Utils.randomInt 50
                        allValid = List.all (\r -> r >= 0 && r < 50) [r1, r2, r3, r4, r5]
                    in
                    Expect.true "all should be valid" allValid
            ]
        ]


-- ============================================================================
-- TIMESTAMP TESTS
-- ============================================================================


timestampTests : Test
timestampTests =
    describe "getCurrentTimestamp"
        [ test "timestamp is a positive number" <|
            \_ ->
                Expect.true "should be positive" (Utils.getCurrentTimestamp > 0)

        , test "timestamp is a reasonable Unix timestamp (after year 2000)" <|
            \_ ->
                -- Year 2000 in milliseconds: 946684800000
                Expect.true "should be after year 2000" (Utils.getCurrentTimestamp > 946684800000)

        , test "timestamp is not in the far future (before year 2100)" <|
            \_ ->
                -- Year 2100 in milliseconds: 4102444800000
                Expect.true "should be before year 2100" (Utils.getCurrentTimestamp < 4102444800000)
        ]


-- ============================================================================
-- CONSOLE LOG TESTS
-- ============================================================================


consoleLogTests : Test
consoleLogTests =
    describe "consoleLog"
        [ test "consoleLog executes without error" <|
            \_ ->
                let
                    _ = Utils.consoleLog "Test message"
                in
                Expect.pass

        , test "consoleLog with empty string executes" <|
            \_ ->
                let
                    _ = Utils.consoleLog ""
                in
                Expect.pass

        , test "consoleLog with special characters executes" <|
            \_ ->
                let
                    _ = Utils.consoleLog "Test: !@#$%^&*()"
                in
                Expect.pass

        , test "consoleLog with unicode executes" <|
            \_ ->
                let
                    _ = Utils.consoleLog "Unicode test: \u{1F600}"
                in
                Expect.pass

        , test "consoleLog with newlines executes" <|
            \_ ->
                let
                    _ = Utils.consoleLog "Line 1\nLine 2\nLine 3"
                in
                Expect.pass
        ]
