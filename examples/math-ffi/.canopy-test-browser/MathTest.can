module MathTest exposing (main, suite)

{-| Comprehensive Unit Tests for Math FFI

This module provides 100% test coverage for all Math FFI functions.

-}

import Html exposing (Html, div, text, pre)
import Test exposing (Test, describe, test, runTests)
import Expect
import Result exposing (Result(..))

foreign import javascript "external/math.js" as FFI


main : Html msg
main =
    let
        results =
            runTests [ suite ]
    in
    pre [] [ text results ]


suite : Test
suite =
    describe "Math FFI Complete Test Suite"
        [ factorialTests
        , fibonacciTests
        , gcdTests
        , lcmTests
        , primeTests
        , powerTests
        , sqrtTests
        , angleConversionTests
        , distanceTests
        ]


-- ============================================================================
-- FFI WRAPPERS
-- ============================================================================


factorial : Int -> Int
factorial =
    FFI.factorial


fibonacci : Int -> Int
fibonacci =
    FFI.fibonacci


gcd : Int -> Int -> Int
gcd =
    FFI.gcd


lcm : Int -> Int -> Int
lcm =
    FFI.lcm


isPrime : Int -> Bool
isPrime =
    FFI.isPrime


power : Float -> Int -> Float
power =
    FFI.power


type MathError
    = NegativeInput String
    | InvalidInput String


sqrt : Float -> Result MathError Float
sqrt =
    FFI.sqrt


degreesToRadians : Float -> Float
degreesToRadians =
    FFI.degreesToRadians


radiansToDegrees : Float -> Float
radiansToDegrees =
    FFI.radiansToDegrees


distance2D : Float -> Float -> Float -> Float -> Float
distance2D =
    FFI.distance2D


-- ============================================================================
-- FACTORIAL TESTS
-- ============================================================================


factorialTests : Test
factorialTests =
    describe "factorial"
        [ test "factorial 0 equals 1" <|
            \_ -> Expect.equal 1 (factorial 0)

        , test "factorial 1 equals 1" <|
            \_ -> Expect.equal 1 (factorial 1)

        , test "factorial 5 equals 120" <|
            \_ -> Expect.equal 120 (factorial 5)

        , test "factorial 10 equals 3628800" <|
            \_ -> Expect.equal 3628800 (factorial 10)
        ]


-- ============================================================================
-- FIBONACCI TESTS
-- ============================================================================


fibonacciTests : Test
fibonacciTests =
    describe "fibonacci"
        [ test "fibonacci 0 equals 0" <|
            \_ -> Expect.equal 0 (fibonacci 0)

        , test "fibonacci 1 equals 1" <|
            \_ -> Expect.equal 1 (fibonacci 1)

        , test "fibonacci 10 equals 55" <|
            \_ -> Expect.equal 55 (fibonacci 10)

        , test "fibonacci 20 equals 6765" <|
            \_ -> Expect.equal 6765 (fibonacci 20)
        ]


-- ============================================================================
-- GCD TESTS
-- ============================================================================


gcdTests : Test
gcdTests =
    describe "gcd"
        [ test "gcd 48 18 equals 6" <|
            \_ -> Expect.equal 6 (gcd 48 18)

        , test "gcd 7 13 equals 1 (coprime)" <|
            \_ -> Expect.equal 1 (gcd 7 13)

        , test "gcd 0 5 equals 5" <|
            \_ -> Expect.equal 5 (gcd 0 5)

        , test "gcd is commutative" <|
            \_ -> Expect.equal (gcd 48 18) (gcd 18 48)
        ]


-- ============================================================================
-- LCM TESTS
-- ============================================================================


lcmTests : Test
lcmTests =
    describe "lcm"
        [ test "lcm 4 6 equals 12" <|
            \_ -> Expect.equal 12 (lcm 4 6)

        , test "lcm 7 13 equals 91" <|
            \_ -> Expect.equal 91 (lcm 7 13)

        , test "lcm 0 5 equals 0" <|
            \_ -> Expect.equal 0 (lcm 0 5)

        , test "lcm is commutative" <|
            \_ -> Expect.equal (lcm 4 6) (lcm 6 4)
        ]


-- ============================================================================
-- PRIME TESTS
-- ============================================================================


primeTests : Test
primeTests =
    describe "isPrime"
        [ test "0 is not prime" <|
            \_ -> Expect.equal False (isPrime 0)

        , test "1 is not prime" <|
            \_ -> Expect.equal False (isPrime 1)

        , test "2 is prime" <|
            \_ -> Expect.equal True (isPrime 2)

        , test "17 is prime" <|
            \_ -> Expect.equal True (isPrime 17)

        , test "18 is not prime" <|
            \_ -> Expect.equal False (isPrime 18)

        , test "97 is prime" <|
            \_ -> Expect.equal True (isPrime 97)
        ]


-- ============================================================================
-- POWER TESTS
-- ============================================================================


powerTests : Test
powerTests =
    describe "power"
        [ test "power 2.0 0 equals 1.0" <|
            \_ -> Expect.equal 1.0 (power 2.0 0)

        , test "power 2.0 8 equals 256.0" <|
            \_ -> Expect.equal 256.0 (power 2.0 8)

        , test "power 3.0 4 equals 81.0" <|
            \_ -> Expect.equal 81.0 (power 3.0 4)

        , test "power 10.0 3 equals 1000.0" <|
            \_ -> Expect.equal 1000.0 (power 10.0 3)
        ]


-- ============================================================================
-- SQRT TESTS
-- ============================================================================


sqrtTests : Test
sqrtTests =
    describe "sqrt"
        [ test "sqrt 0.0 equals Ok 0.0" <|
            \_ -> Expect.equal (Ok 0.0) (sqrt 0.0)

        , test "sqrt 4.0 equals Ok 2.0" <|
            \_ -> Expect.equal (Ok 2.0) (sqrt 4.0)

        , test "sqrt 9.0 equals Ok 3.0" <|
            \_ -> Expect.equal (Ok 3.0) (sqrt 9.0)

        , test "sqrt 16.0 equals Ok 4.0" <|
            \_ -> Expect.equal (Ok 4.0) (sqrt 16.0)

        , test "sqrt of negative returns error" <|
            \_ ->
                case sqrt (-1.0) of
                    Err _ -> Expect.pass
                    Ok _ -> Expect.fail "Expected Err for negative input"
        ]


-- ============================================================================
-- ANGLE CONVERSION TESTS
-- ============================================================================


angleConversionTests : Test
angleConversionTests =
    describe "angle conversions"
        [ test "0 degrees equals 0 radians" <|
            \_ -> Expect.equal 0.0 (degreesToRadians 0.0)

        , test "90 degrees is approximately pi/2" <|
            \_ -> Expect.within (Expect.Absolute 0.0001) 1.5708 (degreesToRadians 90.0)

        , test "180 degrees is approximately pi" <|
            \_ -> Expect.within (Expect.Absolute 0.0001) 3.1416 (degreesToRadians 180.0)

        , test "0 radians equals 0 degrees" <|
            \_ -> Expect.equal 0.0 (radiansToDegrees 0.0)

        , test "roundtrip conversion for 45 degrees" <|
            \_ -> Expect.within (Expect.Absolute 0.0001) 45.0 (radiansToDegrees (degreesToRadians 45.0))
        ]


-- ============================================================================
-- DISTANCE TESTS
-- ============================================================================


distanceTests : Test
distanceTests =
    describe "distance2D"
        [ test "3-4-5 triangle" <|
            \_ -> Expect.equal 5.0 (distance2D 0.0 0.0 3.0 4.0)

        , test "5-12-13 triangle" <|
            \_ -> Expect.equal 13.0 (distance2D 0.0 0.0 5.0 12.0)

        , test "distance from point to itself is 0" <|
            \_ -> Expect.equal 0.0 (distance2D 5.0 5.0 5.0 5.0)

        , test "distance is symmetric" <|
            \_ -> Expect.equal (distance2D 0.0 0.0 3.0 4.0) (distance2D 3.0 4.0 0.0 0.0)
        ]
