TokenPn 40493 2060 1) "//   https://github.com/elm/core/issues/980",WhiteSpace (TokenPn 40536 2060 44) "\n",CommentA (TokenPn 40537 2061 1) "//   https://github.com/elm/core/pull/981",WhiteSpace (TokenPn 40578 2061 42) "\n",CommentA (TokenPn 40579 2062 1) "//   https://github.com/elm/compiler/issues/1776",WhiteSpace (TokenPn 40627 2062 49) "\n",CommentA (TokenPn 40628 2063 1) "//",WhiteSpace (TokenPn 40630 2063 3) "\n",CommentA (TokenPn 40631 2064 1) "// The queue is necessary to avoid ordering issues for synchronous commands.",WhiteSpace (TokenPn 40707 2064 77) "\n\n\n",CommentA (TokenPn 40710 2067 1) "// Why use true/false here? Why not just check the length of the queue?",WhiteSpace (TokenPn 40781 2067 72) "\n",CommentA (TokenPn 40782 2068 1) "// The goal is to detect \"are we currently dispatching effects?\" If we",WhiteSpace (TokenPn 40852 2068 71) "\n",CommentA (TokenPn 40853 2069 1) "// are, we need to bail and let the ongoing while loop handle things.",WhiteSpace (TokenPn 40922 2069 70) "\n",CommentA (TokenPn 40923 2070 1) "//",WhiteSpace (TokenPn 40925 2070 3) "\n",CommentA (TokenPn 40926 2071 1) "// Now say the queue has 1 element. When we dequeue the final element,",WhiteSpace (TokenPn 40996 2071 71) "\n",CommentA (TokenPn 40997 2072 1) "// the queue will be empty, but we are still actively dispatching effects.",WhiteSpace (TokenPn 41071 2072 75) "\n",CommentA (TokenPn 41072 2073 1) "// So you could get queue jumping in a really tricky category of cases.",WhiteSpace (TokenPn 41143 2073 72) "\n",CommentA (TokenPn 41144 2074 1) "//",WhiteSpace (TokenPn 41146 2074 3) "\n"]) (JSLOne (JSVarInitExpression (JSIdentifier (JSAnnot (TokenPn 41151 2075 5) [WhiteSpace (TokenPn 41150 2075 4) " "]) "_Platform_effectsQueue") (JSVarInit (JSAnnot (TokenPn 41174 2075 28) [WhiteSpace (TokenPn 41173 2075 27) " "]) (JSArrayLiteral (JSAnnot (TokenPn 41176 2075 30) [WhiteSpace (TokenPn 41175 2075 29) " "]) [] (JSAnnot (TokenPn 41177 2075 31) []))))) (JSSemi (JSAnnot (TokenPn 41