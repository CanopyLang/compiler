module TestFFIVoid exposing (startOscillator, stopOscillator)

foreign import javascript "examples/audio-ffi/external/audio.js" as AudioFFI

type OscillatorNode = OscillatorNode

-- Test 1: Direct FFI call returning ()
startOscillator : OscillatorNode -> Float -> ()
startOscillator osc when =
    AudioFFI.startOscillator osc when

-- Test 2: Alias for FFI function  
stopOscillator : OscillatorNode -> Float -> ()
stopOscillator = AudioFFI.stopOscillator
