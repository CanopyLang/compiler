module TestFixVerification exposing (main)

-- This test verifies that elm/core modules are now available during canonicalization
import List
import Basics
import Maybe

main =
    -- Test that we can use elm/core functions that previously failed
    let
        numbers = [1, 2, 3, 4, 5]
        doubled = List.map (Basics.multiply 2) numbers
        maybeFirst = List.head doubled
    in
    case maybeFirst of
        Maybe.Nothing -> 0
        Maybe.Just x -> x